---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import HomeHeader from "@sections/homepage/HomeHeader.astro";
import SiteFooter from "@components/layout/SiteFooter.astro";
import ProjectDetailHero from "@sections/project-page/ProjectDetailHero.astro";
import ProjectDetailStats from "@sections/project-page/ProjectDetailStats.astro";
import ProjectDetailBenefits from "@sections/project-page/ProjectDetailBenefits.astro";
import ProjectDetailPlans from "@sections/project-page/ProjectDetailPlans.astro";
import ProjectDetailGallery from "@sections/project-page/ProjectDetailGallery.astro";
import ProjectDetailPurchase from "@sections/project-page/ProjectDetailPurchase.astro";
import ProjectDetailProgress from "@sections/project-page/ProjectDetailProgress.astro";
import ProjectDetailContact from "@sections/project-page/ProjectDetailContact.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects");

  return projects.map((project) => ({
    params: { slug: project.data.slug ?? project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const slug = project.data.slug ?? project.id;
const title = `${project.data.name} · One Construction`;
const description = project.data.seoDescription ?? project.data.description;
const projectDetailNavItems = [
  { label: "Главная", href: "#hero" },
  { label: "Преимущества", href: "#benefits" },
  { label: "Планировки", href: "#plans" },
  { label: "Галерея", href: "#gallery" },
  { label: "Варианты покупки", href: "#purchase" },
  { label: "Этапы строительства", href: "#progress" },
  { label: "Контакты", href: "#contact" },
];
---

<Layout title={title} description={description}>
  <HomeHeader navItems={projectDetailNavItems} mobileCtaHref="#contact" />
  <main id="main" class="overflow-x-hidden bg-[#FBFBFA]">
    <ProjectDetailHero project={project} slug={slug} />
    <ProjectDetailStats project={project} />
    <ProjectDetailBenefits project={project} />
    <ProjectDetailPlans project={project} />
    <ProjectDetailGallery project={project} />
    <ProjectDetailPurchase project={project} />
    <ProjectDetailProgress project={project} />
    <ProjectDetailContact project={project} />
  </main>
  <SiteFooter variant="compact" />
</Layout>
