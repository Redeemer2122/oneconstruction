---
import Layout from "@layouts/Layout.astro";
import HomeHeader from "@sections/homepage/HomeHeader.astro";
import HomeHero from "@sections/homepage/HomeHero.astro";
import HomeProjects from "@sections/homepage/HomeProjects.astro";
import HomeAbout from "@sections/homepage/HomeAbout.astro";
import HomeTimeline from "@sections/homepage/HomeTimeline.astro";
import HomePurchase from "@sections/homepage/HomePurchase.astro";
import HomeContact from "@sections/homepage/HomeContact.astro";
---

<Layout>
  <HomeHeader />
  <main>
    <HomeHero />
    <HomeProjects />
    <HomeAbout />
    <HomeTimeline />
    <HomePurchase />
    <HomeContact />
  </main>

  <footer class="relative bg-[#0f172a] text-alabaster border-t-[0.5px] border-slate-900">
    <!-- Top: massive monogram + nav -->
    <div class="px-6 md:px-10 lg:px-12 pt-16 md:pt-24 pb-12 grid grid-cols-1 lg:grid-cols-12 gap-12 border-b border-slate-800">
      <!-- Monogram -->
      <div class="lg:col-span-6 flex flex-col gap-6">
        <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-slate-500">
          ONE CONSTRUCTION · BISHKEK · KG
        </span>
        <h2 class="font-mono text-[16vw] md:text-[9vw] lg:text-[7.4vw] leading-[0.86] tracking-[-0.04em] uppercase text-alabaster">
          ONE<br />CONSTRUCTION
        </h2>
        <p class="text-sm text-slate-400 max-w-[42ch] leading-relaxed mt-4">
          Девелопер премиальных жилых комплексов в Кыргызстане. Архитектура без компромиссов с 2014 года.
        </p>
      </div>

      <!-- Nav columns -->
      <div class="lg:col-span-6 grid grid-cols-2 md:grid-cols-3 gap-8">
        <div class="flex flex-col gap-3">
          <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-slate-500 pb-3 border-b border-slate-800">Сайт</span>
          <a href="#projects" class="font-mono text-sm uppercase tracking-[0.12em] text-slate-300 hover:text-violet-400 transition-colors">Объекты</a>
          <a href="#about" class="font-mono text-sm uppercase tracking-[0.12em] text-slate-300 hover:text-violet-400 transition-colors">О компании</a>
          <a href="#privileges" class="font-mono text-sm uppercase tracking-[0.12em] text-slate-300 hover:text-violet-400 transition-colors">Стандарт</a>
          <a href="#purchase" class="font-mono text-sm uppercase tracking-[0.12em] text-slate-300 hover:text-violet-400 transition-colors">Покупка</a>
          <a href="#contact" class="font-mono text-sm uppercase tracking-[0.12em] text-slate-300 hover:text-violet-400 transition-colors">Контакты</a>
        </div>

        <div class="flex flex-col gap-3">
          <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-slate-500 pb-3 border-b border-slate-800">Связь</span>
          <a href="tel:+996555100100" class="font-mono text-sm text-slate-300 hover:text-violet-400 transition-colors">+996 555 100 100</a>
          <a href="tel:+996700100100" class="font-mono text-sm text-slate-300 hover:text-violet-400 transition-colors">+996 700 100 100</a>
          <a href="mailto:info@oneconstruction.kg" class="font-mono text-sm text-slate-300 hover:text-violet-400 transition-colors break-all">info@oneconstruction.kg</a>
        </div>

        <div class="flex flex-col gap-3 col-span-2 md:col-span-1">
          <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-slate-500 pb-3 border-b border-slate-800">Офис</span>
          <span class="font-mono text-sm text-slate-300 leading-relaxed">
            г. Бишкек,<br/>ул. Раззакова 32
          </span>
          <span class="font-mono text-[11px] uppercase tracking-[0.16em] text-slate-500">
            ПН — СБ · 10:00 — 19:00
          </span>
        </div>
      </div>
    </div>

    <!-- Bottom strip -->
    <div class="px-6 md:px-10 lg:px-12 py-8 grid grid-cols-1 md:grid-cols-12 gap-6 items-center">
      <div class="md:col-span-6 flex items-center gap-3">
        <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-slate-500">
          © 2026 ONE CONSTRUCTION KG · ВСЕ ПРАВА ЗАЩИЩЕНЫ
        </span>
      </div>
      <div class="md:col-span-6 flex flex-wrap md:justify-end gap-6">
        <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-slate-500">BUILD 0.2.0</span>
        <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-slate-500">ASTRO 6.3</span>
        <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-slate-500">42.8746° N · 74.5698° E</span>
      </div>
    </div>
  </footer>
</Layout>

