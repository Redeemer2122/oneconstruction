---
/**
 * Legacy / currently unused component.
 * Keep for future project pages or quality/material sections.
 */
interface Props {
  slug: string;
  name: string;
  index: string;
  cover: string;
  location: string;
  coordinates: string;
  status: string;
  units?: string;
  aspect?: string;
  fill?: boolean;
}

const {
  slug,
  name,
  index,
  cover,
  location,
  coordinates,
  status,
  units,
  aspect = "aspect-[4/5]",
  fill = false,
} = Astro.props;
---

<article class={`group flex flex-col ${fill ? "h-full" : ""}`}>
  <a
    href={`/projects/${slug}`}
    class={`block border border-[oklch(0.195_0.018_42_/_0.14)]
            transition-colors duration-[800ms] ease-[cubic-bezier(0.625,0.05,0,1)]
            hover:border-[oklch(0.195_0.018_42_/_0.40)]
            focus-visible:border-[oklch(0.48_0.20_285)] focus-visible:outline-none
            ${fill ? "flex flex-col h-full" : ""}`}
  >
    <!-- Изображение -->
    <div class={`relative ${fill ? "flex-1 min-h-0" : aspect} overflow-hidden bg-[#ede9e1]`}>
      <img
        src={cover}
        alt={`ЖК ${name} — дневной рендер`}
        loading="lazy"
        decoding="async"
        class="absolute inset-0 h-full w-full object-cover will-change-transform
               transition-transform duration-[1400ms] ease-[cubic-bezier(0.625,0.05,0,1)]
               group-hover:scale-[1.04]"
      />
      <!-- Нижний scrim -->
      <div
        aria-hidden="true"
        class="pointer-events-none absolute inset-0 bg-gradient-to-t from-[#38332f]/50 via-transparent to-transparent"
      />
      <span class="absolute top-4 left-4 font-mono text-[10px] uppercase tracking-[0.22em] text-[#f2efe9]/90">
        {index}
      </span>
      <span class="absolute top-4 right-4 font-mono text-[10px] uppercase tracking-[0.22em] text-[#f2efe9]/90">
        {status}
      </span>
    </div>

    <!-- Metadata-блок — чистый, плоский, Lagom card bg -->
    <div class="px-5 md:px-6 pt-6 pb-5 flex flex-col gap-5
                border-t border-[oklch(0.195_0.018_42_/_0.10)]
                bg-[#fbfbf9]">
      <h3 class="display text-3xl md:text-5xl leading-[0.92] tracking-tighter text-[#38332f]
                 transition-colors duration-[600ms] ease-[cubic-bezier(0.625,0.05,0,1)]
                 group-hover:text-[oklch(0.48_0.20_285)]">
        {name}
      </h3>

      <dl class="grid grid-cols-2 gap-x-6 gap-y-3 mt-1">
        <div class="flex flex-col gap-1">
          <dt class="font-mono text-[9px] uppercase tracking-[0.22em] text-[#a39c8c]">
            КООРДИНАТЫ
          </dt>
          <dd class="font-mono text-[11px] uppercase tracking-[0.14em] text-[#38332f]">
            {coordinates}
          </dd>
        </div>
        <div class="flex flex-col gap-1">
          <dt class="font-mono text-[9px] uppercase tracking-[0.22em] text-[#a39c8c]">
            ЛОКАЦИЯ
          </dt>
          <dd class="font-mono text-[11px] uppercase tracking-[0.14em] text-[#38332f]">
            {location}
          </dd>
        </div>
        {units && (
          <div class="flex flex-col gap-1 col-span-2">
            <dt class="font-mono text-[9px] uppercase tracking-[0.22em] text-[#a39c8c]">
              ПЛАНИРОВКИ
            </dt>
            <dd class="font-mono text-[11px] uppercase tracking-[0.14em] text-[#38332f]">
              {units}
            </dd>
          </div>
        )}
      </dl>
    </div>
  </a>
</article>
