---
interface Props {
  project: any;
}

const { project } = Astro.props;
const data = project.data;
const options =
  data.purchaseOptions?.length
    ? data.purchaseOptions
    : data.installment
      ? [
          {
            title: data.installment.label,
            body: data.installment.note ?? "Условия покупки уточняются отделом продаж.",
            meta: data.installment.maxMonths ? `до ${data.installment.maxMonths} месяцев` : "по консультации",
            status: data.installment.status,
          },
        ]
      : [];

const accentOptionIndex = options.findIndex(
  (option: any) => option.status === "confirmed" && option.title?.toLowerCase().includes("рассроч")
);
const accentIndex = accentOptionIndex >= 0 ? accentOptionIndex : 0;
const ctaByTitle: Record<string, string> = {
  "Полная оплата": "Оставить заявку",
  "Рассрочка": "Узнать условия",
  "Рассрочка 0%": "Узнать условия",
  "Бартер на авто": "Обсудить условия",
  "Бонусная программа": "Получить консультацию",
};
const fallbackCtas = ["Оставить заявку", "Узнать условия", "Обсудить условия", "Получить консультацию"];
const getCtaLabel = (option: any, index: number) => ctaByTitle[option.title] ?? fallbackCtas[index] ?? "Обсудить условия";
---

{
  options.length > 0 && (
    <section id="purchase" class="relative overflow-hidden bg-[#F5F4F0] px-5 py-20 md:px-8 md:py-24 lg:px-10" aria-labelledby="purchase-title">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-slate-950/10" aria-hidden="true" />

      <div class="mx-auto grid max-w-[1480px] gap-12 lg:grid-cols-[0.35fr_0.65fr] lg:gap-14 xl:gap-20">
        <div class="border-t-[0.5px] border-slate-900/15 pt-8 lg:self-start">
          <p class="mono-detail text-violet-700">ВАРИАНТЫ ПОКУПКИ</p>
          <p class="mt-5 font-mono text-[10px] uppercase tracking-[0.18em] text-slate-500">
            РАССРОЧКА / ОПЛАТА / БАРТЕР / БОНУСЫ
          </p>
          <h2 id="purchase-title" class="mt-6 max-w-[10.5ch] text-[2.75rem] font-medium leading-[0.98] text-slate-950 [text-wrap:balance] md:text-[3.65rem] xl:text-[4.15rem]">
            Выберите удобный вариант покупки
          </h2>
          <p class="mt-7 max-w-[46ch] text-[15px] leading-8 text-slate-600 md:text-base md:leading-8">
            Мы предлагаем прозрачные и гибкие схемы оплаты, чтобы каждая квартира была доступна в соответствии с вашими планами и возможностями.
          </p>
          <aside class="mt-8 border-y-[0.5px] border-slate-900/15 py-5">
            <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-violet-700">Важно</p>
            <p class="mt-3 max-w-[42ch] text-sm leading-7 text-slate-600">
              Финальные условия покупки уточняются у менеджера и зависят от выбранной планировки.
            </p>
          </aside>
        </div>

        <div class="grid gap-3 md:grid-cols-2">
          {options.map((option: any, index: number) => {
            const isAccent = index === accentIndex;

            return (
              <article
                class={`group/card flex min-h-[260px] flex-col border-[0.5px] p-6 transition duration-300 ease-out hover:-translate-y-0.5 md:min-h-[286px] lg:p-7 ${
                  isAccent
                    ? "border-slate-950 bg-slate-950 text-alabaster shadow-[0_16px_42px_rgba(15,23,42,0.08)]"
                    : "border-slate-900/10 bg-[#FBFBFA] text-slate-950 hover:border-violet-700/35 hover:bg-[#F8F7F4]"
                }`}
              >
                <div class="flex items-start justify-between gap-4">
                  <span class={`font-mono text-[11px] uppercase tracking-[0.18em] ${isAccent ? "text-violet-300" : "text-violet-700"}`}>
                    {String(index + 1).padStart(2, "0")}
                  </span>
                  {option.status === "needs_verification" && (
                    <span class={`border-[0.5px] px-2 py-1 font-mono text-[9px] uppercase tracking-[0.12em] ${isAccent ? "border-slate-100/15 text-slate-300" : "border-slate-900/15 text-slate-500"}`}>
                      Уточнить
                    </span>
                  )}
                </div>

                <div class="mt-10">
                  <h3 class={`text-2xl font-medium leading-tight [text-wrap:balance] ${isAccent ? "text-alabaster" : "text-slate-950"}`}>{option.title}</h3>
                  {option.meta && (
                    <p class={`mt-4 font-mono text-[12px] uppercase tracking-[0.12em] ${isAccent ? "text-violet-300" : "text-violet-700"}`}>
                      {option.meta}
                    </p>
                  )}
                  <p class={`mt-5 max-w-[34ch] text-sm leading-7 ${isAccent ? "text-slate-200" : "text-slate-600"}`}>{option.body}</p>
                </div>

                <a
                  href="#contact"
                  class={`mt-auto flex items-center justify-between gap-4 border-t-[0.5px] pt-6 font-mono text-[11px] uppercase tracking-[0.16em] transition-colors duration-300 focus-visible:outline focus-visible:outline-1 focus-visible:outline-offset-4 ${
                    isAccent
                      ? "border-slate-100/15 text-alabaster hover:text-violet-300 focus-visible:text-violet-300 focus-visible:outline-violet-300"
                      : "border-slate-900/10 text-slate-950 hover:text-violet-700 focus-visible:text-violet-700 focus-visible:outline-violet-700"
                  }`}
                >
                  {getCtaLabel(option, index)}
                  <span aria-hidden="true" class="transition-transform duration-300 ease-out group-hover/card:translate-x-1">
                    →
                  </span>
                </a>
              </article>
            );
          })}
        </div>
      </div>
    </section>
  )
}
