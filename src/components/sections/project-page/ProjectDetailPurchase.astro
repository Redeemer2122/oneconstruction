---
interface Props {
  project: any;
}

const { project } = Astro.props;
const data = project.data;
const options =
  data.purchaseOptions?.length
    ? data.purchaseOptions
    : data.installment
      ? [
          {
            title: data.installment.label,
            body: data.installment.note ?? "Условия покупки уточняются отделом продаж.",
            meta: data.installment.maxMonths ? `до ${data.installment.maxMonths} месяцев` : "по консультации",
            status: data.installment.status,
          },
        ]
      : [];
---

{
  options.length > 0 && (
    <section class="bg-[#F5F4F0] px-5 py-20 md:px-8 md:py-28 lg:px-10" aria-labelledby="purchase-title">
      <div class="mx-auto grid max-w-[1480px] gap-12 lg:grid-cols-[0.36fr_1fr]">
        <div class="border-t-[0.5px] border-slate-900/15 pt-8">
          <p class="mono-detail text-violet-700">Варианты покупки</p>
          <h2 id="purchase-title" class="mt-5 text-4xl font-medium leading-[1.02] text-slate-950 md:text-6xl">
            Удобные условия для вас
          </h2>
          <p class="mt-6 max-w-[38ch] text-sm leading-7 text-slate-600">
            Показываем только безопасные условия из текущих данных. Детали менеджер подтверждает перед бронированием.
          </p>
        </div>

        <div class="grid gap-px bg-slate-900/10 p-px md:grid-cols-2 xl:grid-cols-4">
          {options.map((option: any, index: number) => (
            <article class={`flex min-h-[310px] flex-col p-6 transition-colors duration-500 lg:p-7 ${index === 0 ? "bg-slate-950 text-alabaster" : "bg-[#FBFBFA] text-slate-950 hover:bg-[#F8F7F4]"}`}>
              <div class="flex items-start justify-between gap-4">
                <span class={`font-mono text-[11px] uppercase tracking-[0.18em] ${index === 0 ? "text-violet-300" : "text-violet-700"}`}>
                  {String(index + 1).padStart(2, "0")}
                </span>
                {option.status === "needs_verification" && (
                  <span class="border-[0.5px] border-slate-900/15 px-2 py-1 font-mono text-[9px] uppercase tracking-[0.12em] text-slate-500">
                    Проверить
                  </span>
                )}
              </div>
              <h3 class={`mt-12 text-2xl font-medium leading-tight ${index === 0 ? "text-alabaster" : "text-slate-950"}`}>{option.title}</h3>
              {option.meta && <p class={`mt-3 font-mono text-[12px] uppercase tracking-[0.12em] ${index === 0 ? "text-violet-300" : "text-violet-700"}`}>{option.meta}</p>}
              <p class={`mt-5 text-sm leading-7 ${index === 0 ? "text-slate-200" : "text-slate-600"}`}>{option.body}</p>
              <a href="#contact" class={`mt-auto flex items-center justify-between gap-4 border-t-[0.5px] pt-6 font-mono text-[11px] uppercase tracking-[0.16em] transition-colors duration-300 ${index === 0 ? "border-slate-100/15 text-alabaster hover:text-violet-300" : "border-slate-900/10 text-slate-950 hover:text-violet-700"}`}>
                Обсудить условия
                <span aria-hidden="true">→</span>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>
  )
}
