---
interface Props {
  project: any;
}

const { project } = Astro.props;
const data = project.data;
const plans = data.plans ?? [];
const tabs: string[] = ["Все", ...Array.from(new Set<string>(plans.map((plan: any) => String(plan.rooms))))];
const gridColumns = plans.length === 2 ? "md:grid-cols-2 xl:grid-cols-2" : "md:grid-cols-2 xl:grid-cols-3";
---

{
  plans.length > 0 && (
    <section id="plans" class="bg-[#F5F4F0] px-5 py-20 md:px-8 md:py-28 lg:px-10" aria-labelledby="plans-title">
      <div class="mx-auto max-w-[1480px]">
        <div class="grid gap-8 lg:grid-cols-[0.42fr_1fr] lg:items-end">
          <div class="border-t-[0.5px] border-slate-900/15 pt-8">
            <p class="mono-detail text-violet-700">Планировки</p>
            <h2 id="plans-title" class="mt-5 text-5xl font-medium leading-[0.96] text-slate-950 md:text-6xl">
              Выберите свой формат
            </h2>
          </div>
          <div class="flex flex-wrap gap-px bg-slate-900/12 p-px lg:justify-self-end lg:pb-px">
            {tabs.map((tab: string, index: number) => (
              <span class={`max-w-full px-4 py-2.5 text-center font-mono text-[10px] uppercase tracking-[0.13em] ${index === 0 ? "bg-slate-950 text-alabaster" : "bg-[#FBFBFA] text-slate-600"}`}>
                {tab}
              </span>
            ))}
          </div>
        </div>

        <div class={`mt-12 grid gap-5 ${gridColumns}`}>
          {plans.map((plan: any, index: number) => (
            <article class="group grid border-[0.5px] border-slate-900/10 bg-[#FBFBFA] transition-colors duration-500 hover:bg-[#F8F7F4]">
              <div class="relative aspect-[5/3.35] overflow-hidden bg-blueprint">
                <img
                  src={plan.image ?? "/img/privileges/plan.jpg"}
                  alt={`Планировка ${plan.rooms} в ${data.name}`}
                  class="absolute inset-0 h-full w-full object-cover mix-blend-multiply transition-transform duration-[900ms] ease-[cubic-bezier(0.625,0.05,0,1)] group-hover:scale-[1.03]"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="flex min-h-0 flex-col gap-5 p-6 md:p-7">
                <div class="flex items-start justify-between gap-5">
                  <span class="font-mono text-[11px] uppercase tracking-[0.18em] text-slate-400">
                    {String(index + 1).padStart(2, "0")}
                  </span>
                  {plan.note && <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-violet-700">{plan.note}</span>}
                </div>
                <div>
                  <h3 class="text-3xl font-medium leading-tight text-slate-950">
                    {plan.rooms}
                  </h3>
                  <p class="mt-4 font-mono text-[12px] uppercase tracking-[0.12em] text-slate-600">
                    {plan.area}
                  </p>
                  <p class="mt-3 max-w-[34ch] text-sm leading-6 text-slate-600">
                    {plan.note ? `Формат: ${plan.note}.` : "Параметры и доступность уточняются с менеджером."}
                  </p>
                  {plan.price && plan.price !== "по запросу" && (
                    <p class="mt-3 font-mono text-[11px] uppercase tracking-[0.12em] text-slate-400">
                      {plan.price}
                    </p>
                  )}
                </div>
                <a
                  href="#contact"
                  class="mt-auto inline-flex min-h-12 w-fit items-center border-[0.5px] border-slate-900/25 px-5 py-3 font-mono text-[11px] uppercase tracking-[0.14em] text-slate-950 transition-colors duration-300 hover:border-slate-950 hover:bg-slate-950 hover:text-alabaster"
                >
                  Выбрать квартиру
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )
}
