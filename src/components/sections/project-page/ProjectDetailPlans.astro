---
interface Props {
  project: any;
}

const { project } = Astro.props;
const data = project.data;
const plans = data.plans ?? [];

const getRoomCount = (value: string) => value.match(/\d+/)?.[0] ?? "";
const getCategory = (value: string) => {
  const count = getRoomCount(value);
  return count ? `${count}-комнатные` : value;
};
const getCompactCategory = (value: string) => {
  const count = getRoomCount(value);
  return count ? `${count}-комнатная` : value;
};
const getTitle = (value: string) => {
  const count = getRoomCount(value);
  if (!count || value.toLowerCase().includes("квартира")) return value;
  return `${count}-комнатная квартира`;
};
const getAreaNumber = (value: string) => Number.parseFloat(value.replace(",", ".").replace(/[^\d.]/g, ""));
const minArea = plans.reduce((lowest: number | null, plan: any) => {
  const area = getAreaNumber(String(plan.area ?? ""));
  if (!Number.isFinite(area)) return lowest;
  return lowest === null || area < lowest ? area : lowest;
}, null);
const minAreaText = minArea ? minArea.toFixed(1).replace(/\.0$/, "") : "";
const metaText = `${plans.length} планировок${minAreaText ? ` / от ${minAreaText} м²` : ""}`;
const filterOrder = ["1-комнатные", "2-комнатные", "3-комнатные"];
const availableFilters = filterOrder.filter((filter) => plans.some((plan: any) => getCategory(String(plan.rooms)) === filter));
const filters = ["Все", ...availableFilters];
const shouldLimitAll = plans.length > 6;
const gridColumns = plans.length === 2 ? "md:grid-cols-2 xl:grid-cols-2" : "md:grid-cols-2 xl:grid-cols-3";
---

{
  plans.length > 0 && (
    <section
      id="plans"
      class="bg-[#F5F4F0] px-5 py-20 md:px-8 md:py-28 lg:px-10"
      aria-labelledby="plans-title"
      data-plan-selector
      data-all-limit="6"
    >
      <div class="mx-auto max-w-[1480px]">
        <div class="grid gap-10 border-t-[0.5px] border-slate-900/18 pt-8 lg:grid-cols-[minmax(0,0.46fr)_minmax(560px,0.54fr)] lg:items-end">
          <div>
            <div class="flex items-center gap-4">
              <p class="mono-detail text-violet-700">ПЛАНИРОВКИ</p>
              <span class="h-px w-12 bg-slate-900/15" aria-hidden="true"></span>
            </div>
            <h2 id="plans-title" class="project-section-title mt-5 max-w-[11ch] text-balance">
              Выберите свой формат
            </h2>
            <p class="mt-6 max-w-[58ch] text-sm leading-7 text-slate-600 md:text-base md:leading-8">
              От компактных 1-комнатных до просторных семейных форматов — подберите планировку под свой сценарий жизни.
            </p>
            <div class="mt-6 flex max-w-[26rem] items-center gap-4 border-t-[0.5px] border-slate-900/15 pt-3">
              <span class="h-1.5 w-1.5 bg-violet-700" aria-hidden="true"></span>
              <p class="font-mono text-[11px] uppercase tracking-[0.14em] text-slate-500">
                {metaText}
              </p>
            </div>
          </div>

          <div class="min-w-0 lg:justify-self-end">
            <div
              class="plan-filter-shell flex max-w-full gap-1 overflow-x-auto border-[0.5px] border-slate-900/15 bg-[#FBFBFA] p-1 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden lg:flex-wrap lg:justify-end"
              role="group"
              aria-label="Фильтр планировок"
            >
              {filters.map((filter: string, index: number) => (
                <button
                  type="button"
                  class="plan-filter-button shrink-0 border-[0.5px] border-slate-900/10 px-5 py-3.5 text-center font-mono text-[11px] uppercase tracking-[0.12em] text-slate-600 transition-colors duration-300 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-violet-700 md:min-w-[140px] md:px-6"
                  data-plan-filter={filter}
                  aria-pressed={index === 0 ? "true" : "false"}
                >
                  {filter}
                </button>
              ))}
            </div>
          </div>
        </div>

        <div class={`plans-grid mt-14 grid gap-4 md:gap-5 ${gridColumns}`} data-plan-grid>
          {plans.map((plan: any, index: number) => {
            const category = getCategory(String(plan.rooms));
            const compactCategory = getCompactCategory(String(plan.rooms));
            const isInitiallyHidden = shouldLimitAll && index >= 6;

            return (
              <article
                class={`plan-card group grid min-h-[540px] border-[0.5px] border-slate-900/10 bg-[#FBFBFA] transition duration-300 ease-out hover:-translate-y-0.5 hover:border-slate-950/35 hover:bg-[#F8F7F4] ${isInitiallyHidden ? "hidden" : ""}`}
                data-plan-card
                data-plan-category={category}
                data-plan-index={index}
              >
                <div class="plan-media relative aspect-[4/3] overflow-hidden p-3 md:p-4">
                  <img
                    src={plan.image ?? "/img/privileges/plan.jpg"}
                    alt={`Планировка ${getTitle(String(plan.rooms))}, ${plan.area}, ${data.name}`}
                    class="plan-image h-full w-full object-contain mix-blend-multiply transition-transform duration-[900ms] ease-[cubic-bezier(0.625,0.05,0,1)]"
                    loading="lazy"
                    decoding="async"
                  />
                  <div class="plan-index absolute left-0 top-0 bg-[#FBFBFA]/94 px-4 py-3 font-mono text-[11px] uppercase tracking-[0.18em] text-slate-500 backdrop-blur-sm">
                    {String(index + 1).padStart(2, "0")}
                  </div>
                </div>

                <div class="plan-content flex min-h-0 flex-col p-7 md:p-8">
                  <div class="flex items-start justify-between gap-5">
                    <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-violet-700">
                      {compactCategory}
                    </span>
                    {plan.note && (
                      <span class="max-w-[18ch] text-right font-mono text-[10px] uppercase tracking-[0.12em] text-slate-400">
                        {plan.note}
                      </span>
                    )}
                  </div>

                  <div class="plan-body mt-12">
                    <h3 class="plan-title text-3xl font-medium leading-tight text-slate-950">
                      {getTitle(String(plan.rooms))}
                    </h3>
                    <p class="plan-area mt-4 font-mono text-[13px] uppercase tracking-[0.12em] text-slate-600">
                      {plan.area}
                    </p>
                    <p class="plan-note mt-5 max-w-[36ch] text-sm leading-7 text-slate-600">
                      {plan.note ?? "Планировка для ежедневного городского сценария."}
                    </p>
                  </div>

                  <a
                    href="#contact"
                    class="plan-cta mt-auto flex items-center justify-between gap-4 border-t-[0.5px] border-slate-900/18 pt-6 font-mono text-[11px] font-medium uppercase tracking-[0.16em] text-slate-950 transition-colors duration-300 group-hover:border-slate-950/35 group-hover:text-violet-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-violet-700"
                  >
                    Выбрать квартиру
                    <span class="plan-cta-arrow transition-transform duration-300 ease-out" aria-hidden="true">→</span>
                  </a>
                </div>
              </article>
            );
          })}
        </div>

        {shouldLimitAll && (
          <div class="mt-11 border-t-[0.5px] border-slate-900/12 pt-7" data-plan-show-more-wrap>
            <button
              type="button"
              class="plan-show-more inline-flex min-h-10 items-center border-b-[0.5px] border-slate-900/25 pb-2 font-mono text-[11px] uppercase tracking-[0.14em] text-slate-950 transition-colors duration-300 hover:border-violet-700 hover:text-violet-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-violet-700"
              data-plan-show-more
              aria-expanded="false"
            >
              Показать все планировки →
            </button>
          </div>
        )}
      </div>

      <script>
        const selectors = document.querySelectorAll("[data-plan-selector]");

        selectors.forEach((selector) => {
          const buttons = Array.from(selector.querySelectorAll("[data-plan-filter]"));
          const cards = Array.from(selector.querySelectorAll("[data-plan-card]"));
          const showMoreWrap = selector.querySelector("[data-plan-show-more-wrap]");
          const showMoreButton = selector.querySelector("[data-plan-show-more]");
          const allLimit = Number(selector.getAttribute("data-all-limit") ?? 6);
          let activeFilter = "Все";
          let isAllExpanded = false;

          const setActiveButton = () => {
            buttons.forEach((button) => {
              const isActive = button.getAttribute("data-plan-filter") === activeFilter;
              button.setAttribute("aria-pressed", String(isActive));
            });
          };

          const updateCards = () => {
            const isAll = activeFilter === "Все";

            cards.forEach((card) => {
              const category = card.getAttribute("data-plan-category");
              const index = Number(card.getAttribute("data-plan-index") ?? 0);
              const matchesFilter = isAll || category === activeFilter;
              const exceedsCollapsedAll = isAll && !isAllExpanded && index >= allLimit;
              card.classList.toggle("hidden", !matchesFilter || exceedsCollapsedAll);
            });

            if (showMoreWrap && showMoreButton) {
              const shouldShow = isAll && !isAllExpanded && cards.length > allLimit;
              showMoreWrap.classList.toggle("hidden", !shouldShow);
              showMoreButton.setAttribute("aria-expanded", String(isAllExpanded));
            }

            setActiveButton();
          };

          buttons.forEach((button) => {
            button.addEventListener("click", () => {
              activeFilter = button.getAttribute("data-plan-filter") ?? "Все";
              isAllExpanded = false;
              updateCards();
            });
          });

          showMoreButton?.addEventListener("click", () => {
            activeFilter = "Все";
            isAllExpanded = true;
            updateCards();
          });

          updateCards();
        });
      </script>

      <style>
        .plan-filter-button[aria-pressed="true"] {
          background: #020617;
          border-color: #020617;
          color: #fbfbfa;
        }

        .project-section-title {
          font-family: var(--font-display, "Geist Variable", ui-sans-serif, system-ui, sans-serif);
          font-size: clamp(46px, 3.35vw, 64px);
          font-weight: 500;
          line-height: 0.96;
          letter-spacing: 0;
          color: #0e214c;
        }

        .plan-filter-button[aria-pressed="false"]:hover {
          background: #f5f4f0;
          color: #020617;
        }

        .plan-card:hover .plan-image {
          transform: scale(1.01);
        }

        .plan-card:hover .plan-cta-arrow {
          transform: translateX(0.35rem);
        }

        @media (max-width: 760px) {
          .project-section-title {
            font-size: clamp(34px, 9.8vw, 42px);
            line-height: 1;
          }
        }

        @media (max-width: 420px) {
          .project-section-title {
            font-size: 34px;
          }
        }
      </style>
    </section>
  )
}
