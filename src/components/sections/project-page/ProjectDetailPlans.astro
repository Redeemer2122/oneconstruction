---
interface Props {
  project: any;
}

const { project } = Astro.props;
const data = project.data;
const plans = data.plans ?? [];

const getRoomCount = (value: string) => value.match(/\d+/)?.[0] ?? "";
const getCategory = (value: string) => {
  const count = getRoomCount(value);
  return count ? `${count}-комнатные` : value;
};
const getTitle = (value: string) => {
  const count = getRoomCount(value);
  if (!count || value.toLowerCase().includes("квартира")) return value;
  return `${count}-комнатная квартира`;
};
const getAreaNumber = (value: string) => Number.parseFloat(value.replace(",", ".").replace(/[^\d.]/g, ""));
const minArea = plans.reduce((lowest: number | null, plan: any) => {
  const area = getAreaNumber(String(plan.area ?? ""));
  if (!Number.isFinite(area)) return lowest;
  return lowest === null || area < lowest ? area : lowest;
}, null);
const metaText = `${plans.length} планировок${minArea ? ` / от ${minArea.toLocaleString("ru-RU", { maximumFractionDigits: 1 })} м²` : ""}`;
const filterOrder = ["1-комнатные", "2-комнатные", "3-комнатные"];
const availableFilters = filterOrder.filter((filter) => plans.some((plan: any) => getCategory(String(plan.rooms)) === filter));
const filters = ["Все", ...availableFilters];
const shouldLimitAll = plans.length > 6;
const gridColumns = plans.length === 2 ? "md:grid-cols-2 xl:grid-cols-2" : "md:grid-cols-2 xl:grid-cols-3";
---

{
  plans.length > 0 && (
    <section
      id="plans"
      class="bg-[#F5F4F0] px-5 py-20 md:px-8 md:py-28 lg:px-10"
      aria-labelledby="plans-title"
      data-plan-selector
      data-all-limit="6"
    >
      <div class="mx-auto max-w-[1480px]">
        <div class="grid gap-8 border-t-[0.5px] border-slate-900/15 pt-8 lg:grid-cols-[minmax(0,0.52fr)_minmax(420px,0.48fr)] lg:items-end">
          <div>
            <p class="mono-detail text-violet-700">ПЛАНИРОВКИ</p>
            <h2 id="plans-title" class="mt-5 max-w-[11ch] text-5xl font-medium leading-[0.96] text-slate-950 text-balance md:text-6xl">
              Выберите свой формат
            </h2>
            <p class="mt-6 max-w-[58ch] text-sm leading-7 text-slate-600 md:text-base md:leading-8">
              От компактных 1-комнатных до просторных семейных форматов — подберите планировку под свой сценарий жизни.
            </p>
            <p class="mt-5 font-mono text-[11px] uppercase tracking-[0.14em] text-slate-500">
              {metaText}
            </p>
          </div>

          <div class="min-w-0 lg:justify-self-end">
            <div
              class="flex max-w-full gap-px overflow-x-auto bg-slate-900/12 p-px [scrollbar-width:none] [&::-webkit-scrollbar]:hidden lg:flex-wrap lg:justify-end"
              role="group"
              aria-label="Фильтр планировок"
            >
              {filters.map((filter: string, index: number) => (
                <button
                  type="button"
                  class={`shrink-0 px-4 py-3 text-center font-mono text-[10px] uppercase tracking-[0.13em] transition-colors duration-300 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-violet-700 md:px-5 ${index === 0 ? "bg-slate-950 text-alabaster" : "bg-[#FBFBFA] text-slate-600 hover:bg-[#F8F7F4] hover:text-slate-950"}`}
                  data-plan-filter={filter}
                  aria-pressed={index === 0 ? "true" : "false"}
                >
                  {filter}
                </button>
              ))}
            </div>
          </div>
        </div>

        <div class={`mt-12 grid gap-4 md:gap-5 ${gridColumns}`} data-plan-grid>
          {plans.map((plan: any, index: number) => {
            const category = getCategory(String(plan.rooms));
            const isInitiallyHidden = shouldLimitAll && index >= 6;

            return (
              <article
                class={`group grid min-h-[520px] border-[0.5px] border-slate-900/10 bg-[#FBFBFA] transition duration-300 ease-out hover:-translate-y-0.5 hover:border-slate-950/35 hover:bg-[#F8F7F4] ${isInitiallyHidden ? "hidden" : ""}`}
                data-plan-card
                data-plan-category={category}
                data-plan-index={index}
              >
                <div class="relative aspect-[5/3.55] overflow-hidden bg-blueprint">
                  <img
                    src={plan.image ?? "/img/privileges/plan.jpg"}
                    alt={`Планировка ${getTitle(String(plan.rooms))}, ${plan.area}, ${data.name}`}
                    class="absolute inset-0 h-full w-full object-cover mix-blend-multiply transition-transform duration-[900ms] ease-[cubic-bezier(0.625,0.05,0,1)] group-hover:scale-[1.035]"
                    loading="lazy"
                    decoding="async"
                  />
                  <div class="absolute left-0 top-0 bg-[#FBFBFA]/92 px-4 py-3 font-mono text-[11px] uppercase tracking-[0.18em] text-slate-500 backdrop-blur-sm">
                    {String(index + 1).padStart(2, "0")}
                  </div>
                </div>

                <div class="flex min-h-0 flex-col p-6 md:p-7">
                  <div class="flex items-start justify-between gap-5">
                    <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-violet-700">
                      {category}
                    </span>
                    {plan.note && (
                      <span class="max-w-[18ch] text-right font-mono text-[10px] uppercase tracking-[0.12em] text-slate-400">
                        {plan.note}
                      </span>
                    )}
                  </div>

                  <div class="mt-12">
                    <h3 class="text-3xl font-medium leading-tight text-slate-950">
                      {getTitle(String(plan.rooms))}
                    </h3>
                    <p class="mt-4 font-mono text-[13px] uppercase tracking-[0.12em] text-slate-600">
                      {plan.area}
                    </p>
                    <p class="mt-5 max-w-[36ch] text-sm leading-7 text-slate-600">
                      {plan.note ?? "Планировка для ежедневного городского сценария."}
                    </p>
                  </div>

                  <a
                    href="#contact"
                    class="mt-auto flex items-center justify-between gap-4 border-t-[0.5px] border-slate-900/12 pt-6 font-mono text-[11px] uppercase tracking-[0.16em] text-slate-950 transition-colors duration-300 group-hover:border-slate-950/30 group-hover:text-violet-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-violet-700"
                  >
                    Выбрать квартиру
                    <span aria-hidden="true">→</span>
                  </a>
                </div>
              </article>
            );
          })}
        </div>

        {shouldLimitAll && (
          <div class="mt-10" data-plan-show-more-wrap>
            <button
              type="button"
              class="inline-flex min-h-12 items-center border-[0.5px] border-slate-900/25 bg-[#FBFBFA] px-5 py-3 font-mono text-[11px] uppercase tracking-[0.14em] text-slate-950 transition-colors duration-300 hover:border-slate-950 hover:bg-slate-950 hover:text-alabaster focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-violet-700"
              data-plan-show-more
              aria-expanded="false"
            >
              Показать все планировки →
            </button>
          </div>
        )}
      </div>

      <script>
        const selectors = document.querySelectorAll("[data-plan-selector]");

        selectors.forEach((selector) => {
          const buttons = Array.from(selector.querySelectorAll("[data-plan-filter]"));
          const cards = Array.from(selector.querySelectorAll("[data-plan-card]"));
          const showMoreWrap = selector.querySelector("[data-plan-show-more-wrap]");
          const showMoreButton = selector.querySelector("[data-plan-show-more]");
          const allLimit = Number(selector.getAttribute("data-all-limit") ?? 6);
          let activeFilter = "Все";
          let isAllExpanded = false;

          const setActiveButton = () => {
            buttons.forEach((button) => {
              const isActive = button.getAttribute("data-plan-filter") === activeFilter;
              button.setAttribute("aria-pressed", String(isActive));
              button.classList.toggle("bg-slate-950", isActive);
              button.classList.toggle("text-alabaster", isActive);
              button.classList.toggle("bg-[#FBFBFA]", !isActive);
              button.classList.toggle("text-slate-600", !isActive);
            });
          };

          const updateCards = () => {
            const isAll = activeFilter === "Все";

            cards.forEach((card) => {
              const category = card.getAttribute("data-plan-category");
              const index = Number(card.getAttribute("data-plan-index") ?? 0);
              const matchesFilter = isAll || category === activeFilter;
              const exceedsCollapsedAll = isAll && !isAllExpanded && index >= allLimit;
              card.classList.toggle("hidden", !matchesFilter || exceedsCollapsedAll);
            });

            if (showMoreWrap && showMoreButton) {
              const shouldShow = isAll && !isAllExpanded && cards.length > allLimit;
              showMoreWrap.classList.toggle("hidden", !shouldShow);
              showMoreButton.setAttribute("aria-expanded", String(isAllExpanded));
            }

            setActiveButton();
          };

          buttons.forEach((button) => {
            button.addEventListener("click", () => {
              activeFilter = button.getAttribute("data-plan-filter") ?? "Все";
              isAllExpanded = false;
              updateCards();
            });
          });

          showMoreButton?.addEventListener("click", () => {
            activeFilter = "Все";
            isAllExpanded = true;
            updateCards();
          });

          updateCards();
        });
      </script>
    </section>
  )
}
