---
interface Props {
  project: any;
}

const { project } = Astro.props;
const data = project.data;
const status = data.constructionStatus;
const sectionLabel = status?.label;
const items = status?.items ?? [];
const stages = status?.stages ?? [];
const activeStageIndex = Math.min(Math.max(status?.activeStageIndex ?? 0, 0), Math.max(stages.length - 1, 0));
const activeStage = stages[activeStageIndex] ?? stages[0];
const uiLabels = status?.uiLabels ?? {};

const stateClass = (state?: string) => {
  if (state === "completed") return "is-completed";
  if (state === "active") return "is-active";
  if (state === "target") return "is-target";
  return "is-planned";
};

const imageFallback = data.hero?.image ?? data.cover;
const stageImagePositions = ["54% 42%", "68% 48%", "50% 44%", "42% 50%", "58% 58%", "48% 52%"];
---

{
  status && (status.title || status.summary || items.length > 0 || stages.length > 0) && (
<section id="progress" class="construction-progress bg-[#F8F7F4] px-5 py-20 md:px-8 md:py-24 lg:px-10" aria-labelledby="progress-title">
  <div class="mx-auto max-w-[1480px] border-y-[0.5px] border-slate-900/15 py-8 md:py-12">
    <div class="grid gap-6 lg:grid-cols-[minmax(0,0.82fr)_minmax(420px,0.72fr)]">
      <div class="bg-[#FBFBFA] p-6 ring-1 ring-slate-900/10 md:p-8 lg:p-10">
        <div class="max-w-[680px]">
          {sectionLabel && <p class="mono-detail text-violet-800">{sectionLabel}</p>}
          {status.title && (
            <h2 id="progress-title" class="project-section-title mt-5 max-w-[13ch]">
              {status.title}
            </h2>
          )}
          {status.summary && <p class="mt-6 max-w-[62ch] text-base leading-8 text-slate-700 md:text-lg md:leading-8">{status.summary}</p>}
        </div>

        <dl class="mt-9 grid gap-3 sm:grid-cols-2 md:max-w-[620px]">
          {items.map((item: any) => (
            <div class="border-t-[0.5px] border-slate-900/15 pt-4">
              <dt class="font-mono text-[10px] uppercase tracking-[0.14em] text-slate-500">{item.label}</dt>
              <dd class="mt-3 text-2xl font-medium leading-tight text-slate-950 md:text-3xl">{item.value}</dd>
              {item.note && <p class="mt-3 text-xs leading-5 text-slate-500">{item.note}</p>}
            </div>
          ))}
        </dl>

        {
          status.verificationNote && (
            <div class="mt-8 grid grid-cols-[auto_1fr] gap-4 border-t-[0.5px] border-slate-900/10 pt-6 md:max-w-[620px]">
              <span class="mt-1 h-2.5 w-2.5 bg-violet-800" aria-hidden="true"></span>
              <p class="text-sm leading-7 text-slate-600">{status.verificationNote}</p>
            </div>
          )
        }
      </div>

      {
        activeStage && (
          <article class="featured-stage bg-[#151923] text-[#FBFBFA] ring-1 ring-slate-950/10" aria-live="polite">
            <div class="relative aspect-[4/3] overflow-hidden md:aspect-[16/10]">
              <img
                data-stage-image
                src={activeStage.image ?? imageFallback}
                alt={activeStage.imageAlt ?? `${data.name} ${activeStage.title}`}
                class="h-full w-full object-cover opacity-[0.88] transition-[opacity,transform] duration-500"
                style={`object-position: ${stageImagePositions[activeStageIndex] ?? "50% 50%"}`}
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-[#151923]/88 via-[#151923]/10 to-transparent" aria-hidden="true"></div>
              <div class="absolute left-0 right-0 top-0 flex items-start justify-between gap-5 p-5 md:p-6">
                {
                  uiLabels.activeStageLabel && (
                    <span class="border-[0.5px] border-[#FBFBFA]/28 bg-[#151923]/35 px-3 py-2 font-mono text-[10px] uppercase tracking-[0.14em] text-[#FBFBFA]/76">
                      {uiLabels.activeStageLabel}
                    </span>
                  )
                }
                <p data-stage-number class="font-mono text-5xl leading-none text-[#FBFBFA] md:text-6xl">
                  {String(activeStageIndex + 1).padStart(2, "0")}
                </p>
              </div>
              <div class="absolute bottom-0 left-0 right-0 p-5 md:p-6">
                <h3 data-stage-title class="max-w-[12ch] text-3xl font-medium leading-tight text-[#FBFBFA] md:text-5xl">{activeStage.title}</h3>
              </div>
            </div>

            <div class="grid gap-7 p-5 md:p-6 lg:p-7">
              <div class="grid gap-3 sm:grid-cols-2">
                <div>
                  {uiLabels.statusLabel && <p class="font-mono text-[10px] uppercase tracking-[0.14em] text-[#FBFBFA]/45">{uiLabels.statusLabel}</p>}
                  <span data-stage-status class={`stage-badge mt-3 ${stateClass(activeStage.state)}`}>{activeStage.status}</span>
                </div>
                <div>
                  {uiLabels.periodLabel && <p class="font-mono text-[10px] uppercase tracking-[0.14em] text-[#FBFBFA]/45">{uiLabels.periodLabel}</p>}
                  <p data-stage-period class="mt-3 text-lg font-medium leading-tight text-[#FBFBFA]">{activeStage.period}</p>
                </div>
              </div>

              <p data-stage-description class="max-w-[56ch] border-t-[0.5px] border-[#FBFBFA]/14 pt-6 text-base leading-7 text-[#FBFBFA]/72">{activeStage.description}</p>
            </div>
          </article>
        )
      }
    </div>

    {
      stages.length > 0 && (
        <div class="mt-12 border-t-[0.5px] border-slate-900/15 pt-8 md:mt-14 md:pt-10">
          <div class="mb-6 flex flex-col gap-3 md:mb-8 md:flex-row md:items-end md:justify-between">
            {uiLabels.roadmapTitle && <h3 class="text-2xl font-medium leading-tight text-slate-950 md:text-3xl">{uiLabels.roadmapTitle}</h3>}
            {uiLabels.roadmapHint && <p class="max-w-[34ch] text-sm leading-6 text-slate-600 md:text-right">{uiLabels.roadmapHint}</p>}
          </div>

          <ol class="construction-timeline grid gap-4 lg:grid-cols-6">
            {stages.map((stage: any, index: number) => (
              <li>
                <button
                  type="button"
                  class={`timeline-stage ${stateClass(stage.state)} ${index === activeStageIndex ? "is-selected" : ""} group relative grid h-full w-full grid-cols-[88px_1fr] gap-4 bg-[#FBFBFA] p-3 text-left transition-[background-color,color,transform] duration-300 hover:-translate-y-0.5 hover:bg-[#F5F4F0] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-violet-800 lg:block lg:min-h-[286px] lg:p-3`}
                  aria-current={index === activeStageIndex ? "step" : undefined}
                  aria-pressed={index === activeStageIndex ? "true" : "false"}
                  data-stage-trigger
                  data-index={index}
                  data-title={stage.title}
                  data-status={stage.status}
                  data-period={stage.period ?? ""}
                  data-description={stage.description ?? ""}
                  data-image={stage.image ?? imageFallback}
                  data-image-alt={stage.imageAlt ?? `${data.name} ${stage.title}`}
                  data-image-position={stageImagePositions[index] ?? "50% 50%"}
                  data-state={stage.state ?? "planned"}
                >
                  <span class="timeline-media block aspect-square overflow-hidden lg:aspect-[4/3]">
                    <img
                      src={stage.image ?? imageFallback}
                      alt={stage.imageAlt ?? `${data.name} ${stage.title}`}
                      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
                      style={`object-position: ${stageImagePositions[index] ?? "50% 50%"}`}
                      loading="lazy"
                    />
                  </span>

                  <span class="block min-w-0">
                    <span class="flex items-start justify-between gap-3 lg:mt-5">
                      <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-slate-500">
                        {String(index + 1).padStart(2, "0")}
                      </span>
                      <span class="timeline-node mt-1 h-2.5 w-2.5 shrink-0 bg-current" aria-hidden="true"></span>
                    </span>
                    <span class="mt-4 block text-lg font-medium leading-snug text-slate-950 lg:min-h-[50px]">{stage.title}</span>
                    <span class="mt-4 flex flex-wrap items-center gap-2">
                      <span class={`timeline-status ${stateClass(stage.state)}`}>{stage.status}</span>
                      <span class="font-mono text-[10px] uppercase tracking-[0.12em] text-slate-500">{stage.period}</span>
                    </span>
                  </span>
                </button>
              </li>
            ))}
          </ol>
        </div>
      )
    }
  </div>
</section>
  )
}

<style>
  .construction-timeline {
    counter-reset: timeline;
  }

  .project-section-title {
    font-family: var(--font-display, "Geist Variable", ui-sans-serif, system-ui, sans-serif);
    font-size: clamp(46px, 3.35vw, 64px);
    font-weight: 500;
    line-height: 0.96;
    letter-spacing: 0;
    color: #0e214c;
  }

  .stage-badge,
  .timeline-status {
    display: inline-flex;
    align-items: center;
    min-height: 1.75rem;
    border: 0.5px solid currentColor;
    padding: 0.375rem 0.625rem;
    font-family: var(--font-mono, monospace);
    font-size: 0.625rem;
    line-height: 1;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .stage-badge.is-completed,
  .timeline-status.is-completed {
    color: rgb(187 247 208 / 0.86);
  }

  .stage-badge.is-active,
  .timeline-status.is-active {
    color: rgb(221 214 254 / 0.96);
  }

  .stage-badge.is-planned,
  .timeline-status.is-planned {
    color: rgb(226 232 240 / 0.72);
  }

  .stage-badge.is-target,
  .timeline-status.is-target {
    color: rgb(253 230 138 / 0.9);
  }

  .timeline-status.is-completed {
    color: rgb(21 128 61);
  }

  .timeline-status.is-active {
    color: rgb(91 33 182);
  }

  .timeline-status.is-planned {
    color: rgb(71 85 105);
  }

  .timeline-status.is-target {
    color: rgb(133 77 14);
  }

  .timeline-stage {
    color: rgb(71 85 105);
    box-shadow: inset 0 0 0 0.5px rgb(15 23 42 / 0.11);
  }

  .timeline-stage:hover .timeline-media img {
    transform: scale(1.035);
  }

  .timeline-stage.is-selected {
    background: #f5f4f0;
    color: rgb(91 33 182);
    box-shadow:
      inset 0 0 0 0.5px rgb(91 33 182 / 0.38),
      inset 0 -3px 0 rgb(91 33 182 / 0.72);
  }

  .timeline-stage.is-planned {
    background: rgb(251 251 250 / 0.72);
  }

  .timeline-stage.is-target {
    color: rgb(133 77 14);
  }

  .timeline-media {
    box-shadow: inset 0 0 0 0.5px rgb(15 23 42 / 0.12);
  }

  @media (min-width: 1024px) {
    .timeline-stage::before {
      content: "";
      position: absolute;
      left: calc(100% - 0.25rem);
      top: 1.15rem;
      width: 1rem;
      height: 0.5px;
      background: rgb(15 23 42 / 0.16);
    }

    .timeline-stage:last-child::before {
      display: none;
    }

    .timeline-node {
      position: relative;
      z-index: 1;
    }
  }

  @media (max-width: 1023px) {
    .timeline-stage {
      min-height: 0;
    }

    .timeline-stage::before {
      content: "";
      position: absolute;
      right: 1.05rem;
      top: 5.9rem;
      bottom: -1.1rem;
      width: 0.5px;
      background: rgb(15 23 42 / 0.16);
    }

    .timeline-stage:last-child::before {
      display: none;
    }
  }

  @media (max-width: 760px) {
    .project-section-title {
      font-size: clamp(34px, 9.8vw, 42px);
      line-height: 1;
    }
  }

  @media (max-width: 420px) {
    .project-section-title {
      font-size: 34px;
    }
  }
</style>

<script>
  const progressSection = document.querySelector(".construction-progress");
  const stageTriggers = progressSection?.querySelectorAll("[data-stage-trigger]");
  const featuredImage = progressSection?.querySelector("[data-stage-image]") as HTMLImageElement | null;
  const featuredNumber = progressSection?.querySelector("[data-stage-number]");
  const featuredStatus = progressSection?.querySelector("[data-stage-status]");
  const featuredPeriod = progressSection?.querySelector("[data-stage-period]");
  const featuredTitle = progressSection?.querySelector("[data-stage-title]");
  const featuredDescription = progressSection?.querySelector("[data-stage-description]");

  stageTriggers?.forEach((trigger) => {
    trigger.addEventListener("click", () => {
      const button = trigger as HTMLButtonElement;
      const state = button.dataset.state ?? "planned";

      stageTriggers.forEach((item) => {
        item.classList.remove("is-selected");
        item.removeAttribute("aria-current");
        item.setAttribute("aria-pressed", "false");
      });

      button.classList.add("is-selected");
      button.setAttribute("aria-current", "step");
      button.setAttribute("aria-pressed", "true");

      if (featuredImage) {
        featuredImage.src = button.dataset.image ?? featuredImage.src;
        featuredImage.alt = button.dataset.imageAlt ?? featuredImage.alt;
        featuredImage.style.objectPosition = button.dataset.imagePosition ?? "50% 50%";
      }

      if (featuredNumber) featuredNumber.textContent = String(Number(button.dataset.index ?? 0) + 1).padStart(2, "0");
      if (featuredStatus) {
        featuredStatus.textContent = button.dataset.status ?? "";
        featuredStatus.className = `stage-badge is-${state}`;
      }
      if (featuredPeriod) featuredPeriod.textContent = button.dataset.period ?? "";
      if (featuredTitle) featuredTitle.textContent = button.dataset.title ?? "";
      if (featuredDescription) featuredDescription.textContent = button.dataset.description ?? "";
    });
  });
</script>
