---
interface Props {
  project: any;
}

const { project } = Astro.props;
const data = project.data;
const status =
  data.constructionStatus ?? {
    title: "Статус проекта",
    summary: data.description,
    items: [
      { label: "Статус", value: data.status },
      { label: "Сдача", value: data.delivery },
    ],
  };
const items = status.items ?? [];
---

<section class="bg-[#FBFBFA] px-5 py-20 md:px-8 md:py-28 lg:px-10" aria-labelledby="progress-title">
  <div class="mx-auto max-w-[1480px] border-y-[0.5px] border-slate-900/15 py-12 md:py-16">
    <div class="grid gap-12 lg:grid-cols-[0.34fr_1fr]">
      <div>
        <p class="mono-detail text-violet-700">Статус строительства</p>
        <h2 id="progress-title" class="mt-5 text-4xl font-medium leading-[1.02] text-slate-950 md:text-6xl">
          {status.title}
        </h2>
      </div>

      <div class="grid gap-8">
        <p class="max-w-[74ch] text-lg leading-8 text-slate-700 md:text-xl md:leading-9">{status.summary}</p>

        <div class="grid gap-px bg-slate-900/10 p-px lg:grid-cols-[0.9fr_1.1fr]">
          <dl class="grid bg-[#FBFBFA] sm:grid-cols-3 lg:grid-cols-1">
            {items.map((item: any) => (
              <div class="border-b-[0.5px] border-slate-900/10 p-6 last:border-b-0 sm:border-b-0 sm:border-r-[0.5px] sm:last:border-r-0 lg:border-b-[0.5px] lg:border-r-0 lg:last:border-b-0">
                <dt class="font-mono text-[10px] uppercase tracking-[0.15em] text-slate-500">{item.label}</dt>
                <dd class="mt-5 text-2xl font-medium leading-tight text-slate-950">{item.value}</dd>
                {item.note && <p class="mt-3 text-xs leading-5 text-slate-500">{item.note}</p>}
              </div>
            ))}
          </dl>

          <div class="bg-[#F8F7F4] p-6 md:p-8">
            <div class="flex items-start justify-between gap-6">
              <div>
                <p class="font-mono text-[10px] uppercase tracking-[0.16em] text-violet-700">Проверочный контур</p>
                <h3 class="mt-4 text-2xl font-medium leading-tight text-slate-950">Этапы будут показаны после подтверждения</h3>
              </div>
              <span class="hidden h-12 w-12 border-[0.5px] border-violet-700/30 text-violet-700 md:flex md:items-center md:justify-center">
                <svg viewBox="0 0 24 24" aria-hidden="true" class="h-6 w-6 fill-none stroke-current stroke-[1.25]">
                  <path d="M5 12h14M12 5v14M7 7l10 10M17 7L7 17" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
            </div>
            <div class="mt-10 grid grid-cols-[auto_1fr_auto] items-center gap-4">
              <span class="h-3 w-3 bg-violet-700" aria-hidden="true"></span>
              <span class="h-px bg-slate-900/20" aria-hidden="true"></span>
              <span class="h-3 w-3 border-[0.5px] border-slate-900/25" aria-hidden="true"></span>
            </div>
            <div class="mt-4 flex items-start justify-between gap-5 font-mono text-[10px] uppercase tracking-[0.14em] text-slate-500">
              <span>Текущий статус</span>
              <span class="text-right">Подтвержденный график</span>
            </div>
            <p class="mt-8 max-w-[60ch] border-t-[0.5px] border-slate-900/10 pt-5 text-sm leading-7 text-slate-600">
              Эта зона намеренно не показывает неподтвержденные стадии. После появления структурированного графика здесь можно вывести реальные этапы строительства.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
