---
interface Props {
  project: any;
}

const { project } = Astro.props;
const benefits = project.data.benefits ?? [];

const iconPaths = [
  "M6 19V8l6-4 6 4v11M9 19v-6h6v6",
  "M5 16h14M7 12h10M9 8h6M4 20h16V4H4z",
  "M7 13l3 3 7-8M5 5h14v14H5z",
  "M12 3v18M5 8h14M6 16h12",
  "M5 12h14M12 5v14M7 7l10 10M17 7L7 17",
  "M12 21s7-5.2 7-11a7 7 0 0 0-14 0c0 5.8 7 11 7 11zM12 10.5v.01",
];
---

{
  benefits.length > 0 && (
    <section class="bg-[#FBFBFA] px-5 py-18 md:px-8 md:py-24 lg:px-10" aria-labelledby="benefits-title">
      <div class="mx-auto grid max-w-[1480px] gap-12 lg:grid-cols-[0.36fr_1fr]">
        <div class="max-w-[430px] border-t-[0.5px] border-slate-900/15 pt-8">
          <p class="mono-detail text-violet-700">Преимущества</p>
          <h2 id="benefits-title" class="mt-5 text-4xl font-medium leading-[1.02] text-slate-950 md:text-6xl">
            Комфорт в каждой детали
          </h2>
          <p class="mt-6 max-w-[36ch] text-base leading-7 text-slate-600">
            Шесть практичных причин, которые формируют ежедневное качество жизни в этом проекте.
          </p>
        </div>
        <div class="grid border-t-[0.5px] border-slate-900/12 md:grid-cols-2 xl:grid-cols-3">
          {benefits.map((benefit: any, index: number) => (
            <article class="group min-h-[260px] border-b-[0.5px] border-slate-900/12 p-6 transition-colors duration-500 hover:bg-[#F8F7F4] md:border-r-[0.5px] md:p-7 xl:[&:nth-child(3n)]:border-r-0">
              <div class="flex items-start justify-between gap-6">
                <span class="flex h-12 w-12 items-center justify-center border-[0.5px] border-violet-700/25 text-violet-700">
                  <svg viewBox="0 0 24 24" aria-hidden="true" class="h-6 w-6 fill-none stroke-current stroke-[1.25]">
                    <path d={iconPaths[index % iconPaths.length]} stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </span>
                <span class="font-mono text-[11px] uppercase tracking-[0.18em] text-slate-400">
                  {String(index + 1).padStart(2, "0")}
                </span>
              </div>
              <h3 class="mt-10 text-2xl font-medium leading-tight text-slate-950">{benefit.title}</h3>
              <p class="mt-4 max-w-[36ch] text-sm leading-7 text-slate-600">{benefit.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  )
}
