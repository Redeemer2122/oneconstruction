---
import {
  Building2,
  Gem,
  LayoutGrid,
  MapPin,
  ShieldCheck,
  Trees,
} from "@lucide/astro";

interface Props {
  project: any;
}

const { project } = Astro.props;
const benefits = project.data.benefits ?? [];
const projectSlug = project.data.slug ?? project.id;
const isMedina = projectSlug === "medina";

const benefitIcons = [MapPin, Building2, LayoutGrid, ShieldCheck, Gem, Trees];
const sectionTitle = isMedina ? "Почему именно ЖК «Медина+»" : "Комфорт в каждой детали";
const sectionIntro = isMedina
  ? [
      "ЖК «Медина+» — это гармония комфорта, безопасности и высокого качества.",
      "Мы продумали каждую деталь, чтобы вы чувствовали себя дома с первого дня.",
    ]
  : [
      "Шесть практичных причин, которые формируют ежедневное качество жизни в этом проекте.",
      "Каждый сценарий продуман для спокойного, удобного и красивого быта.",
    ];
---

{
  benefits.length > 0 && (
    <section id="benefits" class="benefits-section bg-[#FBFBFA] px-5 py-16 md:px-8 md:py-24 lg:px-10" aria-labelledby="benefits-title">
      <div class="mx-auto grid max-w-[1480px] gap-12 lg:grid-cols-[minmax(320px,0.35fr)_minmax(0,0.65fr)] lg:gap-14 xl:gap-20">
        <aside class="benefits-intro relative flex min-h-[620px] flex-col overflow-hidden lg:min-h-[720px]">
          <div class="relative z-10 max-w-[470px]">
            <div class="benefits-label text-[#7C66A3]">
              <p class="font-mono text-[12px] uppercase leading-none tracking-[0.18em]">ПРЕИМУЩЕСТВА</p>
            </div>

            <h2 id="benefits-title" class="benefits-title mt-9 text-[#0E214C]" aria-label={sectionTitle}>
              {isMedina ? (
                <>
                  <span>Почему именно</span>
                  <span>ЖК «Медина+»</span>
                </>
              ) : (
                <span>{sectionTitle}</span>
              )}
            </h2>

            <div class="benefits-divider mt-9" aria-hidden="true">
              <span></span>
            </div>

            <div class="mt-8 max-w-[440px] space-y-1 text-[17px] leading-8 text-[#2E3D62] md:text-[18px] md:leading-9">
              {sectionIntro.map((line) => <p>{line}</p>)}
            </div>

            <a
              href="#contact"
              class="mt-10 inline-flex min-h-14 w-full max-w-[360px] items-center justify-center border-[0.5px] border-slate-950 bg-slate-950 px-6 py-4 font-mono text-[11px] uppercase tracking-[0.16em] text-alabaster transition-colors duration-300 hover:border-violet-700 hover:bg-violet-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-violet-700"
            >
              Оставить заявку
            </a>
          </div>

          <div class="benefits-decorative-asset" aria-hidden="true">
            <img
              src="/img/project-details/medina/benefits-decorative-asset.png"
              alt=""
              loading="lazy"
              decoding="async"
            />
          </div>
        </aside>

        <div class="benefits-matrix" role="list">
          {benefits.map((benefit: any, index: number) => {
            const Icon = benefitIcons[index % benefitIcons.length];

            return (
              <article class="benefits-item" role="listitem">
                <div class="benefits-item-kicker">
                  <span class="benefits-item-number" aria-hidden="true">
                    {String(index + 1).padStart(2, "0")}
                  </span>
                  <span class="benefits-item-icon" aria-hidden="true">
                    <Icon size={42} stroke-width={1.08} />
                  </span>
                </div>
                <h3>{benefit.title}</h3>
                <p>{benefit.body}</p>
              </article>
            );
          })}
        </div>
      </div>
    </section>
  )
}

<style>
  .benefits-section {
    color: #0e214c;
    background:
      linear-gradient(90deg, rgba(124, 102, 163, 0.045), transparent 34rem),
      linear-gradient(180deg, #fbfbfa 0%, #f8f7f4 100%);
  }

  .benefits-label::after {
    content: "";
    display: block;
    width: 50px;
    height: 1px;
    margin-top: 18px;
    background: #7c66a3;
  }

  .benefits-title {
    font-family: var(--font-display, "Geist Variable", ui-sans-serif, system-ui, sans-serif);
    max-width: 620px;
    font-size: clamp(46px, 3.35vw, 64px);
    font-weight: 500;
    line-height: 0.96;
    letter-spacing: 0;
  }

  .benefits-title span {
    display: block;
    white-space: nowrap;
  }

  .benefits-divider {
    position: relative;
    width: 154px;
    height: 1px;
    background: rgba(124, 102, 163, 0.22);
  }

  .benefits-divider::before,
  .benefits-divider::after {
    display: none;
  }

  .benefits-divider span {
    display: none;
  }

  .benefits-decorative-asset {
    position: absolute;
    left: -54%;
    bottom: -26px;
    z-index: 0;
    width: 232%;
    height: 610px;
    pointer-events: none;
    opacity: 0.42;
    -webkit-mask-image:
      linear-gradient(to right, #000 0%, #000 58%, transparent 98%),
      linear-gradient(to top, #000 0%, #000 68%, transparent 100%);
    mask-image:
      linear-gradient(to right, #000 0%, #000 58%, transparent 98%),
      linear-gradient(to top, #000 0%, #000 68%, transparent 100%);
    -webkit-mask-composite: source-in;
    mask-composite: intersect;
  }

  .benefits-decorative-asset::after {
    content: "";
    position: absolute;
    inset: -1px;
    background:
      linear-gradient(180deg, rgba(251, 251, 250, 0.94) 0%, rgba(251, 251, 250, 0.58) 26%, rgba(251, 251, 250, 0) 56%),
      linear-gradient(90deg, rgba(251, 251, 250, 0.04) 0%, rgba(251, 251, 250, 0) 46%, rgba(251, 251, 250, 0.68) 100%),
      linear-gradient(0deg, rgba(248, 247, 244, 0.12) 0%, rgba(248, 247, 244, 0) 34%);
    pointer-events: none;
  }

  .benefits-decorative-asset img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: left bottom;
    filter: grayscale(1) contrast(1.22) brightness(0.96);
  }

  .benefits-matrix {
    display: grid;
    align-self: center;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .benefits-item {
    min-height: 342px;
    padding: clamp(30px, 2.9vw, 46px) clamp(26px, 2.8vw, 46px);
    color: #0e214c;
  }

  .benefits-item:nth-child(3n + 2),
  .benefits-item:nth-child(3n + 3) {
    border-left: 1px solid rgba(14, 33, 76, 0.12);
  }

  .benefits-item:nth-child(n + 4) {
    border-top: 1px solid rgba(14, 33, 76, 0.12);
  }

  .benefits-item-kicker {
    display: flex;
    min-height: 72px;
    align-items: flex-start;
    justify-content: flex-start;
    gap: clamp(34px, 3.2vw, 62px);
  }

  .benefits-item-number {
    font-family: var(--font-display, "Geist Variable", ui-sans-serif, system-ui, sans-serif);
    font-size: clamp(36px, 3.1vw, 50px);
    font-weight: 400;
    line-height: 1;
    color: #7c66a3;
  }

  .benefits-item-icon {
    color: #70579b;
  }

  .benefits-item h3 {
    font-family: var(--font-display, "Geist Variable", ui-sans-serif, system-ui, sans-serif);
    margin-top: 24px;
    max-width: 13.5ch;
    font-size: clamp(25px, 1.62vw, 30px);
    font-weight: 500;
    line-height: 1.14;
    letter-spacing: 0;
    color: currentColor;
  }

  .benefits-item p {
    margin-top: 20px;
    max-width: 28ch;
    font-size: 16px;
    line-height: 1.68;
    color: rgba(46, 61, 98, 0.84);
  }

  @media (max-width: 1023px) {
    .benefits-intro {
      min-height: 520px;
    }

    .benefits-decorative-asset {
      left: -42%;
      bottom: -20px;
      width: 205%;
      height: 485px;
      opacity: 0.28;
    }

    .benefits-matrix {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      border-top: 1px solid rgba(14, 33, 76, 0.12);
    }

    .benefits-item {
      min-height: 280px;
    }

    .benefits-item:nth-child(n) {
      border-left: 0;
      border-top: 0;
    }

    .benefits-item:nth-child(even) {
      border-left: 1px solid rgba(14, 33, 76, 0.12);
    }

    .benefits-item:nth-child(n + 3) {
      border-top: 1px solid rgba(14, 33, 76, 0.12);
    }
  }

  @media (max-width: 760px) {
    .benefits-section {
      padding-top: 72px;
      padding-bottom: 78px;
    }

    .benefits-intro {
      min-height: 0;
      padding-bottom: 0;
    }

    .benefits-title {
      margin-top: 28px;
      max-width: 100%;
      font-size: clamp(34px, 9.8vw, 42px);
      line-height: 1;
    }

    .benefits-decorative-asset {
      display: none;
    }

    .benefits-matrix {
      display: block;
      border-top: 1px solid rgba(14, 33, 76, 0.12);
    }

    .benefits-item {
      min-height: 0;
      padding: 26px 0 28px;
      border-left: 0;
      border-top: 0;
      border-bottom: 1px solid rgba(14, 33, 76, 0.12);
    }

    .benefits-item:nth-child(n) {
      border-left: 0;
      border-top: 0;
    }

    .benefits-item-kicker {
      min-height: 44px;
      justify-content: flex-start;
      gap: 22px;
    }

    .benefits-item-number {
      font-size: 38px;
    }

    .benefits-item-icon :global(svg) {
      width: 34px;
      height: 34px;
    }

    .benefits-item h3 {
      margin-top: 20px;
      max-width: 18ch;
      font-size: clamp(24px, 7.2vw, 31px);
      line-height: 1.14;
    }

    .benefits-item p {
      margin-top: 12px;
      max-width: 31ch;
      font-size: 15px;
      line-height: 1.6;
    }
  }

  @media (max-width: 420px) {
    .benefits-title {
      font-size: 34px;
    }

    .benefits-item h3 {
      font-size: 25px;
    }
  }
</style>
