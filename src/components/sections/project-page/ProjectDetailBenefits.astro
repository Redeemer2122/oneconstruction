---
import {
  Layers,
  LayoutGrid,
  MapPin,
  ShieldCheck,
  Wrench,
  Trees,
} from "@lucide/astro";

interface Props {
  project: any;
}

const { project } = Astro.props;
const benefits = project.data.benefits ?? [];
const projectSlug = project.data.slug ?? project.id;
const isMedina = projectSlug === "medina";

const benefitIcons = [MapPin, Wrench, LayoutGrid, ShieldCheck, Layers, Trees];
const sectionTitle = isMedina ? "Почему именно Медина+" : "Комфорт в каждой детали";
const sectionIntro = isMedina
  ? "Закрытая территория, продуманные планировки, спокойный двор и инфраструктура в шаговой доступности."
  : "Шесть практичных причин, которые формируют ежедневное качество жизни в этом проекте.";
---

{
  benefits.length > 0 && (
    <section class="relative bg-[#FBFBFA] px-5 py-16 md:px-8 md:py-24 lg:px-10" aria-labelledby="benefits-title">
      <div class="mx-auto grid max-w-[1480px] gap-10 border-t-[0.5px] border-slate-900/14 pt-8 md:gap-12 md:pt-10 lg:grid-cols-[minmax(280px,0.33fr)_minmax(0,0.67fr)] lg:gap-14">
        <div class="lg:sticky lg:top-28 lg:self-start">
          <div class="max-w-[420px]">
            <p class="mono-detail text-violet-700">ПРЕИМУЩЕСТВА</p>
            <h2 id="benefits-title" class="mt-5 max-w-[12ch] text-[clamp(2.35rem,4.2vw,4.8rem)] font-medium leading-[1] tracking-normal text-slate-950">
              {sectionTitle}
            </h2>
            <p class="mt-6 max-w-[38ch] text-base leading-8 text-slate-700 md:text-lg md:leading-8">
              {sectionIntro}
            </p>
          </div>
          <div class="mt-9 max-w-[360px] border-y-[0.5px] border-slate-900/12 py-5">
            <p class="font-mono text-[10px] uppercase leading-relaxed tracking-[0.16em] text-slate-500 md:text-[11px]">
              MEDINA+ / CITY FORMAT / COMFORT
            </p>
          </div>
        </div>
        <div class="grid border-l-[0.5px] border-t-[0.5px] border-slate-900/14 md:grid-cols-2">
          {benefits.map((benefit: any, index: number) => {
            const Icon = benefitIcons[index % benefitIcons.length];
            const isDark = index === 2;
            const isViolet = index === 4;

            return (
              <article
                class={`group relative flex min-h-[255px] flex-col border-b-[0.5px] border-r-[0.5px] border-slate-900/14 p-6 transition-colors duration-300 md:min-h-[300px] md:p-7 xl:p-8 ${isDark ? "border-slate-950 bg-slate-950 text-[#FBFBFA]" : isViolet ? "bg-[#F5F4F0]" : "bg-[#FBFBFA] text-slate-950 hover:bg-[#F8F7F4]"}`}
              >
                <div class="flex items-start justify-between gap-6">
                  <span
                    class={`flex h-11 w-11 items-center justify-center border-[0.5px] transition-colors duration-300 ${isDark ? "border-[#FBFBFA]/22 text-[#FBFBFA]" : isViolet ? "border-violet-700/28 text-violet-700" : "border-slate-900/14 text-violet-700 group-hover:border-violet-700/35"}`}
                  >
                    <Icon aria-hidden="true" size={20} stroke-width={1.35} />
                  </span>
                  <span class={`font-mono text-[10px] uppercase tracking-[0.16em] ${isDark ? "text-[#FBFBFA]/48" : "text-slate-400"}`}>
                    {String(index + 1).padStart(2, "0")}
                  </span>
                </div>
                <div class="mt-auto pt-10">
                  <h3 class={`max-w-[17ch] text-[1.55rem] font-medium leading-tight tracking-normal md:text-[1.75rem] ${isDark ? "text-[#FBFBFA]" : "text-slate-950"}`}>
                    {benefit.title}
                  </h3>
                  <p class={`mt-5 max-w-[36ch] text-sm leading-7 md:text-[0.95rem] ${isDark ? "text-[#FBFBFA]/68" : "text-slate-600"}`}>
                    {benefit.body}
                  </p>
                </div>
                <span
                  class={`pointer-events-none absolute bottom-6 right-6 h-px w-9 transition-colors duration-300 ${isDark ? "bg-[#FBFBFA]/28" : isViolet ? "bg-violet-700/38" : "bg-slate-900/0 group-hover:bg-violet-700/35"}`}
                  aria-hidden="true"
                ></span>
              </article>
            );
          })}
        </div>
      </div>
    </section>
  )
}
