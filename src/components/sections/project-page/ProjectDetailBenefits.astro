---
import {
  Building2,
  Gem,
  LayoutGrid,
  MapPin,
  ShieldCheck,
  Trees,
} from "@lucide/astro";

interface Props {
  project: any;
}

const { project } = Astro.props;
const benefits = project.data.benefits ?? [];
const projectSlug = project.data.slug ?? project.id;
const isMedina = projectSlug === "medina";

const benefitIcons = [MapPin, Building2, LayoutGrid, ShieldCheck, Gem, Trees];
const sectionTitle = isMedina ? "Почему именно ЖК «Медина+»" : "Комфорт в каждой детали";
const sectionIntro = isMedina
  ? [
      "ЖК «Медина+» — это гармония комфорта, безопасности и высокого качества.",
      "Мы продумали каждую деталь, чтобы вы чувствовали себя дома с первого дня.",
    ]
  : [
      "Шесть практичных причин, которые формируют ежедневное качество жизни в этом проекте.",
      "Каждый сценарий продуман для спокойного, удобного и красивого быта.",
    ];
---

{
  benefits.length > 0 && (
    <section class="benefits-section bg-[#FBFBFA] px-5 py-16 md:px-8 md:py-24 lg:px-10" aria-labelledby="benefits-title">
      <div class="mx-auto grid max-w-[1480px] gap-12 lg:grid-cols-[minmax(320px,0.36fr)_minmax(0,0.64fr)] lg:gap-16 xl:gap-20">
        <aside class="benefits-intro relative flex min-h-[700px] flex-col overflow-hidden lg:min-h-[820px]">
          <div class="relative z-10 max-w-[470px]">
            <div class="benefits-label flex items-center gap-5 text-[#7C66A3]">
              <svg class="h-8 w-8 shrink-0" viewBox="0 0 40 40" fill="none" aria-hidden="true">
                <path d="M20 5c4.2 5.2 4.2 10.8 0 16-4.2-5.2-4.2-10.8 0-16Z" stroke="currentColor" stroke-width="1.05" />
                <path d="M20 21c4.7-3.2 9.2-3.4 13.6-.5-3.1 3.9-7.3 5.2-13.6.5Z" stroke="currentColor" stroke-width="1.05" />
                <path d="M20 21c-4.7-3.2-9.2-3.4-13.6-.5 3.1 3.9 7.3 5.2 13.6.5Z" stroke="currentColor" stroke-width="1.05" />
                <path d="M20 18v17M13 35h14M15.5 29.5h9" stroke="currentColor" stroke-width="1.05" stroke-linecap="square" />
              </svg>
              <p class="font-mono text-[11px] uppercase leading-none tracking-[0.24em]">ПРЕИМУЩЕСТВА</p>
            </div>

            <h2 id="benefits-title" class="benefits-title mt-9 text-[#0E214C]">
              {isMedina ? (
                <>
                  <span>Почему именно</span>
                  <span>ЖК «Медина+»</span>
                </>
              ) : (
                <span>{sectionTitle}</span>
              )}
            </h2>

            <div class="benefits-divider mt-9" aria-hidden="true">
              <span></span>
            </div>

            <div class="mt-8 max-w-[440px] space-y-1 text-[17px] leading-8 text-[#2E3D62] md:text-[18px] md:leading-9">
              {sectionIntro.map((line) => <p>{line}</p>)}
            </div>
          </div>

          <div class="benefits-line-art absolute left-0 top-[455px] w-[min(455px,88vw)] text-[#0E214C]" aria-hidden="true">
            <svg viewBox="0 0 620 330" fill="none" role="img">
              <path d="M42 286h530" stroke="currentColor" stroke-width="1" />
              <path d="M82 286V92h178v194M260 286V58h154v228M414 286V118h96v168" stroke="currentColor" stroke-width="1.12" />
              <path d="M82 92l88-46 90 46M260 58l77-38 77 38M414 118l47-25 49 25" stroke="currentColor" stroke-width="1.12" />
              <path d="M112 126h42v48h-42zM188 126h42v48h-42zM292 92h34v48h-34zM350 92h34v48h-34zM440 150h24v42h-24zM482 150h24v42h-24z" stroke="currentColor" stroke-width="0.9" />
              <path d="M112 202h42v48h-42zM188 202h42v48h-42zM292 164h34v48h-34zM350 164h34v48h-34zM440 214h24v42h-24zM482 214h24v42h-24z" stroke="currentColor" stroke-width="0.9" />
              <path d="M154 286v-48c0-19 14-35 31-35s31 16 31 35v48M319 286v-54c0-21 15-39 34-39s34 18 34 39v54" stroke="currentColor" stroke-width="1.05" />
              <path d="M94 112h154M274 77h126M428 134h70M95 190h152M275 152h126M429 204h70" stroke="currentColor" stroke-width="0.72" />
              <path d="M61 286c4-28 8-56 10-84M42 222c22 8 32 23 29 48M88 216c-18 10-24 26-17 52M548 286c4-25 7-50 9-74M530 230c20 7 29 21 27 44M576 225c-18 9-25 24-19 49" stroke="currentColor" stroke-width="0.9" />
              <path d="M70 296c38-12 75-11 111 2M216 298c55-11 107-10 156 1M402 297c46-10 87-9 123 1" stroke="currentColor" stroke-width="0.75" />
              <path d="M126 70h88M295 39h83M448 106h28" stroke="currentColor" stroke-width="0.7" opacity="0.58" />
            </svg>
          </div>

          <a
            href="#contact"
            class="benefits-cta relative z-10 mt-auto inline-grid min-h-16 w-full max-w-[390px] grid-cols-[1fr_auto] items-center border border-[#7C66A3]/70 px-9 py-5 font-mono text-[11px] uppercase leading-none tracking-[0.22em] text-[#7C66A3] transition-colors duration-300 hover:border-[#0E214C] hover:bg-[#0E214C] hover:text-[#FBFBFA] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#7C66A3]"
          >
            <span>ОСТАВИТЬ ЗАЯВКУ</span>
            <span class="text-3xl leading-none" aria-hidden="true">→</span>
          </a>
        </aside>

        <div class="benefits-list" role="list">
          {benefits.map((benefit: any, index: number) => {
            const Icon = benefitIcons[index % benefitIcons.length];

            return (
              <article class="benefits-row" role="listitem" tabindex="0">
                <div class="benefits-row-icon" aria-hidden="true">
                  <Icon size={25} stroke-width={1.18} />
                </div>
                <div class="benefits-row-number" aria-hidden="true">
                  {String(index + 1).padStart(2, "0")}
                </div>
                <span class="benefits-row-rule" aria-hidden="true"></span>
                <div class="benefits-row-copy">
                  <h3>{benefit.title}</h3>
                  <p>{benefit.body}</p>
                </div>
              </article>
            );
          })}
        </div>
      </div>
    </section>
  )
}

<style>
  .benefits-section {
    color: #0e214c;
    background:
      radial-gradient(circle at 9% 27%, rgba(124, 102, 163, 0.045), transparent 20rem),
      linear-gradient(180deg, #fbfbfa 0%, #f8f7f4 100%);
  }

  .benefits-title {
    font-family: var(--font-display, "Geist Variable", ui-sans-serif, system-ui, sans-serif);
    max-width: 620px;
    font-size: clamp(46px, 3.45vw, 62px);
    font-weight: 500;
    line-height: 0.96;
    letter-spacing: 0;
  }

  .benefits-title span {
    display: block;
    white-space: nowrap;
  }

  .benefits-divider {
    position: relative;
    width: 190px;
    height: 18px;
  }

  .benefits-divider::before,
  .benefits-divider::after {
    content: "";
    position: absolute;
    top: 50%;
    width: calc(50% - 10px);
    height: 1px;
    background: rgba(124, 102, 163, 0.32);
  }

  .benefits-divider::before {
    left: 0;
  }

  .benefits-divider::after {
    right: 0;
  }

  .benefits-divider span {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 8px;
    height: 8px;
    background: #7c66a3;
    transform: translate(-50%, -50%) rotate(45deg);
  }

  .benefits-line-art {
    opacity: 0.082;
  }

  .benefits-list {
    display: grid;
    gap: 6px;
  }

  .benefits-row {
    display: grid;
    min-height: 138px;
    grid-template-columns: 86px 92px 1px minmax(0, 1fr);
    align-items: center;
    border: 1px solid rgba(14, 33, 76, 0.15);
    background: rgba(251, 251, 250, 0.86);
    color: #0e214c;
    outline: none;
    transition:
      transform 220ms var(--ease-out-expo),
      background-color 220ms var(--ease-out-expo),
      border-color 220ms var(--ease-out-expo),
      color 220ms var(--ease-out-expo);
  }

  .benefits-row-icon {
    display: flex;
    justify-content: center;
    color: #7c66a3;
    transition: color 220ms var(--ease-out-expo);
  }

  .benefits-row-number {
    font-family: var(--font-display, "Geist Variable", ui-sans-serif, system-ui, sans-serif);
    font-size: clamp(38px, 3vw, 50px);
    font-weight: 500;
    line-height: 1;
    text-align: center;
    color: currentColor;
    transition: color 220ms var(--ease-out-expo);
  }

  .benefits-row-rule {
    width: 1px;
    height: 68px;
    background: rgba(14, 33, 76, 0.17);
    transition: background-color 220ms var(--ease-out-expo);
  }

  .benefits-row-copy {
    min-width: 0;
    padding: 24px 34px 24px 42px;
  }

  .benefits-row-copy h3 {
    font-family: var(--font-display, "Geist Variable", ui-sans-serif, system-ui, sans-serif);
    font-size: clamp(24px, 1.68vw, 28px);
    font-weight: 500;
    line-height: 1.16;
    letter-spacing: 0;
    color: currentColor;
  }

  .benefits-row-copy p {
    margin-top: 10px;
    max-width: 42ch;
    font-size: 17px;
    line-height: 1.58;
    color: rgba(46, 61, 98, 0.9);
    transition: color 220ms var(--ease-out-expo);
  }

  .benefits-row:focus-visible {
    border-color: rgba(124, 102, 163, 0.62);
    box-shadow: 0 0 0 2px rgba(124, 102, 163, 0.14);
  }

  @media (max-width: 1279px) {
    .benefits-row {
      grid-template-columns: 72px 78px 1px minmax(0, 1fr);
    }

    .benefits-row-copy {
      padding-inline: 32px 22px;
    }

    .benefits-row-copy p {
      font-size: 16px;
    }
  }

  @media (hover: hover) and (pointer: fine) {
    .benefits-row:hover,
    .benefits-row:focus-visible {
      transform: translateX(4px) translateY(-2px);
      border-color: #0b1c4a;
      background: #0b1c4a;
      color: #fbfbfa;
    }

    .benefits-row:hover .benefits-row-icon,
    .benefits-row:focus-visible .benefits-row-icon {
      color: rgba(210, 199, 236, 0.96);
    }

    .benefits-row:hover .benefits-row-rule,
    .benefits-row:focus-visible .benefits-row-rule {
      background: rgba(251, 251, 250, 0.3);
    }

    .benefits-row:hover .benefits-row-copy p,
    .benefits-row:focus-visible .benefits-row-copy p {
      color: rgba(251, 251, 250, 0.82);
    }
  }

  @media (max-width: 1023px) {
    .benefits-intro {
      min-height: 590px;
    }

    .benefits-line-art {
      top: 360px;
      opacity: 0.065;
    }
  }

  @media (max-width: 760px) {
    .benefits-section {
      padding-top: 72px;
      padding-bottom: 78px;
    }

    .benefits-intro {
      min-height: 0;
      padding-bottom: 0;
    }

    .benefits-label {
      gap: 14px;
    }

    .benefits-title {
      margin-top: 28px;
      max-width: 100%;
      font-size: clamp(34px, 9.8vw, 42px);
      line-height: 1;
    }

    .benefits-line-art {
      display: none;
    }

    .benefits-cta {
      margin-top: 34px;
      max-width: none;
      min-height: 58px;
      padding: 18px 22px;
      letter-spacing: 0.16em;
    }

    .benefits-list {
      gap: 6px;
    }

    .benefits-row {
      min-height: 0;
      grid-template-columns: 44px minmax(0, 1fr);
      grid-template-areas:
        "icon number"
        "copy copy";
      align-items: start;
      padding: 18px 18px 20px;
    }

    .benefits-row-icon {
      grid-area: icon;
      justify-content: flex-start;
      padding-top: 4px;
    }

    .benefits-row-icon :global(svg) {
      width: 27px;
      height: 27px;
    }

    .benefits-row-number {
      grid-area: number;
      font-size: 38px;
      text-align: left;
    }

    .benefits-row-rule {
      display: none;
    }

    .benefits-row-copy {
      grid-area: copy;
      padding: 16px 0 0;
    }

    .benefits-row-copy h3 {
      font-size: clamp(24px, 7.2vw, 31px);
      line-height: 1.14;
    }

    .benefits-row-copy p {
      margin-top: 10px;
      max-width: 31ch;
      font-size: 15px;
      line-height: 1.6;
    }
  }

  @media (max-width: 420px) {
    .benefits-title {
      font-size: 34px;
    }

    .benefits-row {
      padding-inline: 15px;
    }

    .benefits-row-copy h3 {
      font-size: 25px;
    }
  }
</style>
