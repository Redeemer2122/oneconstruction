---
/**
 * HomeHero — фулл-вьюпорт герой со светлым дневным видео-фоном.
 *
 * Светлая стратегия читаемости:
 *  1. <video> autoplay/loop/muted/playsinline + poster fallback.
 *  2. Soft scrim: лёгкий алебастровый градиент по краям и снизу — никаких
 *     тёмных вьеток, только воздушная тонировка для контраста типографики.
 *  3. Главная типографика — глубокий графит. Mix-blend-mode исключён,
 *     потому что светлая тема требует предсказуемого тонального контраста.
 *  4. Мобильный H1: text-[14vw] чтобы заголовок гарантированно влезал и
 *     не вызывал горизонтального скролла.
 */
const heroVideo =
  "https://cdn.pixabay.com/video/2024/07/11/220695_large.mp4";
const heroPoster =
  "https://images.unsplash.com/photo-1487958449943-2429e8be8625?w=2400&q=85&auto=format&fit=crop";
---

<section
  id="hero"
  class="relative isolate min-h-[100dvh] w-full overflow-hidden bg-alabaster"
>
  <video
    class="absolute inset-0 -z-10 h-full w-full object-cover opacity-90"
    autoplay
    muted
    loop
    playsinline
    preload="metadata"
    poster={heroPoster}
    aria-hidden="true"
  >
    <source src={heroVideo} type="video/mp4" />
  </video>

  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 -z-10"
    style="background: radial-gradient(ellipse at 50% 40%, oklch(0.98 0.003 60 / 0.15) 0%, oklch(0.98 0.003 60 / 0.35) 55%, oklch(0.98 0.003 60 / 0.75) 100%);"
  >
  </div>

  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-x-0 bottom-0 -z-10 h-1/2 bg-gradient-to-t from-alabaster via-alabaster/70 to-transparent"
  >
  </div>

  <div class="relative min-h-[100dvh] grid grid-cols-12 gap-0 px-6 md:px-10 lg:px-12 pt-28 md:pt-40 pb-20 md:pb-24">
    <div class="col-span-12 md:col-span-10 xl:col-span-9 flex flex-col justify-end min-w-0 pr-1 md:pr-4">
      <p class="mono-detail mb-8 md:mb-10 text-slate-600">
        ID: 000 / DIGITAL SHOWROOM / BISHKEK · 2026
      </p>
      <h1
        class="display text-[14vw] md:text-[9vw] xl:text-[8.6vw] leading-[0.94] tracking-[-0.035em] text-slate-900 max-w-full"
      >
        <span class="headline-mask"><span>АРХИТЕКТУРА</span></span>
        <span class="headline-mask"><span>БЕЗ КОМПРОМИССА</span></span>
      </h1>
    </div>

    <aside class="col-span-12 md:col-span-3 md:pl-10 flex flex-col justify-end gap-5 mt-10 md:mt-0">
      <span class="h-px w-12 bg-slate-400" aria-hidden="true"></span>
      <p class="text-sm text-slate-700 max-w-[36ch] leading-relaxed">
        One Construction. Премиальные жилые комплексы в Бишкеке.
        Стекло, сталь, выверенный архитектурный ритм.
      </p>
      <a
        href="#projects"
        class="self-start mt-2 font-mono text-[11px] uppercase tracking-[0.22em] text-slate-900 border-b-[0.5px] border-slate-400 pb-1.5 transition-colors duration-300 hover:text-violet-600 hover:border-violet-600"
      >
        Смотреть объекты ↘
      </a>
    </aside>
  </div>

  <div class="absolute bottom-6 left-6 right-6 md:left-10 md:right-10 flex items-end justify-between text-slate-600 pointer-events-none">
    <span class="mono-detail">42.8746° N · 74.5698° E</span>
    <span class="mono-detail hidden md:inline">SCROLL ↓</span>
  </div>
</section>
