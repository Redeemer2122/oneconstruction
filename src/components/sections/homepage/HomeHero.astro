---
import { hero } from "@data/homepage";
import { company } from "@data/company";
const { image: heroImage, imageAlt, eyebrow, titleLines, subtitle, metrics } = hero;
---

<section
  id="hero"
  class="relative isolate min-h-[100dvh] w-full overflow-hidden bg-[#FBFBFA] flex flex-col"
>
  <!-- Background render -->
  <div class="absolute inset-0 -z-10">
    <img
      src={heroImage}
      alt={imageAlt}
      class="h-full w-full object-cover opacity-40"
      loading="eager"
    />
    <div
      aria-hidden="true"
      class="absolute inset-0 bg-gradient-to-r from-[#FBFBFA] via-[#FBFBFA]/80 to-transparent"
    ></div>
    <div
      aria-hidden="true"
      class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-[#FBFBFA] to-transparent"
    ></div>
  </div>

  <!-- Main content -->
  <div class="relative flex-1 grid grid-cols-12 gap-0 px-6 md:px-10 lg:px-12 pt-32 md:pt-44 pb-8">
    <!-- Left: brutalist title -->
    <div class="col-span-12 md:col-span-8 xl:col-span-7 flex flex-col justify-center">
      <p class="mono-detail mb-6 md:mb-8 text-slate-500">
        {eyebrow}
      </p>
      <h1
        class="font-mono text-[12vw] md:text-[7.5vw] xl:text-[6.8vw] leading-[0.92] tracking-[-0.04em] text-slate-900 uppercase max-w-full"
      >
        <span class="headline-mask"><span>{titleLines[0]}</span></span>
        <span class="headline-mask"><span>{titleLines[1]}</span></span>
        <span class="headline-mask"><span>{titleLines[2]}</span></span>
      </h1>

      <p
        class="mt-8 md:mt-12 text-sm md:text-base text-slate-600 max-w-[48ch] leading-relaxed"
      >
        {subtitle}
      </p>
    </div>

    <!-- Right: coordinates + CTA -->
    <aside class="col-span-12 md:col-span-4 xl:col-span-5 flex flex-col justify-end items-start md:items-end gap-6 mt-10 md:mt-0">
      <span class="mono-detail text-slate-400">{company.coordinates.display}</span>
      <a
        href="#projects"
        class="inline-block font-mono text-[11px] uppercase tracking-[0.2em] text-slate-900 border border-slate-800 px-6 py-3 transition-colors duration-300 hover:bg-slate-900 hover:text-white"
      >
        Смотреть объекты ↘
      </a>
    </aside>
  </div>

  <!-- METRICS INFO-BAR -->
  <div class="relative w-full bg-[#F5F4F0] border-t border-slate-200">
    <div class="px-6 md:px-10 lg:px-12 py-8 md:py-10 grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-0">
      {metrics.map((m, i) => (
        <div class={`flex flex-col gap-2 ${i > 0 ? "md:border-l md:border-slate-200 md:pl-8" : ""}`}>
          <span class="font-mono text-3xl md:text-4xl xl:text-5xl tracking-tight text-slate-900 font-medium">
            {m.value}
          </span>
          <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-500">
            {m.label}
          </span>
        </div>
      ))}

      <!-- CTA in bar -->
      <div class="hidden md:flex items-center justify-end">
        <a
          href="#contact"
          class="font-mono text-[11px] uppercase tracking-[0.2em] text-slate-900 border border-slate-800 px-6 py-3 transition-colors duration-300 hover:bg-slate-900 hover:text-white"
        >
          Связаться →
        </a>
      </div>
    </div>
  </div>
</section>
