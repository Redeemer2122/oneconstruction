---
const purchaseCards = [
  {
    meta: "до 12%",
    title: "Полная оплата",
    body: "Сразу покупаете квартиру полностью, никаких переплат и процентов.",
    cta: "Оставить заявку",
  },
  {
    meta: "до 70 мес.",
    title: "Рассрочка 0%",
    body: "Оплачивайте равными частями без переплаты, на срок до 70 месяцев.",
    cta: "Рассчитать график",
  },
  {
    meta: "зачёт",
    title: "Trade-in",
    body: "Меняйте старую квартиру или автомобиль на новый объект с доплатой.",
    cta: "Узнать оценку",
  },
  {
    meta: "бонусы",
    title: "Бонусная программа",
    body: "Скидки, подарки и специальные условия для постоянных клиентов.",
    cta: "Подключиться",
  },
] as const;
---

<section id="purchase" class="purchase-section oc-chapter oc-chapter--commercial" aria-label="Выберите удобный вариант покупки">
  <div class="section-stitch-top stitch-technical-to-commercial" aria-hidden="true"></div>
  <div class="purchase-shell">
    <aside class="purchase-intro" data-reveal>
      <p class="purchase-label">ПОКУПКА</p>
      <h2>ВЫБЕРИТЕ УДОБНЫЙ ВАРИАНТ ПОКУПКИ<span>.</span></h2>
      <div class="purchase-intro__rule" aria-hidden="true"></div>
      <p class="purchase-description">
        Три основных способа покупки и дополнительная бонусная программа для повторных клиентов и рекомендаций.
      </p>
      <a class="purchase-intro__cta" href="#contact">
        <span>Оставить заявку</span>
        <span aria-hidden="true">↗</span>
      </a>
    </aside>

    <div class="purchase-grid">
      {purchaseCards.map((card, index) => (
        <article class="purchase-card" data-reveal style={`--reveal-delay: ${0.08 * index}s;`}>
          <div class="purchase-card__top">
            <span>{String(index + 1).padStart(2, "0")}.</span>
            <span>{card.meta}</span>
          </div>
          <div class="purchase-card__divider" aria-hidden="true"></div>

          <div class="purchase-card__content">
            <h3>{card.title}</h3>
            <span class="purchase-card__accent" aria-hidden="true"></span>
            <p>{card.body}</p>
          </div>

          <a class="purchase-card__cta" href="#contact">
            <span>{card.cta}</span>
            <span aria-hidden="true">↗</span>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .purchase-section {
    position: relative; overflow: hidden;
    border-top: 1px solid rgb(15 23 42 / 0.1);
    background:
      linear-gradient(90deg, rgb(15 23 42 / 0.018) 1px, transparent 1px) 50% 0 / min(26vw, 390px) 100%,
      radial-gradient(circle at 18% 10%, rgb(148 163 184 / 0.14), transparent 27%),
      linear-gradient(180deg, #f8f6f0 0%, #f5f2ea 100%);
  }

  .purchase-section::before {
    position: absolute; inset: 0; pointer-events: none; content: "";
    background:
      linear-gradient(180deg, rgb(255 255 252 / 0.42), transparent 38%, rgb(15 23 42 / 0.016)),
      linear-gradient(135deg, transparent 0 74%, rgb(15 23 42 / 0.045) 74.08% 74.16%, transparent 74.24%);
  }

  .purchase-shell {
    position: relative; display: grid;
    grid-template-columns: minmax(280px, 0.78fr) minmax(0, 1.42fr);
    gap: clamp(44px, 5.2vw, 84px);
    max-width: 1500px; margin: 0 auto;
    padding: clamp(72px, 7vw, 112px) clamp(22px, 5vw, 88px) clamp(76px, 7.6vw, 118px);
  }

  .purchase-label {
    font-family: var(--font-mono, monospace);
    font-size: 13px; font-weight: 700; line-height: 1.15;
    letter-spacing: 0.18em; text-transform: uppercase;
  }

  .purchase-label { margin: 0 0 clamp(42px, 5.6vw, 72px); color: rgb(71 85 105 / 0.72); }

  .purchase-intro { position: relative; min-width: 0; }

  .purchase-intro::after {
    position: absolute;
    left: -48px; bottom: 0; width: min(30vw, 420px); height: 190px;
    pointer-events: none; content: ""; opacity: 0.48;
    background:
      linear-gradient(90deg, transparent 0 42px, rgb(15 23 42 / 0.12) 42px 43px, transparent 43px),
      linear-gradient(0deg, transparent 0 46px, rgb(15 23 42 / 0.08) 46px 47px, transparent 47px),
      linear-gradient(135deg, transparent 0 30%, rgb(109 40 217 / 0.16) 30.2% 30.7%, transparent 30.9%);
  }

  .purchase-intro h2 {
    max-width: 7.7em; margin: 0; color: #151a24;
    font-family: var(--font-mono, monospace);
    font-size: clamp(48px, 4.7vw, 76px); font-weight: 700; line-height: 1.02;
    letter-spacing: 0;
  }

  .purchase-intro h2 span { color: #5b3bc4; }

  .purchase-intro__rule {
    position: relative; width: min(100%, 360px); height: 1px;
    margin: 34px 0 30px;
    background: rgb(15 23 42 / 0.22);
  }

  .purchase-intro__rule::after {
    position: absolute; right: -8px; top: -8px; color: rgb(91 59 196 / 0.74); content: "+";
    font-family: var(--font-mono, monospace);
    font-size: 16px; line-height: 1;
  }

  .purchase-description {
    max-width: 36ch; margin: 0;
    color: rgb(51 65 85 / 0.86);
    font-size: clamp(17px, 1.28vw, 21px);
    line-height: 1.55;
  }

  .purchase-intro__cta {
    display: inline-flex; align-items: center;
    min-width: min(100%, 320px);
    margin-top: clamp(38px, 5vw, 58px);
    border: 1px solid rgb(15 23 42 / 0.92);
    background: #111827;
    box-shadow: 0 22px 46px rgb(15 23 42 / 0.16);
    color: #f8f7f2;
    font-size: 18px; font-weight: 700; line-height: 1; text-decoration: none;
  }

  .purchase-intro__cta span:first-child { flex: 1; padding: 24px 28px; }

  .purchase-intro__cta span:last-child {
    display: grid; width: 72px; align-self: stretch; place-items: center;
    border-left: 1px solid rgb(248 247 242 / 0.22);
    color: #8b5cf6; font-size: 26px;
    transition: transform 260ms cubic-bezier(0.16, 1, 0.3, 1), opacity 260ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .purchase-intro__cta:hover span:last-child {
    opacity: 0.88;
    transform: translate(3px, -3px);
  }

  .purchase-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    grid-auto-rows: 1fr;
    gap: 20px;
  }

  .purchase-card {
    position: relative; display: flex; min-width: 0;
    min-height: clamp(260px, 24vw, 340px); height: 100%;
    flex-direction: column;
    border: 1px solid rgb(15 23 42 / 0.14);
    background:
      linear-gradient(180deg, rgb(255 255 252 / 0.72), rgb(245 244 240 / 0.84)),
      #f8f7f2;
    box-shadow:
      0 28px 54px rgb(15 23 42 / 0.055),
      0 1px 0 rgb(255 255 252 / 0.84) inset,
      0 -1px 0 rgb(15 23 42 / 0.048) inset;
    padding: clamp(26px, 2.45vw, 36px);
    transition: transform 260ms cubic-bezier(0.16, 1, 0.3, 1), border-color 260ms cubic-bezier(0.16, 1, 0.3, 1), box-shadow 260ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .purchase-card::before,
  .purchase-card::after {
    position: absolute; right: -1px; pointer-events: none; content: "";
  }

  .purchase-card::before {
    top: -1px; width: 18px; height: 18px;
    border: 1px solid rgb(15 23 42 / 0.12);
    background:
      linear-gradient(90deg, transparent 8px, rgb(15 23 42 / 0.12) 8px 9px, transparent 9px),
      linear-gradient(0deg, transparent 8px, rgb(15 23 42 / 0.12) 8px 9px, transparent 9px);
  }

  .purchase-card::after {
    bottom: 10px; width: 1px; height: 34px;
    border-right: 1px dashed rgb(15 23 42 / 0.18);
  }

  .purchase-card:hover {
    transform: translateY(-4px);
    border-color: rgb(109 40 217 / 0.38);
    box-shadow:
      0 34px 68px rgb(15 23 42 / 0.085),
      0 1px 0 rgb(255 255 252 / 0.9) inset,
      0 -1px 0 rgb(15 23 42 / 0.05) inset;
  }

  .purchase-card__top {
    display: flex; align-items: flex-start; justify-content: space-between;
    gap: 20px; color: #273240;
    font-family: var(--font-mono, monospace);
    font-size: clamp(18px, 1.3vw, 22px);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: 0.02em;
  }

  .purchase-card__divider {
    height: 1px;
    margin: 24px 0 clamp(40px, 4.7vw, 66px);
    background: rgb(15 23 42 / 0.13);
  }

  .purchase-card__content { display: grid; gap: 22px; }

  .purchase-card h3 {
    max-width: 14ch; margin: 0; color: #151a24;
    font-size: clamp(32px, 2.7vw, 44px);
    font-weight: 700; line-height: 1.02; letter-spacing: 0;
  }

  .purchase-card__accent { width: 58px; height: 2px; background: rgb(91 59 196 / 0.62); }

  .purchase-card p {
    max-width: 31ch; margin: 0;
    color: rgb(51 65 85 / 0.82);
    font-size: clamp(16px, 1.15vw, 20px);
    line-height: 1.32;
  }

  .purchase-card__cta {
    display: flex; align-items: center; justify-content: space-between;
    gap: 24px;
    margin-top: auto; padding-top: clamp(34px, 4vw, 56px);
    color: #151a24;
    font-size: clamp(16px, 1.1vw, 19px);
    font-weight: 700; line-height: 1; text-decoration: none;
  }

  .purchase-card__cta span:last-child {
    color: #5b3bc4; font-size: 30px; font-weight: 400; line-height: 0.8;
    transition: transform 260ms cubic-bezier(0.16, 1, 0.3, 1), opacity 260ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .purchase-card:hover .purchase-card__cta span:last-child {
    opacity: 0.88;
    transform: translate(4px, -4px);
  }

  @media (max-width: 767px) {
    .purchase-shell {
      grid-template-columns: 1fr;
      gap: 34px; padding: 58px 20px 66px;
    }

    .purchase-label { margin-bottom: 32px; }
    .purchase-intro::after { display: none; }

    .purchase-intro h2 {
      max-width: 8.2em;
      font-size: clamp(38px, 12vw, 48px);
    }

    .purchase-intro__rule { margin: 28px 0 24px; }

    .purchase-intro__cta {
      width: 100%; min-width: 0; margin-top: 34px; font-size: 16px;
    }

    .purchase-grid {
      grid-template-columns: 1fr;
      gap: 18px;
    }

    .purchase-card { min-height: 310px; padding: 24px; }
  }
</style>
