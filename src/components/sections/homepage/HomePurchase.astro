---
import { purchaseOptions, purchaseSection } from "@data/purchase";

const titleLines = purchaseSection.title.toLocaleUpperCase("ru-RU").split(" ");
---

<section id="purchase" class="purchase-section oc-chapter oc-chapter--commercial" aria-label={purchaseSection.title}>
  <div class="section-stitch-top stitch-technical-to-commercial" aria-hidden="true"></div>

  <div class="purchase-shell">
    <aside class="purchase-intro" data-reveal>
      <p class="purchase-label">{purchaseSection.label}</p>

      <h2>
        {titleLines.map((line) => <span>{line}</span>)}
        <span aria-hidden="true" class="purchase-title-dot">.</span>
      </h2>

      <div class="purchase-intro__rule" aria-hidden="true"></div>

      <p class="purchase-description">{purchaseSection.intro}</p>

      <a class="purchase-intro__cta" href="#contact">
        <span>{purchaseSection.cta}</span>
        <span aria-hidden="true">↗</span>
      </a>
    </aside>

    <div class="purchase-grid" data-reveal style="--reveal-delay: 0.08s;">
      {purchaseOptions.map((option, index) => (
        <article class="purchase-card" data-reveal style={`--reveal-delay: ${0.12 + 0.05 * index}s;`}>
          <div class="purchase-card__top">
            <span>{option.index}.</span>
            <strong>{option.metric}</strong>
          </div>

          <div class="purchase-card__rule" aria-hidden="true"></div>

          <div class="purchase-card__content">
            <h3>{option.title}</h3>
            <span class="purchase-card__accent" aria-hidden="true"></span>
            <p>{option.body}</p>
          </div>

          <a class="purchase-card__cta" href="#contact">
            <span>{option.cta}</span>
            <span aria-hidden="true">↗</span>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .purchase-section {
    position: relative;
    overflow: hidden;
    border-top: 1px solid rgb(15 23 42 / 0.08);
    border-bottom: 1px solid rgb(15 23 42 / 0.08);
    background:
      radial-gradient(circle at 8% 22%, rgb(255 255 252 / 0.68), transparent 28%),
      linear-gradient(180deg, #f8f6f0 0%, #f3f0e7 100%);
  }

  .purchase-section::before {
    position: absolute;
    inset: 0;
    pointer-events: none;
    content: "";
    background:
      linear-gradient(90deg, rgb(15 23 42 / 0.018) 1px, transparent 1px) 50% 0 / min(24vw, 380px) 100%,
      linear-gradient(180deg, rgb(255 255 252 / 0.34), transparent 42%, rgb(15 23 42 / 0.018));
  }

  .purchase-shell {
    position: relative;
    display: grid;
    grid-template-columns: minmax(300px, 0.61fr) minmax(0, 1fr);
    gap: clamp(48px, 5vw, 82px);
    max-width: 1510px;
    margin: 0 auto;
    padding: clamp(76px, 7.2vw, 112px) clamp(22px, 5.4vw, 88px) clamp(78px, 7vw, 108px);
  }

  .purchase-intro {
    min-width: 0;
    padding-top: clamp(10px, 1.4vw, 22px);
  }

  .purchase-label {
    margin: 0 0 clamp(42px, 5.6vw, 72px);
    color: #4f36bd;
    font-family: var(--font-mono, monospace);
    font-size: clamp(12px, 0.9vw, 15px);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .purchase-intro h2 {
    display: grid;
    gap: 0.015em;
    max-width: 8.9em;
    margin: 0;
    color: #121824;
    font-size: clamp(52px, 5.05vw, 86px);
    font-weight: 700;
    line-height: 0.98;
    letter-spacing: 0;
  }

  .purchase-title-dot {
    display: inline;
    color: #4f36bd;
  }

  .purchase-intro__rule {
    position: relative;
    width: min(100%, 380px);
    height: 1px;
    margin: clamp(28px, 3vw, 38px) 0 clamp(28px, 3vw, 36px);
    background: rgb(79 54 189 / 0.36);
  }

  .purchase-intro__rule::after {
    position: absolute;
    right: 0;
    top: -9px;
    color: #6547d5;
    content: "+";
    font-family: var(--font-mono, monospace);
    font-size: 16px;
    font-weight: 700;
    line-height: 1;
  }

  .purchase-description {
    max-width: 34ch;
    margin: 0;
    color: rgb(51 65 85 / 0.84);
    font-size: clamp(17px, 1.28vw, 21px);
    line-height: 1.48;
  }

  .purchase-intro__cta {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 70px;
    width: min(100%, 340px);
    margin-top: clamp(34px, 4vw, 48px);
    border: 1px solid rgb(15 23 42 / 0.88);
    background: #101624;
    color: #f8f7f2;
    font-size: clamp(16px, 1.2vw, 19px);
    font-weight: 700;
    line-height: 1;
    text-decoration: none;
    box-shadow: 0 18px 42px rgb(15 23 42 / 0.12);
    transition:
      transform 280ms cubic-bezier(0.16, 1, 0.3, 1),
      background 280ms cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 280ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .purchase-intro__cta span:first-child {
    min-width: 0;
    padding: 23px 28px;
  }

  .purchase-intro__cta span:last-child {
    display: grid;
    place-items: center;
    border-left: 1px solid rgb(248 247 242 / 0.22);
    color: #7455e7;
    font-size: 25px;
    transition: transform 280ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .purchase-intro__cta:hover,
  .purchase-intro__cta:focus-visible {
    background: #0d1320;
    box-shadow: 0 22px 50px rgb(15 23 42 / 0.16);
    transform: translateY(-2px);
  }

  .purchase-intro__cta:hover span:last-child,
  .purchase-intro__cta:focus-visible span:last-child {
    transform: translate(4px, -4px);
  }

  .purchase-intro__cta:active {
    transform: translateY(0);
  }

  .purchase-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    grid-auto-rows: 1fr;
    gap: clamp(18px, 1.7vw, 24px);
    min-width: 0;
  }

  .purchase-card {
    position: relative;
    display: flex;
    min-width: 0;
    min-height: clamp(300px, 24vw, 372px);
    flex-direction: column;
    border: 1px solid rgb(15 23 42 / 0.15);
    background:
      linear-gradient(180deg, rgb(255 255 252 / 0.78), rgb(245 244 240 / 0.86)),
      #f8f7f2;
    box-shadow:
      0 16px 42px rgb(15 23 42 / 0.04),
      0 1px 0 rgb(255 255 252 / 0.82) inset;
    transition:
      transform 280ms cubic-bezier(0.16, 1, 0.3, 1),
      border-color 280ms cubic-bezier(0.16, 1, 0.3, 1),
      background 280ms cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 280ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .purchase-card:hover,
  .purchase-card:focus-within {
    border-color: rgb(79 54 189 / 0.34);
    background:
      linear-gradient(180deg, rgb(255 255 252 / 0.92), rgb(246 244 239 / 0.94)),
      #fbfaf6;
    box-shadow:
      0 22px 52px rgb(15 23 42 / 0.07),
      0 1px 0 rgb(255 255 252 / 0.9) inset;
    transform: translateY(-4px);
  }

  .purchase-card__top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 18px;
    padding: clamp(26px, 2.4vw, 36px) clamp(26px, 2.8vw, 40px) 0;
    color: #4f36bd;
    font-family: var(--font-mono, monospace);
    font-size: clamp(18px, 1.45vw, 25px);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: 0.04em;
  }

  .purchase-card__top strong {
    font: inherit;
    letter-spacing: 0;
    text-align: right;
  }

  .purchase-card__rule {
    height: 1px;
    margin: clamp(18px, 1.8vw, 26px) clamp(26px, 2.8vw, 40px) 0;
    background: rgb(15 23 42 / 0.14);
  }

  .purchase-card__content {
    display: grid;
    gap: clamp(18px, 1.8vw, 24px);
    padding: clamp(34px, 4.2vw, 58px) clamp(26px, 2.8vw, 40px) clamp(28px, 3vw, 38px);
  }

  .purchase-card h3 {
    max-width: 13ch;
    margin: 0;
    color: #121824;
    font-size: clamp(32px, 2.9vw, 50px);
    font-weight: 700;
    line-height: 1.02;
    letter-spacing: 0;
    text-wrap: balance;
  }

  .purchase-card__accent {
    width: 70px;
    height: 3px;
    background: #4f36bd;
  }

  .purchase-card p {
    max-width: 33ch;
    margin: 0;
    color: rgb(51 65 85 / 0.82);
    font-size: clamp(16px, 1.18vw, 20px);
    line-height: 1.34;
  }

  .purchase-card__cta {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 56px;
    align-items: center;
    min-height: 68px;
    margin-top: auto;
    border-top: 1px solid rgb(15 23 42 / 0.13);
    color: #121824;
    font-size: clamp(16px, 1.12vw, 19px);
    font-weight: 700;
    line-height: 1.1;
    text-decoration: none;
  }

  .purchase-card__cta span:first-child {
    min-width: 0;
    padding: 19px clamp(26px, 2.8vw, 40px);
  }

  .purchase-card__cta span:last-child {
    display: grid;
    place-items: center;
    color: #4f36bd;
    font-size: 28px;
    line-height: 1;
    transition:
      transform 280ms cubic-bezier(0.16, 1, 0.3, 1),
      color 280ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .purchase-card:hover .purchase-card__cta span:last-child,
  .purchase-card:focus-within .purchase-card__cta span:last-child {
    color: #6547d5;
    transform: translate(4px, -4px);
  }

  .purchase-card__cta:focus-visible,
  .purchase-intro__cta:focus-visible {
    outline: 2px solid rgb(79 54 189 / 0.52);
    outline-offset: 4px;
  }

  @media (max-width: 1080px) {
    .purchase-shell {
      grid-template-columns: 1fr;
    }

    .purchase-intro h2 {
      max-width: 100%;
    }
  }

  @media (max-width: 767px) {
    .purchase-shell {
      gap: 34px;
      padding: 58px 20px 66px;
    }

    .purchase-label {
      margin-bottom: 30px;
      font-size: 11px;
    }

    .purchase-intro h2 {
      max-width: 8.6em;
      font-size: clamp(38px, 11.6vw, 46px);
      line-height: 1;
    }

    .purchase-intro__rule {
      width: calc(100% - 22px);
      margin: 26px 0 24px;
    }

    .purchase-description {
      max-width: 100%;
      font-size: 16px;
      line-height: 1.48;
    }

    .purchase-intro__cta {
      grid-template-columns: minmax(0, 1fr) 58px;
      width: 100%;
      margin-top: 30px;
      font-size: 16px;
    }

    .purchase-intro__cta span:first-child {
      padding: 21px 22px;
    }

    .purchase-grid {
      grid-template-columns: 1fr;
      grid-auto-rows: auto;
      gap: 18px;
    }

    .purchase-card {
      min-height: 0;
    }

    .purchase-card__top {
      padding: 24px 24px 0;
      font-size: clamp(18px, 5.4vw, 22px);
    }

    .purchase-card__rule {
      margin: 18px 24px 0;
    }

    .purchase-card__content {
      gap: 16px;
      padding: 30px 24px 28px;
    }

    .purchase-card h3 {
      max-width: 100%;
      font-size: clamp(30px, 8.2vw, 36px);
    }

    .purchase-card p {
      max-width: 100%;
      font-size: 16px;
      line-height: 1.42;
    }

    .purchase-card__accent {
      width: 64px;
      height: 2px;
    }

    .purchase-card__cta {
      grid-template-columns: minmax(0, 1fr) 50px;
      min-height: 62px;
      font-size: 15px;
    }

    .purchase-card__cta span:first-child {
      padding: 18px 24px;
    }

    .purchase-card__cta span:last-child {
      font-size: 25px;
    }
  }
</style>
