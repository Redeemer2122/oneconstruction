---
const purchaseCards = [
  {
    title: "Полная оплата",
    metric: "до 12%",
    body: "Сразу покупаете квартиру полностью, никаких переплат и процентов.",
    cta: "Оставить заявку",
  },
  {
    title: "Рассрочка 0%",
    metric: "до 70 мес.",
    body: "Оплачивайте равными частями без переплаты, на срок до 70 месяцев.",
    cta: "Рассчитать график",
  },
  {
    title: "Trade-in",
    metric: "зачёт",
    body: "Меняйте старую квартиру или автомобиль на новый объект с доплатой.",
    cta: "Узнать оценку",
  },
  {
    title: "Бонусная программа",
    metric: "бонусы",
    body: "Скидки, подарки и специальные условия для постоянных клиентов.",
    cta: "Подключиться",
  },
] as const;
---

<section id="purchase" class="purchase-section" aria-label="Выберите удобный вариант покупки">
  <div class="purchase-shell">
    <div class="purchase-intro" data-reveal>
      <p class="purchase-label">ПОКУПКА · 05</p>
      <h2>ВЫБЕРИТЕ УДОБНЫЙ ВАРИАНТ ПОКУПКИ.</h2>
      <p class="purchase-description">
        Три основных способа покупки и дополнительная бонусная программа для повторных клиентов и рекомендаций.
      </p>
    </div>

    <div class="purchase-grid">
      {purchaseCards.map((card, index) => (
        <article class="purchase-card" data-reveal style={`--reveal-delay: ${0.08 * index}s;`}>
          <div class="purchase-card__top">
            <span>{String(index + 1).padStart(2, "0")}</span>
            <span>{card.metric}</span>
          </div>

          <div class="purchase-card__content">
            <h3>{card.title}</h3>
            <p>{card.body}</p>
          </div>

          <a class="purchase-card__cta" href="#contact">
            <span>{card.cta}</span>
            <span aria-hidden="true">+</span>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .purchase-section { background: #f5f4f0; border-top: 1px solid rgb(15 23 42 / 0.12); }

  .purchase-shell {
    display: grid;
    grid-template-columns: minmax(280px, 0.85fr) minmax(0, 1.35fr);
    gap: clamp(32px, 5vw, 72px);
    max-width: 1360px;
    margin: 0 auto;
    padding: clamp(72px, 9vw, 128px) clamp(20px, 5vw, 64px);
  }

  .purchase-label,
  .purchase-card__top,
  .purchase-card__cta {
    font-family: var(--font-mono, monospace);
    font-size: 11px;
    line-height: 1.2;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .purchase-label {
    margin: 0 0 24px;
    color: rgb(88 28 135 / 0.82);
  }

  .purchase-intro h2 {
    max-width: 9.8em;
    margin: 0;
    color: #0f172a;
    font-family: var(--font-mono, monospace);
    font-size: clamp(34px, 4.4vw, 68px);
    line-height: 0.96;
    letter-spacing: 0;
  }

  .purchase-description {
    max-width: 34rem;
    margin: 28px 0 0;
    color: rgb(51 65 85 / 0.88);
    font-size: clamp(16px, 1.35vw, 19px);
    line-height: 1.55;
  }

  .purchase-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
  }

  .purchase-card {
    display: flex;
    min-width: 0;
    min-height: 260px;
    flex-direction: column;
    justify-content: space-between;
    gap: 30px;
    border: 1px solid rgb(15 23 42 / 0.14);
    background: rgb(250 249 245 / 0.82);
    padding: clamp(24px, 3vw, 34px);
    transition: transform 280ms cubic-bezier(0.22, 1, 0.36, 1), border-color 280ms cubic-bezier(0.22, 1, 0.36, 1), background-color 280ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .purchase-card:hover {
    transform: translateY(-4px);
    border-color: rgb(109 40 217 / 0.55);
    background: rgb(255 255 252 / 0.94);
  }

  .purchase-card__top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    color: rgb(88 28 135 / 0.78);
  }

  .purchase-card__content {
    display: grid;
    gap: 18px;
  }

  .purchase-card h3 {
    margin: 0;
    color: #111827;
    font-family: var(--font-mono, monospace);
    font-size: clamp(24px, 2vw, 34px);
    line-height: 1.04;
    letter-spacing: 0;
  }

  .purchase-card p {
    max-width: 28rem;
    margin: 0;
    color: rgb(51 65 85 / 0.9);
    font-size: 15px;
    line-height: 1.55;
  }

  .purchase-card__cta {
    display: inline-flex;
    width: fit-content;
    max-width: 100%;
    align-items: center;
    gap: 12px;
    color: #111827;
    text-decoration: none;
  }

  .purchase-card__cta span:last-child {
    color: #6d28d9;
    transition: transform 280ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .purchase-card:hover .purchase-card__cta span:last-child { transform: translateX(4px); }

  @media (max-width: 767px) {
    .purchase-shell {
      grid-template-columns: 1fr;
      padding-block: 64px;
    }

    .purchase-grid {
      grid-template-columns: 1fr;
      gap: 18px;
    }

    .purchase-card {
      min-height: 0;
      gap: 28px;
    }
  }
</style>
