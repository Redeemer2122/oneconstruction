---
import { purchaseOptions, purchaseSection } from "@data/purchase";

const label = `${purchaseSection.label} / ${String(purchaseOptions.length).padStart(2, "0")}`;
const titleWords = purchaseSection.title.toLocaleUpperCase("ru-RU").split(" ");
const titleLines = [
  titleWords[0],
  titleWords[1],
  titleWords.slice(2, 4).join(" "),
  titleWords.slice(4).join(" "),
].filter(Boolean);
---

<section id="purchase" class="purchase-section oc-chapter oc-chapter--commercial" aria-labelledby="purchase-title">
  <div class="section-stitch-top stitch-technical-to-commercial" aria-hidden="true"></div>

  <div class="purchase-shell">
    <aside class="purchase-intro" data-reveal>
      <div class="purchase-kicker">
        <span class="purchase-kicker__rule" aria-hidden="true"></span>
        <p class="purchase-label mono-detail text-violet-700">{label}</p>
      </div>

      <h2 id="purchase-title" class="purchase-title display uppercase text-slate-950" aria-label={purchaseSection.title}>
        {titleLines.map((line) => (
          <span>{line}</span>
        ))}
      </h2>

      <p class="purchase-description">{purchaseSection.intro}</p>

      <a class="purchase-cta" href="#contact">
        <span>{purchaseSection.cta}</span>
        <span aria-hidden="true">↗</span>
      </a>
    </aside>

    <div class="purchase-board" data-reveal style="--reveal-delay: 0.08s;">
      <ol class="purchase-matrix" aria-label="Варианты покупки">
        {purchaseOptions.map((option, index) => (
          <li
            class:list={["purchase-matrix__item", { "purchase-matrix__item--accent": option.index === "02" }]}
            data-reveal
            style={`--reveal-delay: ${0.12 + 0.05 * index}s;`}
          >
            <article class="purchase-option">
              <header class="purchase-option__header">
                <span class="purchase-option__number" aria-hidden="true">{option.index}</span>
                <span class="purchase-option__mark" aria-hidden="true"></span>
              </header>

              <div class="purchase-option__body">
                <h3>{option.title}</h3>
                <p class="purchase-option__text">{option.body}</p>
              </div>

              <footer class="purchase-option__footer">
                {option.metric && <p class="purchase-option__metric">{option.metric}</p>}

                {option.cta && (
                  <a class="purchase-option__cta" href="#contact">
                    <span>{option.cta}</span>
                    <span aria-hidden="true">↗</span>
                  </a>
                )}
              </footer>
            </article>
          </li>
        ))}
      </ol>
    </div>
  </div>
</section>

<style>
  .purchase-section {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    border-top: 1px solid rgb(15 23 42 / 0.1);
    border-bottom: 1px solid rgb(15 23 42 / 0.1);
    background: #f7f5ef;
    color: #101827;
  }

  .purchase-section::before {
    position: absolute;
    inset: clamp(2.25rem, 4vw, 4rem) clamp(1.1rem, 3vw, 3rem);
    z-index: -1;
    pointer-events: none;
    content: "";
    border-top: 1px solid rgb(15 23 42 / 0.07);
    border-bottom: 1px solid rgb(15 23 42 / 0.06);
  }

  .purchase-shell {
    position: relative;
    display: grid;
    grid-template-columns: minmax(18rem, 0.68fr) minmax(0, 1.32fr);
    gap: clamp(3.25rem, 5.7vw, 6.8rem);
    max-width: 1620px;
    margin: 0 auto;
    padding: clamp(5.45rem, 7.4vw, 7.85rem) clamp(1.15rem, 4.4vw, 4.65rem) clamp(5.85rem, 7.65vw, 8.15rem);
  }

  .purchase-intro {
    display: flex;
    min-width: 0;
    flex-direction: column;
    align-items: flex-start;
    padding-top: clamp(0.35rem, 1vw, 0.95rem);
  }

  .purchase-kicker {
    display: grid;
    grid-template-columns: clamp(2.9rem, 4.6vw, 4.75rem) auto;
    align-items: center;
    gap: 1rem;
    margin-bottom: clamp(2rem, 3vw, 3.15rem);
  }

  .purchase-kicker__rule {
    height: 1px;
    background: rgb(93 58 196 / 0.72);
  }

  .purchase-label {
    margin: 0;
    font-family: var(--font-mono, monospace);
    font-size: 10px;
    font-weight: 400;
    line-height: 1.4;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .purchase-title {
    display: grid;
    max-width: 8.55em;
    margin: 0;
    color: #0f172a;
    font-family: var(--font-display);
    font-size: clamp(3.04rem, 4.76vw, 5.48rem);
    font-weight: 500;
    line-height: 0.96;
    letter-spacing: -0.024em;
    text-wrap: balance;
  }

  .purchase-title span {
    display: block;
  }

  .purchase-description {
    max-width: 34rem;
    margin: clamp(2rem, 3.2vw, 3rem) 0 0;
    padding-top: clamp(1.45rem, 2.2vw, 2.1rem);
    border-top: 1px solid rgb(15 23 42 / 0.14);
    color: #475569;
    font-size: clamp(1rem, 1.05vw, 1.12rem);
    line-height: 1.68;
  }

  .purchase-cta {
    display: inline-grid;
    grid-template-columns: minmax(0, 1fr) 3.9rem;
    align-items: stretch;
    min-width: min(100%, 21rem);
    margin-top: clamp(2rem, 3.4vw, 3rem);
    border: 1px solid #0d1422;
    background: #0d1422;
    color: #f8f7f2;
    font-family: var(--font-mono, monospace);
    font-size: 11px;
    font-weight: 400;
    line-height: 1.4;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background-color 240ms cubic-bezier(0.16, 1, 0.3, 1), border-color 240ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .purchase-cta span:first-child {
    min-width: 0;
    padding: 1.32rem 1.55rem;
  }

  .purchase-cta span:last-child {
    display: grid;
    place-items: center;
    border-left: 1px solid rgb(248 247 242 / 0.2);
    color: #8b74e8;
    font-size: 1.45rem;
    line-height: 1;
    transition: transform 240ms cubic-bezier(0.16, 1, 0.3, 1), color 240ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .purchase-cta:hover,
  .purchase-cta:focus-visible {
    border-color: #5137bd;
    background: #5137bd;
  }

  .purchase-cta:hover span:last-child,
  .purchase-cta:focus-visible span:last-child {
    color: #f8f7f2;
    transform: translate(0.16rem, -0.16rem);
  }

  .purchase-cta:active {
    transform: scale(0.99);
  }

  .purchase-board {
    min-width: 0;
    align-self: center;
  }

  .purchase-matrix {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    --purchase-divider: rgb(15 23 42 / 0.17);
    box-sizing: border-box;
    gap: 0;
    margin: 0;
    padding: 0;
    overflow: hidden;
    border: 1px solid var(--purchase-divider);
    background: transparent;
    list-style: none;
  }

  .purchase-matrix__item {
    min-width: 0;
    margin: 0;
    background: #f7f5ef;
  }

  .purchase-matrix__item:nth-child(2n) {
    border-left: 1px solid var(--purchase-divider);
  }

  .purchase-matrix__item:nth-child(n + 3) {
    border-top: 1px solid var(--purchase-divider);
  }

  .purchase-matrix__item--accent {
    background: #0d1422;
    color: #f8f7f2;
  }

  .purchase-option {
    display: flex;
    min-height: clamp(18.35rem, 21.6vw, 22.65rem);
    min-width: 0;
    flex-direction: column;
    padding: clamp(1.7rem, 2.35vw, 2.75rem) clamp(1.5rem, 2.35vw, 2.8rem) clamp(1.45rem, 1.95vw, 2.25rem);
  }

  .purchase-option__header {
    display: grid;
    justify-items: start;
    gap: 0.95rem;
    margin-bottom: clamp(1.65rem, 2.45vw, 2.9rem);
  }

  .purchase-option__number {
    color: #5137bd;
    font-family: var(--font-mono, monospace);
    font-size: clamp(1.05rem, 1.5vw, 1.55rem);
    line-height: 1;
    letter-spacing: 0.04em;
    font-variant-numeric: tabular-nums;
  }

  .purchase-option__mark {
    display: block;
    width: clamp(2.2rem, 3vw, 3.05rem);
    height: 1px;
    background: rgb(93 58 196 / 0.62);
  }

  .purchase-matrix__item--accent .purchase-option__number,
  .purchase-matrix__item--accent .purchase-option__metric,
  .purchase-matrix__item--accent .purchase-option__cta span:last-child {
    color: #a892ff;
  }

  .purchase-matrix__item--accent .purchase-option__mark,
  .purchase-matrix__item--accent .purchase-option__metric::before {
    background: rgb(168 146 255 / 0.68);
  }

  .purchase-option__body {
    display: grid;
    gap: clamp(1.1rem, 1.45vw, 1.55rem);
    min-width: 0;
  }

  .purchase-option h3 {
    max-width: 12.5ch;
    margin: 0;
    color: #0f172a;
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 2.6vw, 3.15rem);
    font-weight: 500;
    line-height: 0.98;
    letter-spacing: 0;
    text-wrap: balance;
  }

  .purchase-matrix__item--accent .purchase-option h3,
  .purchase-matrix__item--accent .purchase-option__cta {
    color: #f8f7f2;
  }

  .purchase-option__text {
    max-width: 20.5rem;
    margin: 0;
    color: #475569;
    font-size: clamp(0.94rem, 0.98vw, 1rem);
    line-height: 1.64;
  }

  .purchase-matrix__item--accent .purchase-option__text {
    color: rgb(248 247 242 / 0.82);
  }

  .purchase-option__footer {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: clamp(1rem, 2vw, 2rem);
    align-items: end;
    margin-top: auto;
    padding-top: clamp(1.55rem, 2.2vw, 2.65rem);
  }

  .purchase-option__metric {
    position: relative;
    width: fit-content;
    margin: 0;
    padding-top: 0.95rem;
    color: #5137bd;
    font-family: var(--font-mono, monospace);
    font-size: clamp(0.88rem, 1.05vw, 1.05rem);
    line-height: 1.2;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .purchase-option__metric::before {
    position: absolute;
    top: 0;
    left: 0;
    width: clamp(2.8rem, 4.1vw, 4.1rem);
    height: 1px;
    content: "";
    background: rgb(93 58 196 / 0.62);
  }

  .purchase-option__cta {
    display: inline-grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.65rem;
    align-items: start;
    justify-self: end;
    max-width: 13rem;
    color: #0f172a;
    font-family: var(--font-mono, monospace);
    font-size: 10px;
    line-height: 1.45;
    letter-spacing: 0.14em;
    text-align: right;
    text-decoration: none;
    text-transform: uppercase;
    transition: color 220ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .purchase-option__cta span:first-child {
    min-width: 0;
  }

  .purchase-option__cta span:last-child {
    color: #5137bd;
    font-size: 1.2rem;
    line-height: 0.9;
    transition: transform 220ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .purchase-option__cta:hover,
  .purchase-option__cta:focus-visible {
    color: #5137bd;
  }

  .purchase-option__cta:hover span:last-child,
  .purchase-option__cta:focus-visible span:last-child {
    transform: translate(0.14rem, -0.14rem);
  }

  .purchase-cta:focus-visible,
  .purchase-option__cta:focus-visible {
    outline: 2px solid rgb(79 54 189 / 0.52);
    outline-offset: 4px;
  }

  @media (max-width: 1180px) {
    .purchase-shell {
      grid-template-columns: 1fr;
      gap: 3.6rem;
    }

    .purchase-title {
      max-width: 11em;
    }

    .purchase-description {
      max-width: 44rem;
    }

    .purchase-board {
      align-self: auto;
    }
  }

  @media (max-width: 860px) {
    .purchase-matrix {
      grid-template-columns: 1fr;
    }

    .purchase-matrix__item:nth-child(2n) {
      border-left: 0;
    }

    .purchase-matrix__item:nth-child(n + 2) {
      border-top: 1px solid var(--purchase-divider);
    }

    .purchase-option__cta {
      justify-self: start;
      max-width: 100%;
      text-align: left;
    }

    .purchase-matrix__item--accent + .purchase-matrix__item {
      border-top-color: var(--purchase-divider);
    }
  }

  @media (max-width: 767px) {
    .purchase-section::before {
      inset: 1.5rem 1.25rem;
    }

    .purchase-shell {
      gap: 2.7rem;
      padding: 4.45rem 1.25rem 4.9rem;
    }

    .purchase-kicker {
      grid-template-columns: 2.65rem auto;
      gap: 0.85rem;
      margin-bottom: 1.55rem;
    }

    .purchase-label {
      font-size: 10px;
      letter-spacing: 0.14em;
    }

    .purchase-title {
      max-width: 100%;
      font-size: clamp(2.42rem, 10.7vw, 3.22rem);
      line-height: 0.985;
      letter-spacing: -0.018em;
      overflow-wrap: break-word;
    }

    .purchase-description {
      max-width: 100%;
      margin-top: 1.75rem;
      padding-top: 1.3rem;
      font-size: 1rem;
      line-height: 1.65;
    }

    .purchase-cta {
      width: 100%;
      min-width: 0;
      grid-template-columns: minmax(0, 1fr) 3.45rem;
      margin-top: 1.85rem;
    }

    .purchase-cta span:first-child {
      padding: 1.2rem 1.22rem;
    }

    .purchase-option {
      min-height: 0;
      padding: 1.55rem 1.25rem 1.45rem;
    }

    .purchase-option__header {
      gap: 0.8rem;
      margin-bottom: 1.8rem;
    }

    .purchase-option__number {
      font-size: 1rem;
    }

    .purchase-option h3 {
      max-width: 100%;
      font-size: clamp(1.62rem, 7.4vw, 2.15rem);
      line-height: 1.03;
      overflow-wrap: break-word;
    }

    .purchase-option__metric {
      padding-top: 0.64rem;
      font-size: 0.82rem;
    }

    .purchase-option__text {
      max-width: 100%;
      font-size: 0.96rem;
      line-height: 1.62;
      overflow-wrap: break-word;
    }

    .purchase-option__footer {
      grid-template-columns: 1fr;
      gap: 1.05rem;
      justify-items: start;
      padding-top: 1.75rem;
    }

    .purchase-option__cta {
      font-size: 10px;
      overflow-wrap: anywhere;
    }
  }

  @media (max-width: 390px) {
    .purchase-shell {
      padding-right: 1rem;
      padding-left: 1rem;
    }

    .purchase-cta {
      font-size: 10px;
      letter-spacing: 0.12em;
    }
  }
</style>
