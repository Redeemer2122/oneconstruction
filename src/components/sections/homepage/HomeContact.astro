---
/**
 * HomeContact — бруталистичный сплит-экран.
 * Слева: моноширинный блок контактов офиса в Бишкеке.
 * Справа: форма с фокусом на Royal Violet.
 */
import ContactForm from "@modules/ContactForm.tsx";
import { company } from "@data/company";
---

<section
  id="contact"
  class="relative bg-alabaster border-t-[0.5px] border-slate-200 scroll-mt-28"
>
  <div class="section-stitch-top stitch-blueprint-to-alabaster" aria-hidden="true"></div>

  <header class="flex items-end justify-between px-6 md:px-10 pt-20 md:pt-28 pb-8 mb-0 border-b-[0.5px] border-slate-200">
    <span class="mono-detail">КОНТАКТЫ · 06</span>
    <span class="mono-detail">PRIVATE LINE</span>
  </header>

  <div class="grid grid-cols-1 md:grid-cols-2">
    <div class="flex flex-col gap-12 px-6 md:px-10 py-16 md:py-24 border-b-[0.5px] md:border-b-0 md:border-r-[0.5px] border-slate-200 bg-bone">
      <span class="mono-detail text-violet-600">ОФИС · БИШКЕК</span>

      <h2 class="font-mono text-4xl md:text-5xl xl:text-6xl leading-[0.92] tracking-[-0.04em] uppercase text-slate-900 max-w-[14ch]">
        Поговорим о вашей квартире.
      </h2>

      <dl class="flex flex-col gap-8 mt-4">
        <div class="flex flex-col gap-2 border-t-[0.5px] border-slate-200 pt-5">
          <dt class="mono-detail">ТЕЛЕФОН</dt>
          <dd class="flex flex-col gap-1">
            <a
              href={company.phones[0].href}
              class="font-mono text-2xl md:text-3xl tracking-tight text-slate-900 transition-colors duration-300 hover:text-violet-600"
            >
              {company.phones[0].display}
            </a>
          </dd>
        </div>

        <div class="flex flex-col gap-2 border-t-[0.5px] border-slate-200 pt-5">
          <dt class="mono-detail">E-MAIL</dt>
          <dd>
            <a
              href={company.email.href}
              class="font-mono text-base md:text-lg text-slate-900 transition-colors duration-300 hover:text-violet-600 break-all"
            >
              {company.email.display}
            </a>
          </dd>
        </div>

        <div class="flex flex-col gap-2 border-t-[0.5px] border-slate-200 pt-5">
          <dt class="mono-detail">АДРЕС</dt>
          <dd class="font-mono text-sm text-slate-700 leading-relaxed">
            {company.office.addressDisplayRu}<br />
            {company.hours.display}<br />
            {company.hours.sunday}
          </dd>
        </div>

        <div class="flex flex-col gap-2 border-t-[0.5px] border-slate-200 pt-5">
          <dt class="mono-detail">КООРДИНАТЫ</dt>
          <dd class="font-mono text-sm text-slate-700">
            {company.coordinates.display}
          </dd>
        </div>
      </dl>

      <!-- Blueprint map placeholder -->
      <div class="relative border-[0.5px] border-slate-200 bg-alabaster overflow-hidden mt-auto" style="aspect-ratio: 16 / 7;">
        <svg class="absolute inset-0 w-full h-full opacity-[0.12]" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <pattern id="bp-grid" width="24" height="24" patternUnits="userSpaceOnUse">
              <path d="M 24 0 L 0 0 0 24" fill="none" stroke="#1e293b" stroke-width="0.5"/>
            </pattern>
          </defs>
          <rect width="100%" height="100%" fill="url(#bp-grid)"/>
          <path d="M 0 40 H 100% M 0 80 H 100% M 60 0 V 100% M 120 0 V 100%"
                fill="none" stroke="#334155" stroke-width="0.75"/>
        </svg>
        <div class="absolute left-[62%] top-[38%] -translate-x-1/2 -translate-y-1/2 flex flex-col items-center gap-1">
          <div class="w-3 h-3 border-[0.5px] border-violet-600 bg-alabaster rotate-45"></div>
          <span class="font-mono text-[8px] text-violet-600 tracking-widest leading-none">УЛ. РАЗЗАКОВА</span>
        </div>
        <div class="absolute bottom-3 right-3 flex flex-col items-center gap-0.5">
          <span class="font-mono text-[8px] text-slate-500 tracking-widest">N</span>
          <div class="w-px h-4 bg-slate-400/60"></div>
        </div>
        <div class="absolute top-2 left-3 font-mono text-[8px] text-slate-500 tracking-widest leading-none">
          {company.coordinates.display}
        </div>
        <div class="absolute bottom-3 left-3 flex items-center gap-0.5">
          <div class="h-px w-10 bg-slate-400/60"></div>
          <span class="font-mono text-[7px] text-slate-500 tracking-widest">500 М</span>
        </div>
      </div>
    </div>

    <div class="flex flex-col gap-10 px-6 md:px-10 py-16 md:py-24">
      <span class="mono-detail text-violet-600">ЗАЯВКА · 30 СЕК.</span>
      <h3 class="font-mono text-2xl md:text-3xl leading-[0.95] tracking-tight uppercase text-slate-900 max-w-[22ch]">
        Оставьте контакты — пришлём паспорт планировок и приглашение в шоурум.
      </h3>
      <ContactForm client:visible />
    </div>
  </div>
</section>
