---
/**
 * HomeContact — premium office/contact conversion scene.
 * Desktop composition follows the provided reference: left contact column,
 * wide lobby image, floating consultation panel, and full-width map strip.
 */
import { company } from "@data/company";

const mapQuery = encodeURIComponent(`${company.office.addressDisplayRu}, ${company.cityRu}`);
const mapHref = `https://www.google.com/maps/search/?api=1&query=${mapQuery}`;
---

<section id="contact" class="contact-section oc-chapter oc-chapter--contact" aria-labelledby="contact-title">
  <div class="contact-shell">
    <div class="contact-stage">
      <aside class="contact-info" data-reveal>
        <p class="contact-kicker">КОНТАКТЫ</p>
        <h2 id="contact-title" class="contact-title">
          СОЗДАЁМ<br />ПРОСТРАНСТВО<br />ДЛЯ ЖИЗНИ
        </h2>
        <span class="contact-title-rule" aria-hidden="true"></span>
        <p class="contact-lede">
          Обсудим ваш проект и подберём лучшее решение.
        </p>

        <dl class="contact-details" aria-label="Контактные данные One Construction">
          <div class="contact-detail">
            <dt>Адрес</dt>
            <dd>{company.office.addressDisplayRu}</dd>
          </div>

          <div class="contact-detail">
            <dt>Телефон</dt>
            <dd>
              <a href={company.phones[0].href}>{company.phones[0].display}</a>
            </dd>
          </div>

          <div class="contact-detail">
            <dt>E-mail</dt>
            <dd>
              <a href={company.email.href}>{company.email.display}</a>
            </dd>
          </div>

          <div class="contact-detail">
            <dt>График</dt>
            <dd>{company.hours.display}<br />{company.hours.sunday}</dd>
          </div>
        </dl>
      </aside>

      <figure class="contact-image" data-reveal style="--reveal-delay: 0.08s">
        <img
          src="/img/contact/one-construction-office-lobby.png"
          alt="Интерьер офиса продаж One Construction"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <div class="contact-form-panel" data-reveal style="--reveal-delay: 0.16s">
        <header class="contact-form-head">
          <h3>Записаться на консультацию</h3>
          <span aria-hidden="true"></span>
        </header>

        <form class="contact-lead-form" data-contact-form>
          <label class="contact-lead-form__field">
            <span>Ваше имя*</span>
            <input
              name="name"
              required
              autocomplete="name"
              placeholder=" "
            />
          </label>

          <label class="contact-lead-form__field">
            <span>Телефон*</span>
            <input
              name="phone"
              type="tel"
              required
              autocomplete="tel"
              placeholder=" "
            />
          </label>

          <label class="contact-lead-form__field contact-lead-form__field--wide">
            <span>Интересующий объект</span>
            <input
              name="interest"
              autocomplete="off"
              placeholder=" "
            />
          </label>

          <label class="contact-privacy">
            <input type="checkbox" name="privacy" required />
            <span>Я соглашаюсь с политикой в отношении обработки персональных данных</span>
          </label>

          <button class="contact-lead-form__submit" type="submit">
            <span data-submit-label>Оставить заявку</span>
            <span aria-hidden="true">→</span>
          </button>
        </form>
      </div>
    </div>

    <div class="contact-map" aria-label={`Карта района: ${company.office.addressDisplayRu}`}>
      <svg class="contact-map__drawing" viewBox="0 0 1600 420" preserveAspectRatio="none" aria-hidden="true">
        <path d="M-80 74 C 180 112 300 34 520 82 S 860 148 1680 76" />
        <path d="M-90 122 C 190 92 348 170 584 132 S 940 90 1684 144" />
        <path d="M-90 190 C 228 150 382 242 604 198 S 980 130 1680 222" />
        <path d="M-82 270 C 188 220 424 306 666 258 S 1048 218 1682 278" />
        <path d="M-70 338 C 184 278 440 384 704 312 S 1108 266 1680 344" />
        <path d="M126 -30 C 178 86 142 238 246 450" />
        <path d="M294 -30 C 322 104 270 264 374 450" />
        <path d="M456 -30 C 512 122 436 248 570 450" />
        <path d="M724 -30 C 698 116 800 252 766 450" />
        <path d="M934 -30 C 908 98 986 236 950 450" />
        <path d="M1114 -30 C 1056 98 1184 238 1130 450" />
        <path d="M1404 -30 C 1348 126 1468 250 1414 450" />
        <path d="M-90 50 L 1684 50" />
        <path d="M-90 254 L 1684 254" />
        <path d="M846 -30 L 820 450" />
      </svg>

      <p class="contact-map__coords">{company.coordinates.display}</p>

      <div class="contact-map__pin" aria-hidden="true">
        <span>ONE</span>
      </div>
      <p class="contact-map__pin-label">{company.office.streetRu}</p>

      <a class="contact-map__route" href={mapHref} target="_blank" rel="noopener noreferrer">
        <span>Построить маршрут</span>
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

<script>
  const contactForm = document.querySelector<HTMLFormElement>("[data-contact-form]");

  contactForm?.addEventListener("submit", (event) => {
    event.preventDefault();
    const button = contactForm.querySelector<HTMLButtonElement>(".contact-lead-form__submit");
    const label = contactForm.querySelector<HTMLElement>("[data-submit-label]");

    if (!button || !label) return;

    button.disabled = true;
    label.textContent = "Заявка принята";
  });
</script>

<style>
  .contact-section {
    position: relative;
    overflow: clip;
    background: #f5f3ed;
    color: #0f172a;
    scroll-margin-top: 7rem;
  }

  .contact-shell {
    width: min(100%, 1760px);
    margin: 0 auto;
    padding: clamp(76px, 7vw, 118px) clamp(20px, 4.8vw, 88px) clamp(58px, 5.6vw, 92px);
  }

  .contact-stage {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: minmax(292px, clamp(360px, 22vw, 420px)) minmax(0, 1fr);
    gap: clamp(10px, 1.8vw, 32px);
    align-items: start;
  }

  .contact-info {
    position: relative;
    z-index: 3;
    min-width: 0;
    padding-top: clamp(32px, 3.2vw, 48px);
    border-top: 1px solid rgb(15 23 42 / 0.18);
  }

  .contact-kicker,
  .contact-detail dt,
  .contact-form-head h3,
  .contact-lead-form__field span,
  .contact-privacy,
  .contact-map__coords,
  .contact-map__pin,
  .contact-map__pin-label,
  .contact-map__route {
    font-family: var(--font-mono, monospace);
    font-size: 10px;
    line-height: 1.45;
    letter-spacing: 0.17em;
    text-transform: uppercase;
  }

  .contact-kicker {
    margin: 0 0 clamp(24px, 2.4vw, 38px);
    color: #334155;
  }

  .contact-title {
    width: max-content;
    max-width: min(12.1ch, calc(100vw - 40px));
    margin: 0;
    color: #0d182b;
    font-family: var(--font-display);
    font-size: clamp(48px, 4.68vw, 84px);
    font-weight: 500;
    line-height: 0.955;
    letter-spacing: -0.024em;
    text-wrap: balance;
  }

  .contact-title-rule {
    display: block;
    width: 28px;
    height: 1px;
    margin: clamp(18px, 1.5vw, 26px) 0 clamp(24px, 2vw, 36px);
    background: #0d182b;
  }

  .contact-lede {
    max-width: 31ch;
    margin: 0 0 clamp(34px, 3.4vw, 56px);
    color: #526176;
    font-size: clamp(16px, 1.08vw, 19px);
    line-height: 1.72;
  }

  .contact-details {
    margin: 0;
    border-top: 1px solid rgb(15 23 42 / 0.115);
  }

  .contact-detail {
    display: grid;
    grid-template-columns: 70px minmax(0, 1fr);
    gap: 12px;
    padding: clamp(16px, 1.32vw, 20px) 0;
    border-bottom: 1px solid rgb(15 23 42 / 0.105);
  }

  .contact-detail dt {
    color: rgb(82 97 118 / 0.7);
  }

  .contact-detail dd {
    margin: 0;
    color: #0f172a;
    font-size: clamp(15px, 1vw, 16px);
    font-weight: 460;
    line-height: 1.55;
    overflow-wrap: anywhere;
  }

  .contact-detail a {
    color: inherit;
    text-decoration: none;
    transition: color 220ms ease;
  }

  .contact-detail a:hover {
    color: #4d36a8;
  }

  .contact-detail a:focus-visible,
  .contact-lead-form__field input:focus-visible,
  .contact-privacy input:focus-visible,
  .contact-lead-form__submit:focus-visible,
  .contact-map__route:focus-visible {
    outline: 2px solid rgb(77 54 168 / 0.45);
    outline-offset: 4px;
  }

  .contact-image {
    position: relative;
    z-index: 1;
    min-width: 0;
    height: clamp(540px, 39vw, 635px);
    min-height: 0;
    margin: 0;
    background: #e9e4db;
    overflow: hidden;
  }

  .contact-image::before {
    position: absolute;
    inset: 0 auto 0 0;
    z-index: 2;
    width: min(58%, 590px);
    content: "";
    pointer-events: none;
    background: linear-gradient(
      90deg,
      #f5f3ed 0%,
      rgb(245 243 237 / 0.96) 30%,
      rgb(245 243 237 / 0.74) 62%,
      rgb(245 243 237 / 0.24) 86%,
      rgb(245 243 237 / 0) 100%
    );
  }

  .contact-image::after {
    position: absolute;
    inset: 0;
    z-index: 2;
    content: "";
    pointer-events: none;
    background: linear-gradient(180deg, rgb(245 243 237 / 0) 72%, rgb(245 243 237 / 0.14) 100%);
  }

  .contact-image img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: 51% center;
  }

  .contact-form-panel {
    position: absolute;
    z-index: 4;
    right: clamp(28px, 5vw, 76px);
    bottom: calc(clamp(70px, 5.6vw, 90px) * -1);
    width: clamp(340px, 22.8vw, 380px);
    padding: clamp(22px, 1.65vw, 30px) clamp(18px, 1.75vw, 28px) clamp(20px, 1.55vw, 26px);
    border: 1px solid rgb(15 23 42 / 0.11);
    background: #fbf9f3;
  }

  .contact-form-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 22px;
    margin-bottom: clamp(19px, 1.55vw, 25px);
  }

  .contact-form-head h3 {
    margin: 0;
    color: #17243a;
    font-weight: 500;
  }

  .contact-form-head span {
    width: 28px;
    height: 1px;
    flex: 0 0 auto;
    background: #0d182b;
  }

  .contact-lead-form {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    column-gap: clamp(16px, 1.45vw, 22px);
    row-gap: clamp(16px, 1.35vw, 21px);
  }

  .contact-lead-form__field {
    display: flex;
    min-width: 0;
    flex-direction: column;
    gap: 8px;
  }

  .contact-lead-form__field--wide,
  .contact-privacy,
  .contact-lead-form__submit {
    grid-column: 1 / -1;
  }

  .contact-lead-form__field span {
    color: rgb(82 97 118 / 0.72);
    transition: color 220ms ease;
  }

  .contact-lead-form__field:focus-within span {
    color: #4d36a8;
  }

  .contact-lead-form__field input {
    width: 100%;
    min-height: 36px;
    padding: 8px 0 12px;
    border: 0;
    border-bottom: 1px solid rgb(15 23 42 / 0.22);
    background: transparent;
    color: #0f172a;
    font: inherit;
    font-size: 16px;
    outline: none;
    transition: border-color 220ms ease;
  }

  .contact-lead-form__field input:hover,
  .contact-lead-form__field input:focus {
    border-bottom-color: #4d36a8;
  }

  .contact-privacy {
    display: grid;
    grid-template-columns: 18px minmax(0, 1fr);
    gap: 11px;
    align-items: start;
    color: rgb(82 97 118 / 0.76);
  }

  .contact-privacy input {
    width: 17px;
    height: 17px;
    margin: 1px 0 0;
    appearance: none;
    border: 1px solid rgb(15 23 42 / 0.32);
    background: transparent;
    cursor: pointer;
  }

  .contact-privacy input:checked {
    border-color: #0d182b;
    background: #0d182b;
  }

  .contact-lead-form__submit {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    width: 100%;
    min-height: 56px;
    margin-top: clamp(2px, 0.5vw, 8px);
    padding: 0 clamp(18px, 1.9vw, 26px);
    border: 1px solid #0d182b;
    background: #0d182b;
    color: #fbf9f3;
    font-family: var(--font-mono, monospace);
    font-size: 11px;
    line-height: 1.45;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    cursor: pointer;
    transition:
      background-color 220ms ease,
      border-color 220ms ease,
      transform 220ms ease;
  }

  .contact-lead-form__submit span:last-child {
    font-size: 18px;
    transition: transform 220ms ease;
  }

  .contact-lead-form__submit:hover,
  .contact-lead-form__submit:focus-visible {
    border-color: #4d36a8;
    background: #4d36a8;
  }

  .contact-lead-form__submit:hover span:last-child,
  .contact-lead-form__submit:focus-visible span:last-child {
    transform: translateX(4px);
  }

  .contact-lead-form__submit:active {
    transform: translateY(1px);
  }

  .contact-lead-form__submit:disabled {
    cursor: default;
    opacity: 0.72;
  }

  .contact-map {
    position: relative;
    z-index: 1;
    min-height: clamp(218px, 12.5vw, 250px);
    margin-top: -1px;
    border-top: 1px solid rgb(15 23 42 / 0.1);
    border-bottom: 1px solid rgb(15 23 42 / 0.1);
    background: #eeeae2;
    overflow: hidden;
  }

  .contact-map::before,
  .contact-map::after {
    position: absolute;
    content: "";
    pointer-events: none;
  }

  .contact-map::before {
    inset: 0;
    background-image:
      linear-gradient(to right, rgb(15 23 42 / 0.045) 1px, transparent 1px),
      linear-gradient(to bottom, rgb(15 23 42 / 0.045) 1px, transparent 1px);
    background-size: 34px 34px;
  }

  .contact-map::after {
    background-image:
      linear-gradient(25deg, transparent 0 42%, rgb(15 23 42 / 0.04) 42% calc(42% + 1px), transparent calc(42% + 1px) 100%),
      linear-gradient(155deg, transparent 0 57%, rgb(77 54 168 / 0.045) 57% calc(57% + 1px), transparent calc(57% + 1px) 100%);
    background-size: 190px 100%, 230px 100%;
  }

  .contact-map::after {
    inset: clamp(14px, 1.7vw, 28px);
    border: 1px solid rgb(15 23 42 / 0.065);
  }

  .contact-map__drawing {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .contact-map__drawing path {
    fill: none;
    stroke: rgb(15 23 42 / 0.12);
    stroke-width: 1.28;
    vector-effect: non-scaling-stroke;
  }

  .contact-map__drawing path:nth-child(2n) {
    stroke: rgb(77 54 168 / 0.112);
    stroke-width: 1.45;
  }

  .contact-map__coords {
    position: absolute;
    left: clamp(26px, 4vw, 76px);
    bottom: clamp(18px, 2.35vw, 36px);
    max-width: 16ch;
    margin: 0;
    padding: 14px 18px;
    border: 1px solid rgb(15 23 42 / 0.1);
    color: rgb(82 97 118 / 0.72);
    background: rgb(251 249 243 / 0.42);
  }

  .contact-map__pin {
    position: absolute;
    left: 50%;
    top: 50%;
    display: grid;
    width: clamp(50px, 4.15vw, 66px);
    height: clamp(50px, 4.15vw, 66px);
    place-items: center;
    border: 1px solid #0d182b;
    background: #0d182b;
    color: #fbf9f3;
    transform: translate(-50%, -50%) rotate(45deg);
  }

  .contact-map__pin span {
    transform: rotate(-45deg);
  }

  .contact-map__pin::after {
    position: absolute;
    left: 50%;
    bottom: -17px;
    width: 7px;
    height: 7px;
    content: "";
    background: #0d182b;
    transform: translateX(-50%);
  }

  .contact-map__pin-label {
    position: absolute;
    left: calc(50% + clamp(46px, 4.35vw, 64px));
    top: 50%;
    max-width: 19ch;
    margin: 0;
    color: #0d182b;
    transform: translateY(-44%);
  }

  .contact-map__route {
    position: absolute;
    right: clamp(26px, 4vw, 76px);
    bottom: clamp(18px, 2.35vw, 36px);
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: 22px;
    min-width: min(286px, calc(100% - 52px));
    min-height: 52px;
    padding: 0 20px;
    border: 1px solid rgb(15 23 42 / 0.52);
    color: #0d182b;
    text-decoration: none;
    transition:
      background-color 220ms ease,
      border-color 220ms ease,
      color 220ms ease;
  }

  .contact-map__route:hover {
    border-color: #0d182b;
    background: #0d182b;
    color: #fbf9f3;
  }

  @media (max-width: 1180px) {
    .contact-stage {
      grid-template-columns: minmax(260px, 340px) minmax(0, 1fr);
      gap: clamp(8px, 2vw, 24px);
    }

    .contact-title {
      font-size: clamp(44px, 5.1vw, 68px);
    }

    .contact-form-panel {
      right: clamp(20px, 3vw, 34px);
      width: min(400px, 43vw);
    }
  }

  @media (max-width: 940px) {
    .contact-shell {
      padding-top: 68px;
    }

    .contact-stage {
      display: flex;
      flex-direction: column;
      gap: 30px;
    }

    .contact-info {
      width: min(100%, 620px);
    }

    .contact-image {
      width: 100%;
      height: auto;
      aspect-ratio: 16 / 9.8;
    }

    .contact-image::before,
    .contact-image::after {
      display: none;
    }

    .contact-form-panel {
      position: static;
      width: 100%;
      max-width: 620px;
      box-shadow: none;
    }

    .contact-map {
      min-height: 248px;
      margin-top: 30px;
    }
  }

  @media (max-width: 620px) {
    .contact-shell {
      padding: 58px 18px 68px;
    }

    .contact-info {
      padding-top: 24px;
    }

    .contact-kicker {
      margin-bottom: 22px;
    }

    .contact-title {
      width: auto;
      max-width: 10.8ch;
      font-size: clamp(38px, 10.6vw, 49px);
      line-height: 0.99;
      letter-spacing: -0.018em;
    }

    .contact-lede {
      max-width: 27ch;
      margin-bottom: 30px;
      font-size: 16px;
      line-height: 1.62;
    }

    .contact-detail {
      grid-template-columns: 1fr;
      gap: 7px;
      padding: 16px 0;
    }

    .contact-image {
      aspect-ratio: 16 / 10;
    }

    .contact-form-panel {
      padding: 28px 20px 24px;
    }

    .contact-form-head {
      margin-bottom: 26px;
    }

    .contact-lead-form {
      grid-template-columns: 1fr;
      row-gap: 22px;
    }

    .contact-lead-form__submit {
      min-height: 58px;
      padding-inline: 18px;
      font-size: 10px;
    }

    .contact-map {
      min-height: 232px;
    }

    .contact-map__coords {
      left: 18px;
      top: 20px;
      bottom: auto;
      padding: 14px 16px;
    }

    .contact-map__pin {
      left: 58%;
      top: 43%;
      width: 48px;
      height: 48px;
    }

    .contact-map__pin-label {
      left: 18px;
      top: 59%;
      max-width: 20ch;
      transform: none;
    }

    .contact-map__route {
      left: 18px;
      right: 18px;
      bottom: 20px;
      width: auto;
      min-width: 0;
      min-height: 52px;
      padding-inline: 16px;
    }
  }
</style>
