---
/**
 * HomeContact — premium light brutalist conversion section.
 * Left: editorial intro + scannable contact rows + blueprint locator.
 * Right: framed paper-card form with elevated dark submit.
 */
import ContactForm from "@modules/ContactForm.tsx";
import { company } from "@data/company";
---

<section id="contact" class="contact-section oc-chapter oc-chapter--contact" aria-label="Свяжитесь с One Construction">
  <div class="contact-stitch stitch-commercial-to-contact" aria-hidden="true"></div>

  <div class="contact-shell">
    <aside class="contact-info" data-reveal>
      <p class="contact-kicker mono-detail text-slate-500">ОФИС · БИШКЕК</p>
      <h2 class="contact-title display uppercase text-slate-900">
        Оставьте заявку<span>.</span>
      </h2>
      <div class="contact-rule" aria-hidden="true"></div>
      <p class="contact-lede">
        И наш менеджер свяжется с вами в течении 15 минут!
      </p>

      <dl class="contact-rows">
        <div class="contact-row">
          <dt>
            <span class="contact-row__num">01</span>
            <span class="contact-row__label">Телефон</span>
          </dt>
          <dd>
            <a class="contact-row__primary" href={company.phones[0].href}>
              {company.phones[0].display}
            </a>
          </dd>
        </div>

        <div class="contact-row">
          <dt>
            <span class="contact-row__num">02</span>
            <span class="contact-row__label">E-mail</span>
          </dt>
          <dd>
            <a class="contact-row__secondary" href={company.email.href}>
              {company.email.display}
            </a>
          </dd>
        </div>

        <div class="contact-row">
          <dt>
            <span class="contact-row__num">03</span>
            <span class="contact-row__label">Офис</span>
          </dt>
          <dd>
            <p class="contact-row__secondary">{company.office.addressDisplayRu}</p>
            <p class="contact-row__hint">
              {company.hours.display} · {company.hours.sunday}
            </p>
          </dd>
        </div>

        <div class="contact-row">
          <dt>
            <span class="contact-row__num">04</span>
            <span class="contact-row__label">Координаты</span>
          </dt>
          <dd>
            <p class="contact-row__secondary contact-row__secondary--mono">
              {company.coordinates.display}
            </p>
          </dd>
        </div>
      </dl>

      <div class="contact-socials" aria-label="Каналы связи">
        {company.socialLinks.map((link) => (
          <a
            class="contact-social"
            href={link.href}
            target={link.external ? "_blank" : undefined}
            rel={link.external ? "noopener noreferrer" : undefined}
            aria-label={link.name}
          >
            <span>{link.label}</span>
            <span aria-hidden="true">↗</span>
          </a>
        ))}
      </div>

      <figure class="contact-map" aria-hidden="true">
        <svg class="contact-map__grid" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" preserveAspectRatio="none">
          <defs>
            <pattern id="contact-bp-grid" width="24" height="24" patternUnits="userSpaceOnUse">
              <path d="M 24 0 L 0 0 0 24" fill="none" stroke="#1e293b" stroke-width="0.5"/>
            </pattern>
          </defs>
          <rect width="100" height="100" fill="url(#contact-bp-grid)"/>
          <path d="M 0 38 H 100 M 0 76 H 100 M 32 0 V 100 M 64 0 V 100"
                fill="none" stroke="#334155" stroke-width="0.6" stroke-dasharray="4 6"/>
        </svg>
        <span class="contact-map__corner contact-map__corner--tl" aria-hidden="true"></span>
        <span class="contact-map__corner contact-map__corner--tr" aria-hidden="true"></span>
        <span class="contact-map__corner contact-map__corner--bl" aria-hidden="true"></span>
        <span class="contact-map__corner contact-map__corner--br" aria-hidden="true"></span>
        <div class="contact-map__pin">
          <span class="contact-map__pin-dot" aria-hidden="true"></span>
          <span class="contact-map__pin-label">{company.office.streetRu}</span>
        </div>
        <div class="contact-map__meta">
          <span>{company.coordinates.display}</span>
          <span>500 М</span>
        </div>
      </figure>
    </aside>

    <div class="contact-form-wrap" data-reveal>
      <div class="contact-form-card">
        <span class="contact-form-card__corner contact-form-card__corner--tl" aria-hidden="true"></span>
        <span class="contact-form-card__corner contact-form-card__corner--tr" aria-hidden="true"></span>
        <span class="contact-form-card__corner contact-form-card__corner--bl" aria-hidden="true"></span>
        <span class="contact-form-card__corner contact-form-card__corner--br" aria-hidden="true"></span>

        <header class="contact-form-card__head">
          <span class="contact-form-card__eyebrow">ОСТАВЬТЕ ЗАЯВКУ</span>
          <span class="contact-form-card__index">07/F</span>
        </header>

        <h3 class="contact-form-card__title">
          Оставьте заявку
        </h3>
        <p class="contact-form-card__subtitle">
          И наш менеджер свяжется с вами в течении 15 минут!
        </p>
        <div class="contact-form-card__rule" aria-hidden="true"></div>

        <ContactForm client:visible />

        <footer class="contact-form-card__foot">
          <span aria-hidden="true">↳</span>
          <span>Я соглашаюсь с политикой в отношении обработки персональных данных</span>
        </footer>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-section {
    position: relative; overflow: hidden;
    border-top: 1px solid rgb(15 23 42 / 0.1);
    background:
      linear-gradient(90deg, rgb(15 23 42 / 0.016) 1px, transparent 1px) 50% 0 / min(30vw, 420px) 100%,
      radial-gradient(circle at 84% 8%, rgb(148 163 184 / 0.13), transparent 28%),
      linear-gradient(180deg, #f5f3ed 0%, #f1eee7 100%);
    scroll-margin-top: 7rem;
  }

  .contact-section::before {
    position: absolute; inset: 0; pointer-events: none; content: "";
    background:
      linear-gradient(180deg, rgb(255 255 252 / 0.42), transparent 36%, rgb(15 23 42 / 0.016)),
      linear-gradient(135deg, transparent 0 78%, rgb(15 23 42 / 0.04) 78.08% 78.16%, transparent 78.24%);
  }

  .contact-stitch {
    position: absolute; left: 0; right: 0; top: 0; height: 96px;
    pointer-events: none; z-index: 0;
    background: linear-gradient(180deg, #F8F6F0 0%, #F5F3ED 100%);
  }

  .contact-shell {
    position: relative; z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 0.94fr) minmax(480px, 1.06fr);
    align-items: start;
    gap: clamp(34px, 4.4vw, 70px);
    max-width: 1500px; margin: 0 auto;
    padding: clamp(78px, 8vw, 118px) clamp(22px, 5vw, 88px) clamp(58px, 6.2vw, 92px);
  }

  /* ── INFO ──────────────────────────────────────────────── */
  .contact-info {
    position: relative; min-width: 0; display: flex; flex-direction: column;
    padding-left: clamp(18px, 2.1vw, 34px);
  }

  .contact-info::before {
    position: absolute; left: 0; top: 2px; bottom: 0; width: 1px; content: "";
    background: linear-gradient(180deg, rgb(15 23 42 / 0.14), rgb(15 23 42 / 0.055) 42%, transparent);
  }

  .contact-kicker {
    margin: 0 0 clamp(18px, 2vw, 26px); color: #64748b;
    font-family: var(--font-mono, monospace);
    font-size: 10px; font-weight: 400; line-height: 1.4;
    letter-spacing: 0.18em; text-transform: uppercase;
  }

  .contact-title {
    max-width: 11ch; margin: 0; color: #0f172a;
    font-family: var(--font-display);
    font-size: clamp(44px, 4.4vw, 72px); font-weight: 500; line-height: 0.92;
    letter-spacing: -0.04em;
  }
  .contact-title span { color: #6d28d9; }

  .contact-rule {
    position: relative; width: min(100%, 320px); height: 1px;
    margin: clamp(20px, 2.1vw, 28px) 0 clamp(18px, 1.8vw, 22px);
    background: rgb(15 23 42 / 0.22);
  }
  .contact-rule::after {
    position: absolute; right: -8px; top: -8px; color: rgb(91 59 196 / 0.74); content: "+";
    font-family: var(--font-mono, monospace);
    font-size: 16px; line-height: 1;
  }

  .contact-lede {
    max-width: 38ch; margin: 0 0 clamp(24px, 2.8vw, 36px);
    color: #475569;
    font-size: clamp(16px, 1.18vw, 19px);
    line-height: 1.625;
  }

  .contact-rows {
    display: grid; gap: 0; margin: 0 0 clamp(22px, 2.5vw, 30px);
    padding-left: clamp(14px, 1.4vw, 22px);
    border-top: 1px solid rgb(15 23 42 / 0.13);
    background: transparent;
  }

  .contact-row {
    display: grid;
    grid-template-columns: minmax(122px, 0.28fr) minmax(260px, 1fr);
    column-gap: clamp(14px, 1.6vw, 24px);
    row-gap: 7px;
    padding: clamp(16px, 1.5vw, 20px) clamp(10px, 1.2vw, 16px) clamp(16px, 1.5vw, 20px) 0;
    border-bottom: 1px solid rgb(15 23 42 / 0.13);
  }

  .contact-row dt {
    display: grid; align-items: baseline;
    grid-template-columns: 32px minmax(0, 1fr);
    column-gap: 10px;
    color: #334155;
    font-family: var(--font-mono, monospace);
    font-size: 10px; font-weight: 400; line-height: 1.4;
    letter-spacing: 0.16em; text-transform: uppercase;
  }
  .contact-row__num {
    color: rgb(91 59 196 / 0.66);
    font-weight: 400;
  }
  .contact-row__label { min-width: 0; }
  .contact-row dd { margin: 0; min-width: 0; display: flex; flex-direction: column; gap: 6px; }

  .contact-row__primary {
    display: inline-block; max-width: 100%;
    color: #0f172a;
    font-family: var(--font-mono, monospace);
    font-size: clamp(22px, 1.78vw, 28px); font-weight: 500;
    letter-spacing: -0.035em; text-decoration: none;
    transition: color 260ms cubic-bezier(0.16, 1, 0.3, 1);
    overflow-wrap: anywhere;
    white-space: nowrap;
  }
  .contact-row__primary:hover { color: #6d28d9; }

  .contact-row__secondary {
    margin: 0; color: #475569;
    font-size: clamp(15px, 1.05vw, 17px); line-height: 1.625; text-decoration: none;
    overflow-wrap: anywhere;
    transition: color 260ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  a.contact-row__secondary:hover { color: #6d28d9; }
  .contact-row__secondary--mono {
    font-family: var(--font-mono, monospace); letter-spacing: 0.02em;
  }
  .contact-row__hint {
    margin: 0;
    color: #64748b;
    font-family: var(--font-mono, monospace);
    font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;
  }

  /* ── SOCIALS ──────────────────────────────────────────── */
  .contact-socials {
    display: flex; flex-wrap: wrap; gap: 10px;
    margin: 0 0 clamp(22px, 2.5vw, 32px);
  }
  .contact-social {
    display: inline-flex; align-items: center; justify-content: space-between; gap: 12px;
    min-height: 44px;
    min-width: 78px;
    padding: 12px 16px;
    border: 1px solid rgb(15 23 42 / 0.22);
    background: rgb(255 255 252 / 0.86);
    color: #0f172a;
    font-family: var(--font-mono, monospace);
    font-size: 11px; font-weight: 400;
    letter-spacing: 0.16em; text-transform: uppercase;
    text-decoration: none;
    box-shadow: 0 1px 0 rgb(255 255 252 / 0.82) inset;
    transition: border-color 260ms cubic-bezier(0.16, 1, 0.3, 1), color 260ms cubic-bezier(0.16, 1, 0.3, 1), transform 260ms cubic-bezier(0.16, 1, 0.3, 1), background-color 260ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .contact-social span:last-child { color: rgb(91 59 196 / 0.9); font-size: 14px; line-height: 0.8; }
  .contact-social:hover {
    border-color: rgb(109 40 217 / 0.55);
    background: #FBFBFA;
    transform: translateY(-2px);
  }
  .contact-social:focus-visible {
    outline: 2px solid rgb(109 40 217 / 0.5);
    outline-offset: 3px;
  }

  /* ── MAP ──────────────────────────────────────────────── */
  .contact-map {
    position: relative; margin: 0; aspect-ratio: 16 / 6.2;
    border: 1px solid rgb(15 23 42 / 0.16);
    background:
      linear-gradient(90deg, rgb(109 40 217 / 0.07) 0 1px, transparent 1px 100%),
      linear-gradient(180deg, rgb(255 255 252 / 0.85), rgb(245 244 240 / 0.9)),
      #FBFBFA;
    overflow: hidden;
    box-shadow: 0 1px 0 rgb(255 255 252 / 0.72) inset;
  }
  .contact-map::after {
    position: absolute; inset: 12px; content: ""; pointer-events: none;
    border: 1px solid rgb(15 23 42 / 0.07);
  }
  .contact-map__grid { position: absolute; inset: 0; width: 100%; height: 100%; opacity: 0.12; }

  .contact-map__corner {
    position: absolute; width: 12px; height: 12px; pointer-events: none;
  }
  .contact-map__corner--tl { top: 8px; left: 8px; border-top: 1px solid rgb(15 23 42 / 0.24); border-left: 1px solid rgb(15 23 42 / 0.24); }
  .contact-map__corner--tr { top: 8px; right: 8px; border-top: 1px solid rgb(15 23 42 / 0.24); border-right: 1px solid rgb(15 23 42 / 0.24); }
  .contact-map__corner--bl { bottom: 8px; left: 8px; border-bottom: 1px solid rgb(15 23 42 / 0.24); border-left: 1px solid rgb(15 23 42 / 0.24); }
  .contact-map__corner--br { bottom: 8px; right: 8px; border-bottom: 1px solid rgb(15 23 42 / 0.24); border-right: 1px solid rgb(15 23 42 / 0.24); }

  .contact-map__pin {
    position: absolute; left: 56%; top: 46%;
    transform: translate(-50%, -50%);
    display: flex; flex-direction: column; align-items: center; gap: 8px;
  }
  .contact-map__pin-dot {
    width: 12px; height: 12px;
    border: 1px solid #6d28d9; background: #FBFBFA;
    transform: rotate(45deg);
    box-shadow: 0 0 0 3px rgb(109 40 217 / 0.1);
  }
  .contact-map__pin-label {
    color: #5b3bc4;
    font-family: var(--font-mono, monospace);
    font-size: 11px; font-weight: 400;
    letter-spacing: 0.16em; text-transform: uppercase;
    white-space: nowrap;
  }
  .contact-map__meta {
    position: absolute; left: 12px; right: 12px; bottom: 14px;
    display: flex; justify-content: space-between; gap: 10px;
    color: #64748b;
    font-family: var(--font-mono, monospace);
    font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase;
  }

  /* ── FORM CARD ────────────────────────────────────────── */
  .contact-form-wrap {
    position: relative; min-width: 0;
    padding: clamp(10px, 1.2vw, 16px) 0 clamp(10px, 1.2vw, 16px) clamp(14px, 1.5vw, 22px);
  }

  .contact-form-wrap::before {
    position: absolute; left: 0; top: 0; bottom: 0; width: 1px; content: "";
    background: linear-gradient(180deg, rgb(15 23 42 / 0.18), rgb(109 40 217 / 0.2) 36%, rgb(15 23 42 / 0.06) 72%, transparent);
  }

  .contact-form-card {
    position: relative; display: flex; flex-direction: column;
    min-height: clamp(620px, 48vw, 700px);
    padding: clamp(28px, 3vw, 44px);
    border: 1px solid rgb(15 23 42 / 0.17);
    border-top-color: rgb(15 23 42 / 0.24);
    background:
      linear-gradient(90deg, rgb(15 23 42 / 0.022) 1px, transparent 1px) 0 0 / 72px 100%,
      linear-gradient(180deg, rgb(255 255 252 / 0.9), rgb(245 244 240 / 0.9)),
      #FBFBFA;
    box-shadow:
      0 22px 54px rgb(15 23 42 / 0.08),
      0 1px 0 rgb(255 255 252 / 0.86) inset,
      0 -1px 0 rgb(15 23 42 / 0.05) inset;
  }

  .contact-form-card__corner {
    position: absolute; width: 14px; height: 14px; pointer-events: none;
  }
  .contact-form-card__corner--tl { top: 9px; left: 9px; border-top: 1px solid rgb(15 23 42 / 0.22); border-left: 1px solid rgb(15 23 42 / 0.22); }
  .contact-form-card__corner--tr { top: 9px; right: 9px; border-top: 1px solid rgb(15 23 42 / 0.18); border-right: 1px solid rgb(15 23 42 / 0.18); }
  .contact-form-card__corner--bl { bottom: -1px; left: -1px; border-bottom: 1px solid rgb(15 23 42 / 0.22); border-left: 1px solid rgb(15 23 42 / 0.22); }
  .contact-form-card__corner--br { bottom: -1px; right: -1px; border-bottom: 1px solid rgb(91 59 196 / 0.62); border-right: 1px solid rgb(91 59 196 / 0.62); }

  .contact-form-card__head {
    display: flex; align-items: center; justify-content: space-between;
    gap: 16px;
    color: #64748b;
    font-family: var(--font-mono, monospace);
    font-size: 10px; font-weight: 400;
    letter-spacing: 0.18em; text-transform: uppercase;
  }
  .contact-form-card__index { color: #64748b; }

  .contact-form-card__title {
    max-width: 22ch; margin: clamp(20px, 2vw, 28px) 0 0; color: #0f172a;
    font-family: var(--font-display);
    font-size: clamp(26px, 2.28vw, 37px); font-weight: 500;
    line-height: 0.98; letter-spacing: -0.04em;
  }

  .contact-form-card__subtitle {
    max-width: 38ch; margin: 14px 0 0;
    color: #475569;
    font-size: clamp(15px, 1.05vw, 17px);
    line-height: 1.625;
  }

  .contact-form-card__rule {
    height: 1px;
    margin: clamp(22px, 2.2vw, 30px) 0 clamp(22px, 2.4vw, 30px);
    background: linear-gradient(90deg, rgb(15 23 42 / 0.2), rgb(15 23 42 / 0.07));
  }

  .contact-form-card :global(form) { gap: clamp(20px, 2vw, 26px); }
  .contact-form-card :global(form > div:first-child) { gap: clamp(18px, 2vw, 26px); }
  .contact-form-card :global(label) { gap: 10px; }
  .contact-form-card :global(input) {
    min-height: 52px;
    border-bottom-color: rgb(15 23 42 / 0.22);
  }
  .contact-form-card :global(input:focus) {
    border-bottom-color: #5b21b6;
    box-shadow: 0 1px 0 0 rgb(91 33 182 / 0.72);
  }
  .contact-form-card :global(button[type="submit"]) {
    min-height: 60px;
    padding-inline: clamp(20px, 2vw, 28px);
    border-color: #151a24;
    background: #151a24;
    box-shadow: 0 18px 38px rgb(15 23 42 / 0.2);
  }
  .contact-form-card :global(button[type="submit"]:hover) {
    border-color: #111827;
    background: #111827;
    box-shadow: 0 20px 42px rgb(15 23 42 / 0.2);
  }
  .contact-form-card :global(form > div:last-child > p) {
    display: none;
  }

  .contact-form-card__foot {
    display: flex; align-items: flex-start; gap: 10px;
    margin-top: clamp(20px, 2vw, 28px);
    padding-top: clamp(18px, 1.8vw, 22px);
    border-top: 1px dashed rgb(15 23 42 / 0.16);
    color: #64748b;
    font-family: var(--font-mono, monospace);
    font-size: 11px; line-height: 1.5;
    letter-spacing: 0.14em; text-transform: uppercase;
  }
  .contact-form-card__foot span:first-child { color: #6d28d9; font-size: 14px; line-height: 1; }

  /* ── MOBILE ───────────────────────────────────────────── */
  @media (max-width: 900px) {
    .contact-shell {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .contact-form-wrap { padding: 0; }
    .contact-form-wrap::before { display: none; }
  }

  @media (max-width: 640px) {
    .contact-shell { padding: 58px 20px 60px; gap: 38px; }
    .contact-info { padding-left: 0; }
    .contact-info::before { display: none; }

    .contact-title { max-width: none; font-size: clamp(38px, 11vw, 48px); line-height: 0.94; }
    .contact-rule { margin: 22px 0 20px; }
    .contact-lede { font-size: 16px; line-height: 1.625; }

    .contact-row {
      grid-template-columns: 1fr;
      gap: 8px;
      padding: 16px 0;
    }
    .contact-rows { padding-left: 14px; }
    .contact-row dt { grid-template-columns: 34px minmax(0, 1fr); column-gap: 10px; }
    .contact-row__primary { font-size: 22px; white-space: normal; }
    .contact-row__secondary { font-size: 15px; }

    .contact-socials { gap: 8px; }
    .contact-social { flex: 1 1 0; min-width: 0; padding: 11px 12px; font-size: 11px; }

    .contact-map { aspect-ratio: 16 / 8.4; }
    .contact-map__pin-label { font-size: 10px; }

    .contact-form-card { min-height: 0; padding: 22px; }
    .contact-form-card__title { font-size: 20px; }
    .contact-form-card :global(form > div:first-child) { grid-template-columns: 1fr; }
    .contact-form-card :global(button[type="submit"]) { min-height: 56px; padding-inline: 18px; }
  }
</style>
