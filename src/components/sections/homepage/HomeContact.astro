---
/**
 * HomeContact — секция связи: реквизиты + форма обратной связи.
 *
 * Композиция: 12-col grid. Слева (5col) — крупный заголовок и
 * контакты живыми ссылками (тел, e-mail, адрес). Справа (7col) —
 * ContactForm (React island, client:visible).
 */
import ContactForm from "@modules/ContactForm.tsx";
---

<section
  id="contact"
  class="relative bg-ink-950 px-6 md:px-10 pt-32 md:pt-44 pb-40 md:pb-56 scroll-mt-28"
>
  <header class="flex items-end justify-between mb-16 md:mb-24 pb-4 border-b-[0.5px] border-white/10">
    <span class="mono-detail">КОНТАКТЫ · 04</span>
    <span class="mono-detail">PRIVATE LINE</span>
  </header>

  <div class="grid grid-cols-12 gap-8 md:gap-10">
    <div class="col-span-12 md:col-span-5 flex flex-col gap-10">
      <h2 class="display text-4xl md:text-6xl leading-[0.92] tracking-tighter text-ink-100 max-w-[14ch]">
        Поговорим о вашей квартире.
      </h2>

      <dl class="flex flex-col gap-8">
        <div class="flex flex-col gap-2 border-t-[0.5px] border-white/10 pt-5">
          <dt class="mono-detail">ТЕЛЕФОН</dt>
          <dd>
            <a
              href="tel:+996700123456"
              class="font-mono text-2xl md:text-3xl tracking-tight text-ink-100 transition-colors duration-300 hover:text-cobalt-400"
            >
              +996 700 123 456
            </a>
          </dd>
        </div>

        <div class="flex flex-col gap-2 border-t-[0.5px] border-white/10 pt-5">
          <dt class="mono-detail">E-MAIL</dt>
          <dd>
            <a
              href="mailto:hello@oneconstruction.kg"
              class="font-mono text-base md:text-lg text-ink-100 transition-colors duration-300 hover:text-cobalt-400 break-all"
            >
              hello@oneconstruction.kg
            </a>
          </dd>
        </div>

        <div class="flex flex-col gap-2 border-t-[0.5px] border-white/10 pt-5">
          <dt class="mono-detail">ОФИС</dt>
          <dd class="font-mono text-sm text-ink-200 leading-relaxed">
            БИШКЕК, ПР. ЧУЙ 219, 4 ЭТАЖ<br />
            ПН — СБ · 10:00 — 19:00
          </dd>
        </div>
      </dl>
    </div>

    <div class="col-span-12 md:col-span-7 md:pl-10">
      <ContactForm client:visible />
    </div>
  </div>
</section>
