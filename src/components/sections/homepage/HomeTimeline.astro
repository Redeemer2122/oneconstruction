---
import { privileges } from "@data/privileges";

const privilegeMedia = {
  "01": {
    src: "/img/privileges/facade.jpg",
    alt: "Фрагмент современного фасада с остеклением",
  },
  "02": {
    src: "/img/privileges/quiet-lobby.jpg",
    alt: "Тихое современное лобби с мягким светом",
  },
  "03": {
    src: "/img/privileges/plan.jpg",
    alt: "Фрагмент архитектурной планировки",
  },
  "04": {
    src: "/img/privileges/water.jpg",
    alt: "Фактура чистой воды",
  },
  "05": {
    src: "/img/privileges/green-facade.jpg",
    alt: "Фасад с озелененными балконами",
  },
  "06": {
    src: "/img/privileges/entrance.jpg",
    alt: "Современная входная группа жилого комплекса",
  },
  "07": {
    src: "/img/privileges/courtyard-water.jpg",
    alt: "Современный двор с водой и архитектурной фактурой",
  },
} as const;
---

<section id="privileges" class="privileges-section oc-chapter oc-chapter--technical" aria-label="Стандарт преимуществ One Construction">
  <div class="section-stitch-top stitch-bone-to-technical" aria-hidden="true"></div>

  <div class="privileges-frame">
    <aside class="privileges-intro" aria-labelledby="privileges-title">
      <div class="privileges-intro__meta">
        <span>02</span>
        <i aria-hidden="true"></i>
        <span>Преимущества</span>
      </div>

      <div class="privileges-intro__copy">
        <h2 id="privileges-title" class="display">
          <span>СТАНДАРТ</span>
          <span>ПРЕИМУЩЕСТВ</span>
          <span>ONE CONSTRUCTION.</span>
        </h2>

        <div class="privileges-intro__text">
          <p>
            Каждый наш жилой комплекс создан с учётом 7 ключевых стандартов
            качества, которые делают жизнь комфортной, безопасной и вдохновляющей.
          </p>
          <p>
            Мы заботимся о вашем здоровье, удобстве и эмоциях с первых минут
            проживания.
          </p>
        </div>
      </div>

      <div class="privileges-system">
        <span class="privileges-system__rule" aria-hidden="true"></span>
        <strong>01 <small>/ 07</small></strong>
        <span>Система преимуществ</span>
      </div>
    </aside>

    <div class="privileges-board" aria-label="Семь стандартов преимуществ">
      <ol class="privileges-wall">
        {
          privileges.map((item) => {
            const media = privilegeMedia[item.index as keyof typeof privilegeMedia];

            return (
              <li class:list={["standard-cell", `standard-cell--${item.index}`]}>
                <div class="standard-cell__content">
                  <span class="standard-cell__index">{item.index}</span>
                  <div>
                    <h3 class="display">{item.title}</h3>
                    <p>{item.body}</p>
                  </div>
                </div>

                {media && (
                  <figure class="standard-cell__media" aria-hidden="true">
                    <img src={media.src} alt={media.alt} loading="lazy" decoding="async" />
                  </figure>
                )}

                <span class="standard-cell__arrow" aria-hidden="true">↗</span>
              </li>
            );
          })
        }
      </ol>
    </div>
  </div>
</section>

<style>
  .privileges-section {
    --priv-bg: #f4f5f1;
    --priv-panel: #fbfaf6;
    --priv-panel-soft: #f3f1eb;
    --priv-ink: #111827;
    --priv-muted: #485466;
    --priv-quiet: #788292;
    --priv-line: rgba(17, 24, 39, 0.13);
    --priv-line-soft: rgba(17, 24, 39, 0.075);
    --priv-violet: #5d3ac4;
    position: relative;
    overflow: hidden;
    background:
      linear-gradient(90deg, rgba(17, 24, 39, 0.008) 1px, transparent 1px) 0 0 / 8.5rem 8.5rem,
      linear-gradient(180deg, rgba(17, 24, 39, 0.007) 1px, transparent 1px) 0 0 / 8.5rem 8.5rem,
      var(--priv-bg);
    color: var(--priv-ink);
    border-top: 1px solid var(--priv-line-soft);
  }

  .privileges-frame {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(27rem, 0.38fr) minmax(0, 0.62fr);
    column-gap: clamp(0.75rem, 1.2vw, 1.35rem);
    width: 100%;
    margin-inline: auto;
    padding: clamp(6.1rem, 7.25vw, 8.8rem) clamp(1rem, 2.2vw, 2.75rem) clamp(6.45rem, 7.8vw, 9.25rem);
  }

  .privileges-intro,
  .privileges-board {
    background:
      linear-gradient(135deg, rgba(251, 251, 250, 0.94), rgba(242, 240, 234, 0.72)),
      var(--priv-panel);
    border: 1px solid var(--priv-line-soft);
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.82) inset;
  }

  .privileges-intro {
    position: relative;
    display: grid;
    grid-template-rows: auto 1fr auto;
    min-width: 0;
    min-height: clamp(55rem, 63vw, 67rem);
    padding: clamp(3rem, 4.05vw, 4.95rem) clamp(1.9rem, 2.65vw, 3.45rem);
    border-right: 1px solid var(--priv-line-soft);
    overflow: hidden;
  }

  .privileges-intro::before {
    position: absolute;
    right: clamp(1.55rem, 2.45vw, 3rem);
    bottom: clamp(4.7rem, 6.3vw, 6.8rem);
    width: min(58%, 22.5rem);
    aspect-ratio: 1.62;
    content: "";
    background:
      linear-gradient(rgba(17, 24, 39, 0.09), rgba(17, 24, 39, 0.09)) 0 100% / 100% 1px no-repeat,
      linear-gradient(90deg, rgba(17, 24, 39, 0.085) 1px, transparent 1px) 0 0 / 33.333% 100%,
      linear-gradient(180deg, rgba(17, 24, 39, 0.07) 1px, transparent 1px) 0 0 / 100% 33.333%,
      linear-gradient(135deg, transparent 49.5%, rgba(93, 58, 196, 0.12) 50%, transparent 50.5%);
    opacity: 0.28;
    pointer-events: none;
  }

  .privileges-intro::after {
    position: absolute;
    left: clamp(1.9rem, 2.65vw, 3.45rem);
    right: clamp(1.9rem, 2.65vw, 3.45rem);
    bottom: clamp(2.95rem, 4vw, 4.5rem);
    height: 1px;
    content: "";
    background: linear-gradient(90deg, rgba(93, 58, 196, 0.32), rgba(17, 24, 39, 0.08) 44%, transparent);
    opacity: 0.64;
    pointer-events: none;
  }

  .privileges-intro__meta,
  .privileges-system,
  .standard-cell__index {
    font-family: var(--font-mono, "Geist Mono", monospace);
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  .privileges-intro__meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: #707a88;
    font-size: clamp(0.68rem, 0.7vw, 0.78rem);
    font-weight: 600;
  }

  .privileges-intro__meta i {
    width: 2.7rem;
    height: 1px;
    background: color-mix(in srgb, var(--priv-violet) 38%, var(--priv-line));
  }

  .privileges-intro__copy {
    align-self: start;
    margin-top: clamp(4.15rem, 5.7vw, 6.35rem);
  }

  .privileges-intro h2 {
    max-width: 100%;
    margin: 0;
    font-size: clamp(2.8rem, 3.08vw, 4.55rem);
    font-weight: 500;
    line-height: 0.94;
    letter-spacing: -0.024em;
    text-transform: uppercase;
  }

  .privileges-intro h2 span {
    display: block;
    white-space: nowrap;
  }

  .privileges-intro__text {
    display: grid;
    gap: 1.05rem;
    max-width: 30rem;
    margin-top: clamp(2.45rem, 3.25vw, 3.7rem);
    padding-top: clamp(1.6rem, 2.15vw, 2.35rem);
    border-top: 1px solid rgba(17, 24, 39, 0.12);
  }

  .privileges-intro__text p {
    margin: 0;
    color: color-mix(in srgb, var(--priv-muted) 88%, var(--priv-ink));
    font-size: clamp(1.02rem, 1.08vw, 1.16rem);
    line-height: 1.74;
  }

  .privileges-system {
    align-self: end;
    display: grid;
    gap: 0.92rem;
    width: min(100%, 18.5rem);
    margin-top: clamp(5.25rem, 8vw, 9rem);
    color: var(--priv-quiet);
    font-size: clamp(0.66rem, 0.7vw, 0.76rem);
    font-weight: 600;
  }

  .privileges-system__rule {
    width: 5.4rem;
    height: 1px;
    background: color-mix(in srgb, var(--priv-violet) 42%, var(--priv-line));
  }

  .privileges-system strong {
    color: color-mix(in srgb, var(--priv-violet) 74%, #8c95a5);
    font-size: clamp(2rem, 2.42vw, 2.56rem);
    font-weight: 500;
    line-height: 1;
    letter-spacing: 0.02em;
  }

  .privileges-system small {
    color: var(--priv-quiet);
    font-size: 0.56em;
  }

  .privileges-board {
    min-width: 0;
    padding: clamp(0.78rem, 0.95vw, 1.05rem);
  }

  .privileges-wall {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    grid-template-rows:
      clamp(15.8rem, 16.75vw, 19.3rem)
      clamp(17.8rem, 18.75vw, 21.8rem)
      clamp(15.35rem, 16.25vw, 18.8rem)
      clamp(15.35rem, 16.25vw, 18.8rem);
    gap: 1px;
    margin: 0;
    padding: 0;
    list-style: none;
    background: rgba(17, 24, 39, 0.105);
    border: 1px solid rgba(17, 24, 39, 0.105);
  }

  .standard-cell {
    position: relative;
    isolation: isolate;
    min-width: 0;
    overflow: hidden;
    background:
      linear-gradient(135deg, rgba(251, 250, 246, 0.62), rgba(241, 239, 233, 0.5)),
      var(--priv-panel-soft);
    transition:
      border-color 260ms var(--ease-out-expo),
      opacity 260ms var(--ease-out-expo),
      transform 260ms var(--ease-out-expo);
  }

  .standard-cell::before {
    position: absolute;
    inset: 0;
    z-index: -1;
    content: "";
    background:
      linear-gradient(90deg, rgba(93, 58, 196, 0.055), transparent 18%),
      linear-gradient(180deg, rgba(17, 24, 39, 0.02), transparent 42%);
    opacity: 0;
    transition: opacity 260ms var(--ease-out-expo);
  }

  .standard-cell:hover {
    transform: translateY(-1px);
  }

  .standard-cell:hover::before {
    opacity: 1;
  }

  .standard-cell--01 {
    grid-column: auto;
    grid-row: 1;
  }

  .standard-cell--02 {
    grid-column: auto;
    grid-row: 1;
  }

  .standard-cell--03 {
    grid-column: 1 / -1;
    grid-row: 2;
  }

  .standard-cell--04,
  .standard-cell--05 {
    grid-column: auto;
    grid-row: 3;
  }

  .standard-cell--06 {
    grid-column: auto;
    grid-row: 4;
  }

  .standard-cell--07 {
    grid-column: auto;
    grid-row: 4;
  }

  .standard-cell__content {
    position: relative;
    z-index: 2;
    display: grid;
    box-sizing: border-box;
    gap: clamp(1rem, 1.18vw, 1.32rem);
    max-width: 25.5rem;
    padding: clamp(1.55rem, 1.95vw, 2.25rem);
  }

  .standard-cell__index {
    color: color-mix(in srgb, var(--priv-ink) 90%, var(--priv-violet));
    font-size: clamp(0.9rem, 0.94vw, 1.06rem);
    font-weight: 600;
    line-height: 1;
  }

  .standard-cell h3 {
    max-width: 18ch;
    margin: 0;
    color: var(--priv-ink);
    font-size: clamp(1.14rem, 1.24vw, 1.48rem);
    font-weight: 500;
    line-height: 1.04;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    text-wrap: balance;
  }

  .standard-cell p {
    max-width: 27ch;
    margin: 0.64rem 0 0;
    color: color-mix(in srgb, #273240 86%, #6f7785);
    font-size: clamp(0.9rem, 0.95vw, 1.04rem);
    line-height: 1.5;
  }

  .standard-cell__media {
    position: absolute;
    inset: auto 0 0 auto;
    z-index: 1;
    width: 54%;
    height: 100%;
    margin: 0;
    overflow: hidden;
    background: #e6e3da;
    opacity: 0.9;
  }

  .standard-cell__media::after {
    position: absolute;
    inset: 0;
    content: "";
    background:
      linear-gradient(90deg, rgba(244, 245, 241, 0.6), rgba(244, 245, 241, 0.16) 42%, transparent 68%),
      linear-gradient(180deg, rgba(251, 250, 246, 0.14), rgba(17, 24, 39, 0.045));
    pointer-events: none;
  }

  .standard-cell__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 50%;
    filter: saturate(0.86) contrast(1.01) brightness(1.035);
    transition:
      transform 900ms var(--ease-out-expo),
      filter 900ms var(--ease-out-expo),
      opacity 900ms var(--ease-out-expo);
  }

  .standard-cell:hover .standard-cell__media img {
    transform: scale(1.012);
    filter: saturate(0.94) contrast(1.04) brightness(1.035);
  }

  .standard-cell__arrow {
    position: absolute;
    right: 0.78rem;
    top: 0.7rem;
    z-index: 3;
    color: rgba(93, 58, 196, 0.2);
    font-family: var(--font-mono, "Geist Mono", monospace);
    font-size: 0.94rem;
    line-height: 1;
    transition:
      color 260ms var(--ease-out-expo),
      transform 260ms var(--ease-out-expo);
  }

  .standard-cell:hover .standard-cell__arrow {
    color: rgba(93, 58, 196, 0.58);
    transform: translate(2px, -2px);
  }

  .standard-cell--01 .standard-cell__content {
      max-width: min(20rem, 62%);
    min-height: 100%;
    background: linear-gradient(90deg, rgba(244, 245, 241, 0.98), rgba(244, 245, 241, 0.76) 76%, transparent);
  }

  .standard-cell--02 .standard-cell__content {
      max-width: min(21rem, 64%);
    min-height: 100%;
    background: linear-gradient(90deg, rgba(244, 245, 241, 0.98), rgba(244, 245, 241, 0.78) 74%, transparent);
  }

  .standard-cell--02 .standard-cell__media {
    width: 47%;
  }

  .standard-cell--03 .standard-cell__content {
    max-width: 31rem;
    min-height: 100%;
    background: linear-gradient(90deg, rgba(244, 245, 241, 0.98), rgba(244, 245, 241, 0.8) 74%, transparent);
  }

  .standard-cell--03 .standard-cell__media {
    width: 61%;
  }

  .standard-cell--04 .standard-cell__media,
  .standard-cell--05 .standard-cell__media {
    width: 100%;
    height: 60%;
    opacity: 0.82;
  }

  .standard-cell--04 .standard-cell__content,
  .standard-cell--05 .standard-cell__content {
    min-height: 100%;
    align-content: start;
    background: linear-gradient(180deg, rgba(244, 245, 241, 0.98), rgba(244, 245, 241, 0.9) 54%, rgba(244, 245, 241, 0.34) 78%, transparent);
  }

  .standard-cell--06 .standard-cell__media,
  .standard-cell--07 .standard-cell__media {
    width: 54%;
    height: 100%;
    opacity: 0.9;
  }

  .standard-cell--06 .standard-cell__content,
  .standard-cell--07 .standard-cell__content {
    min-height: 100%;
    max-width: min(20rem, 62%);
    align-content: start;
    background: linear-gradient(90deg, rgba(244, 245, 241, 0.98), rgba(244, 245, 241, 0.8) 74%, transparent);
  }

  .standard-cell--07 {
    background:
      linear-gradient(105deg, rgba(93, 58, 196, 0.04), transparent 22%),
      linear-gradient(135deg, rgba(251, 250, 246, 0.58), rgba(236, 234, 226, 0.46)),
      var(--priv-panel-soft);
  }

  .standard-cell--07::after {
    display: none;
  }

  .standard-cell--07 .standard-cell__media::after {
    background:
      linear-gradient(90deg, rgba(244, 245, 241, 0.66), rgba(244, 245, 241, 0.16) 42%, transparent 68%),
      linear-gradient(180deg, rgba(17, 24, 39, 0), rgba(17, 24, 39, 0.045));
  }

  .standard-cell--06 .standard-cell__media::after {
    background:
      linear-gradient(90deg, rgba(244, 245, 241, 0.64), rgba(244, 245, 241, 0.14) 42%, transparent 68%),
      linear-gradient(180deg, rgba(17, 24, 39, 0), rgba(17, 24, 39, 0.045));
  }

  .standard-cell--06 .standard-cell__media img {
    object-position: 44% 50%;
    filter: saturate(0.9) contrast(1.02) brightness(1.035);
  }

  .standard-cell--07 .standard-cell__media img {
    object-position: 38% 56%;
    filter: saturate(0.9) contrast(1.04) brightness(1.01);
  }

  @media (max-width: 1180px) {
    .privileges-frame {
      grid-template-columns: 1fr;
      width: min(100%, 980px);
    }

    .privileges-intro {
      min-height: 0;
      border-right: 1px solid var(--priv-line-soft);
      border-bottom: 0;
    }

    .privileges-intro h2 {
      max-width: 100%;
    }

    .privileges-board {
      border-top: 0;
    }

  }

  @media (max-width: 760px) {
    .privileges-section {
      background:
        linear-gradient(90deg, rgba(17, 24, 39, 0.012) 1px, transparent 1px) 0 0 / 6.25rem 6.25rem,
        linear-gradient(180deg, rgba(17, 24, 39, 0.011) 1px, transparent 1px) 0 0 / 6.25rem 6.25rem,
        var(--priv-bg);
    }

    .privileges-frame {
      padding: 3.8rem 0.95rem 4rem;
    }

    .privileges-intro,
    .privileges-board {
      box-shadow: 0 1px 0 rgba(255, 255, 255, 0.72) inset;
    }

    .privileges-intro {
      padding: 1.35rem;
      min-height: 0;
    }

    .privileges-intro::before {
      right: 1.35rem;
      bottom: 5.2rem;
      width: 44%;
      opacity: 0.18;
    }

    .privileges-intro::after {
      left: 1.35rem;
      right: 1.35rem;
      bottom: 1.35rem;
    }

    .privileges-intro__copy {
      margin-top: 1.85rem;
    }

    .privileges-intro h2 {
      max-width: 100%;
      font-size: clamp(1.78rem, 7vw, 2.18rem);
      line-height: 0.98;
      letter-spacing: -0.018em;
    }

    .privileges-intro__text {
      gap: 0.76rem;
      margin-top: 1.35rem;
      padding-top: 1.08rem;
      max-width: 28rem;
    }

    .privileges-intro__text p {
      font-size: 0.92rem;
      line-height: 1.58;
    }

    .privileges-system {
      margin-top: 2.4rem;
    }

    .privileges-board {
      padding: 0.55rem;
    }

    .privileges-wall {
      grid-template-columns: 1fr;
      grid-template-rows: none;
      grid-auto-rows: auto;
    }

    .standard-cell,
    .standard-cell--01,
    .standard-cell--02,
    .standard-cell--03,
    .standard-cell--04,
    .standard-cell--05,
    .standard-cell--06,
    .standard-cell--07 {
      grid-column: auto;
      grid-row: auto;
      min-height: 9.4rem;
    }

    .standard-cell__content,
    .standard-cell--01 .standard-cell__content,
    .standard-cell--02 .standard-cell__content,
    .standard-cell--03 .standard-cell__content,
    .standard-cell--07 .standard-cell__content {
      max-width: calc(64% - 0.25rem);
      padding: 1rem;
    }

    .standard-cell h3 {
      max-width: 18ch;
      font-size: 0.92rem;
      line-height: 1.1;
    }

    .standard-cell p {
      max-width: 25ch;
      font-size: 0.8rem;
      line-height: 1.45;
    }

    .standard-cell__media,
    .standard-cell--03 .standard-cell__media,
    .standard-cell--04 .standard-cell__media,
    .standard-cell--05 .standard-cell__media,
    .standard-cell--06 .standard-cell__media,
    .standard-cell--07 .standard-cell__media {
      width: 40%;
      height: 100%;
      opacity: 0.66;
    }

    .standard-cell--04 .standard-cell__content,
    .standard-cell--05 .standard-cell__content,
    .standard-cell--06 .standard-cell__content,
    .standard-cell--07 .standard-cell__content {
      min-height: 9.4rem;
      align-content: start;
      background: linear-gradient(90deg, rgba(244, 245, 241, 0.98), rgba(244, 245, 241, 0.82) 74%, transparent);
    }
  }
</style>
