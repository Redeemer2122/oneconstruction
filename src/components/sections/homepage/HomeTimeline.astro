---
const phases = [
  {
    index: "01",
    title: "ПРОЕКТИРОВАНИЕ",
    duration: "3–6 МЕС.",
    detail: "Архитектурная концепция, генплан, согласование с городскими службами. Полная BIM-модель объекта.",
    tags: ["АРХИТЕКТУРА", "BIM", "ГП"],
  },
  {
    index: "02",
    title: "МОНОЛИТНЫЕ РАБОТЫ",
    duration: "8–14 МЕС.",
    detail: "Свайное поле, монолитный каркас, плиты перекрытий. Марка бетона: B25–B35. Контроль качества на каждой захватке.",
    tags: ["БЕТОН B35", "АРМАТУРА A500", "ЖБК"],
  },
  {
    index: "03",
    title: "ФАСАДЫ И ИНЖЕНЕРИЯ",
    duration: "4–8 МЕС.",
    detail: "Навесные вентилируемые фасады, теплоизоляция, остекление. Параллельный монтаж инженерных систем.",
    tags: ["НВФ", "СТЕКЛО", "HVAC"],
  },
  {
    index: "04",
    title: "СДАЧА И ВВОД",
    duration: "2–3 МЕС.",
    detail: "Финишная отделка МОП, комиссия, получение разрешения на ввод, передача ключей собственникам.",
    tags: ["ПРИЁМКА", "ВВОД В ЭКСПЛУАТАЦИЮ", "КЛЮЧИ"],
  },
];
---

<section
  id="timeline"
  class="relative bg-[#FBFBFA] border-t border-slate-200 overflow-hidden"
  aria-label="Этапы строительства"
>
  <div class="px-6 md:px-10 lg:px-12 py-24 md:py-40">

    <!-- Section header -->
    <header class="flex items-baseline justify-between pb-6 mb-16 md:mb-24 border-b border-slate-200">
      <span class="mono-detail" data-reveal>ПРОЦЕСС</span>
      <span class="mono-detail" data-reveal style="--reveal-delay:0.1s;">SEC: 004 / BUILD PHASES</span>
    </header>

    <!-- Title -->
    <div class="mb-20 md:mb-32 max-w-[52ch]" data-reveal style="--reveal-delay:0.14s;">
      <h2 class="font-mono text-2xl md:text-4xl xl:text-5xl uppercase tracking-tight text-slate-900 leading-[1.1]">
        От идеи<br/>до ключей.
      </h2>
    </div>

    <!-- Timeline layout -->
    <div class="tl-root relative grid grid-cols-1 md:grid-cols-12 gap-0">

      <!-- Centre spine — the line that fills with violet -->
      <div class="hidden md:block md:col-span-1 relative">
        <div class="tl-track absolute left-1/2 -translate-x-1/2 top-0 bottom-0 w-px bg-slate-200"></div>
        <div
          class="tl-fill absolute left-1/2 -translate-x-1/2 top-0 w-px bg-[#7c3aed]"
          style="height: 0%;"
        ></div>
      </div>

      <!-- Phase cards column -->
      <div class="md:col-span-11 md:pl-10 flex flex-col gap-0">
        {phases.map((phase, idx) => (
          <article
            class="tl-card group relative grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-8 py-10 md:py-14 border-b border-slate-200"
            data-tl-index={idx}
          >
            <!-- Giant ghost index -->
            <span
              class="absolute top-6 right-0 md:-left-10 font-mono text-[80px] md:text-[110px] leading-none tracking-tighter text-slate-900/[0.04] select-none pointer-events-none"
              aria-hidden="true"
            >{phase.index}</span>

            <!-- Left: index + duration -->
            <div class="md:col-span-3 flex flex-col gap-3 justify-start pt-1">
              <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-slate-400">{phase.index}</span>
              <span class="font-mono text-[11px] uppercase tracking-[0.16em] text-slate-500">{phase.duration}</span>

              <!-- Violet dot on spine (desktop) -->
              <div class="hidden md:block absolute -left-10 top-[3.5rem] w-3 h-3 border border-slate-300 bg-[#FBFBFA] group-[.tl-active]:border-[#7c3aed] group-[.tl-active]:bg-[#7c3aed] transition-all duration-500 -translate-x-[5px]"></div>
            </div>

            <!-- Right: content -->
            <div class="md:col-span-9 flex flex-col gap-4">
              <h3 class="font-mono text-sm md:text-base uppercase tracking-[0.14em] text-slate-900 transition-colors duration-300 group-hover:text-[#7c3aed]">
                {phase.title}
              </h3>
              <p class="text-sm text-slate-600 leading-relaxed max-w-[52ch]">
                {phase.detail}
              </p>
              <div class="flex flex-wrap gap-2 mt-2">
                {phase.tags.map((tag) => (
                  <span class="font-mono text-[9px] uppercase tracking-[0.18em] text-slate-500 border border-slate-200 px-2 py-1">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>

    </div>
  </div>
</section>

<script>
  import gsap from "gsap";
  import ScrollTrigger from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const initTimeline = () => {
    const section = document.getElementById("timeline");
    if (!section) return;

    const fill   = section.querySelector<HTMLElement>(".tl-fill");
    const cards  = section.querySelectorAll<HTMLElement>(".tl-card");
    if (!fill || cards.length === 0) return;

    // Spine fill on scroll
    ScrollTrigger.create({
      trigger: section.querySelector(".tl-root"),
      start: "top 70%",
      end: "bottom 30%",
      scrub: 1.2,
      onUpdate: (self) => {
        fill.style.height = `${self.progress * 100}%`;
      },
    });

    // Cards: fly in from sides
    cards.forEach((card, i) => {
      const fromLeft = i % 2 === 0;
      gsap.set(card, { opacity: 0, x: fromLeft ? -40 : 40 });

      ScrollTrigger.create({
        trigger: card,
        start: "top 82%",
        onEnter: () => {
          gsap.to(card, {
            opacity: 1,
            x: 0,
            duration: 0.75,
            ease: "power3.out",
            delay: 0.05 * i,
          });
          card.classList.add("tl-active");
        },
        once: true,
      });
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initTimeline, { once: true });
  } else {
    initTimeline();
  }
</script>
