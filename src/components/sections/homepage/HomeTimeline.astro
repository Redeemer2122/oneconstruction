---
/**
 * HomeTimeline — переверстана под блок "Стандарт привилегий One Construction".
 * 7 пунктов, тонкие hairlines, проявление по ScrollTrigger.
 */
import { privileges } from "@data/privileges";
---

<section
  id="privileges"
  class="relative bg-[#FBFBFA] border-t border-slate-200 overflow-hidden"
  aria-label="Стандарт привилегий One Construction"
>
  <div class="px-6 md:px-10 lg:px-12 py-24 md:py-40">

    <!-- Section header -->
    <header class="flex items-baseline justify-between gap-6 pb-6 mb-16 md:mb-24 border-b border-slate-200">
      <span class="mono-detail" data-reveal>СТАНДАРТ · 03</span>
      <span class="mono-detail" data-reveal style="--reveal-delay:0.1s;">SEC: 003 / PRIVILEGES</span>
    </header>

    <!-- Title -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 mb-20 md:mb-32">
      <div class="lg:col-span-7" data-reveal style="--reveal-delay:0.14s;">
        <h2 class="font-mono text-[8vw] md:text-[5.4vw] xl:text-[4.6vw] uppercase tracking-[-0.04em] text-slate-900 leading-[0.94] max-w-[14ch]">
          Стандарт<br />привилегий<br />
          <span class="text-violet-700">One Construction.</span>
        </h2>
      </div>
      <div class="lg:col-span-5 flex flex-col gap-6 lg:pt-4" data-reveal style="--reveal-delay:0.22s;">
        <p class="text-base md:text-lg text-slate-700 leading-relaxed max-w-[48ch]">
          Семь обязательных слоёв, которые мы закладываем в каждый дом — независимо от класса, площади и квартиры.
        </p>
        <p class="text-sm md:text-base text-slate-600 leading-relaxed max-w-[48ch]">
          Это не маркетинговый список, а технический регламент: его выполняет инженерная служба и фиксирует приёмка.
        </p>
      </div>
    </div>

    <!-- Privileges list — hairline rows -->
    <ul class="priv-list border-t border-slate-200">
      {privileges.map((p, idx) => (
        <li
          class="priv-row group relative grid grid-cols-12 gap-4 md:gap-8 items-start py-8 md:py-12 border-b border-slate-200 transition-colors duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] hover:bg-bone"
          data-priv-index={idx}
        >
          <!-- Index -->
          <div class="col-span-2 md:col-span-1 flex flex-col gap-2 pt-1">
            <span class="font-mono text-[11px] md:text-[10px] uppercase tracking-[0.14em] md:tracking-[0.22em] text-slate-400 group-hover:text-violet-600 transition-colors duration-500">
              {p.index}
            </span>
            <span class="hidden md:block w-2 h-2 border border-slate-300 group-hover:border-violet-600 group-hover:bg-violet-600 transition-all duration-500"></span>
          </div>

          <!-- Title -->
          <div class="col-span-10 md:col-span-5">
            <h3 class="font-mono text-lg md:text-2xl xl:text-3xl tracking-tight text-slate-900 leading-[1.1] group-hover:text-violet-700 transition-colors duration-500">
              {p.title}
            </h3>
          </div>

          <!-- Body -->
          <div class="col-span-12 md:col-span-5">
            <p class="text-sm md:text-base text-slate-600 leading-relaxed max-w-[52ch]">
              {p.body}
            </p>
          </div>

          <!-- Tag -->
          <div class="col-span-12 md:col-span-1 md:flex md:justify-end pt-1">
            <span class="inline-block max-w-full font-mono text-[10px] md:text-[9px] uppercase tracking-[0.14em] md:tracking-[0.2em] text-slate-500 border border-slate-200 px-2 py-1 group-hover:border-violet-600 group-hover:text-violet-700 transition-colors duration-500 break-words">
              {p.tag}
            </span>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<script>
  import gsap from "gsap";
  import ScrollTrigger from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const initPrivileges = () => {
    const section = document.getElementById("privileges");
    if (!section) return;
    const rows = section.querySelectorAll<HTMLElement>(".priv-row");
    if (!rows.length) return;

    rows.forEach((row, i) => {
      gsap.set(row, { opacity: 0, y: 32 });
      ScrollTrigger.create({
        trigger: row,
        start: "top 88%",
        onEnter: () => {
          gsap.to(row, {
            opacity: 1,
            y: 0,
            duration: 0.7,
            ease: "power3.out",
            delay: 0.04 * i,
          });
        },
        once: true,
      });
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initPrivileges, { once: true });
  } else {
    initPrivileges();
  }
</script>
