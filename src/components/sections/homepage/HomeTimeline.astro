---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { privileges } from "@data/privileges";

const privilegeMedia = {
  "01": {
    src: "/img/privileges/facade.jpg",
    alt: "Современный фасад жилого комплекса с чистой архитектурной геометрией",
  },
  "02": {
    src: "/img/privileges/entrance.jpg",
    alt: "Закрытая входная группа жилого комплекса",
  },
  "03": {
    src: "/img/privileges/green-facade.jpg",
    alt: "Зеленый фасад жилого дома с естественным светом",
  },
  "04": {
    src: "/img/privileges/quiet-lobby.jpg",
    alt: "Спокойное интерьерное пространство жилого комплекса",
  },
  "05": {
    src: "/img/privileges/water.jpg",
    alt: "Чистая вода как часть инженерного стандарта дома",
  },
  "06": {
    src: "/img/privileges/plan.jpg",
    alt: "Архитектурная планировка и инженерная точность",
  },
  "07": {
    src: "/img/privileges/courtyard-water.jpg",
    alt: "Дворовая среда с водой и современной инфраструктурой",
  },
} as const;

const optimizedImageModules = import.meta.glob<ImageMetadata>(
  "../../../../public/img/**/*.{jpg,jpeg,png,webp}",
  { eager: true, import: "default" }
);
const getOptimizedImage = (src: string) => optimizedImageModules[`../../../../public${src}`];

const advantages = privileges.map((item) => ({
  ...item,
  media: privilegeMedia[item.index as keyof typeof privilegeMedia],
}));
---

<section id="privileges" class="privileges-section oc-chapter oc-chapter--technical" aria-labelledby="privileges-title">
  <div class="section-stitch-top stitch-bone-to-technical" aria-hidden="true"></div>

  <div class="privileges-shell">
    <div class="standards-board">
      <header class="standards-manifest">
        <div class="privileges-label">
          <span class="privileges-label__rule" aria-hidden="true"></span>
          <span class="mono-detail oc-section-label">ПРЕИМУЩЕСТВА / 07</span>
        </div>

        <div class="standards-heading">
          <h2 id="privileges-title" class="privileges-title display">
            <span>СТАНДАРТ</span>
            <span>ПРЕИМУЩЕСТВ</span>
            <span>ONE CONSTRUCTION.</span>
          </h2>

          <div class="privileges-lead">
            <p>
              Каждый наш жилой комплекс создан с учётом 7 ключевых стандартов
              качества, которые делают жизнь комфортной, безопасной и вдохновляющей.
            </p>
            <p>
              Мы заботимся о вашем здоровье, удобстве и эмоциях с первых минут
              проживания.
            </p>
          </div>
        </div>

        <div class="standards-notation" aria-hidden="true">
          <span class="standards-notation__rule"></span>
          <span class="standards-notation__index">01 <small>/ 07</small></span>
          <span class="mono-detail">СТАНДАРТЫ<br />КАЧЕСТВА</span>
        </div>

      </header>

      <div class="standards-strips" aria-hidden="true">
        {
          advantages.map((item, index) => {
            const optimizedMediaImage = item.media ? getOptimizedImage(item.media.src) : undefined;

            return (
              item.media && (
                <figure class="standards-strip">
                  {
                    optimizedMediaImage ? (
                      <Image
                        src={optimizedMediaImage}
                        format="webp"
                        alt=""
                        loading={index < 3 ? "eager" : "lazy"}
                        decoding="async"
                        onerror="this.dataset.failed='true'"
                      />
                    ) : (
                      <img
                        src={item.media.src}
                        alt=""
                        loading={index < 3 ? "eager" : "lazy"}
                        decoding="async"
                        onerror="this.dataset.failed='true'"
                      />
                    )
                  }
                </figure>
              )
            );
          })
        }
      </div>

      <ol class="standards-register" aria-label="Семь преимуществ One Construction">
        {
          advantages.map((item) => (
            <li class="standards-row">
              <span class="standards-row__number">{item.index}</span>
              <div class="standards-row__content">
                <h3 class="display">{item.title}</h3>
                <p>{item.body}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </div>
</section>

<style>
  .privileges-section {
    --priv-bg: #f6f5ef;
    --priv-ink: #111b2f;
    --priv-muted: #5d6672;
    --priv-soft: #747d86;
    --priv-line: rgba(17, 27, 47, 0.14);
    --priv-line-strong: rgba(17, 27, 47, 0.22);
    --priv-violet: #4e28d8;
    --standard-row: clamp(6.25rem, 7.35vw, 7.55rem);
    position: relative;
    overflow-x: clip;
    background: var(--priv-bg);
    color: var(--priv-ink);
    border-top: 1px solid rgba(17, 27, 47, 0.1);
  }

  .privileges-shell {
    position: relative;
    z-index: 1;
    width: 100%;
    padding: clamp(2.85rem, 4vw, 4.75rem) clamp(1.15rem, 2.8vw, 2.65rem) clamp(3.05rem, 4.2vw, 4.95rem);
  }

  .standards-board {
    display: grid;
    grid-template-areas: "manifest gutter register strips";
    grid-template-columns:
      minmax(22rem, 0.35fr)
      clamp(1.7rem, 2.25vw, 2.9rem)
      minmax(23rem, 0.36fr)
      minmax(16.5rem, 0.29fr);
    align-items: stretch;
    width: min(100%, 93rem);
    margin-inline: auto;
    border-top: 1px solid var(--priv-line-strong);
  }

  .standards-board::before {
    grid-area: gutter;
    content: "";
    border-left: 1px solid var(--priv-line-strong);
  }

  .standards-manifest {
    position: relative;
    grid-area: manifest;
    display: flex;
    flex-direction: column;
    min-width: 0;
    min-height: clamp(41.3rem, 48.65vw, 49.7rem);
    padding: clamp(1.85rem, 2.65vw, 2.7rem) clamp(1.85rem, 2.85vw, 2.7rem) clamp(1.85rem, 2.65vw, 2.7rem) clamp(1.1rem, 1.65vw, 1.65rem);
  }

  .privileges-label {
    display: grid;
    grid-template-columns: clamp(2.25rem, 2.85vw, 3.25rem) auto;
    align-items: center;
    gap: 0.8rem;
    color: var(--priv-soft);
  }

  .privileges-label__rule {
    display: block;
    width: 100%;
    height: 1px;
    background: var(--priv-violet);
  }

  .standards-heading {
    display: grid;
    gap: clamp(1.15rem, 1.55vw, 1.55rem);
    margin-top: clamp(2rem, 3.05vw, 3.35rem);
  }

  .privileges-title {
    max-width: 12.2ch;
    margin: 0;
    color: var(--priv-ink);
    font-size: clamp(2.65rem, 3.55vw, 3.75rem);
    font-weight: 520;
    line-height: 0.98;
    letter-spacing: -0.028em;
    text-transform: uppercase;
  }

  .privileges-title span {
    display: block;
  }

  .privileges-lead {
    display: grid;
    gap: 0.54rem;
    max-width: 38ch;
  }

  .privileges-lead p {
    margin: 0;
    color: var(--priv-muted);
    font-size: clamp(0.92rem, 0.98vw, 1.04rem);
    line-height: 1.56;
    text-wrap: pretty;
  }

  .standards-notation {
    align-self: end;
    display: grid;
    gap: 0.72rem;
    width: max-content;
    margin-top: clamp(2.25rem, 4.8vw, 5rem);
    color: var(--priv-soft);
  }

  .standards-notation__rule {
    display: block;
    width: clamp(2.4rem, 3vw, 3.4rem);
    height: 1px;
    background: var(--priv-violet);
  }

  .standards-notation__index {
    color: color-mix(in srgb, var(--priv-violet) 72%, #778091);
    font-family: var(--font-display, "Geist Variable", ui-sans-serif, system-ui, sans-serif);
    font-size: clamp(1.7rem, 2.25vw, 2.45rem);
    font-weight: 520;
    line-height: 0.9;
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
  }

  .standards-notation__index small {
    color: var(--priv-soft);
    font-size: 0.34em;
    letter-spacing: 0;
  }

  .standards-register {
    grid-area: register;
    display: grid;
    margin: 0;
    padding: 0;
    list-style: none;
    border-right: 1px solid var(--priv-line-strong);
  }

  .standards-row {
    display: grid;
    grid-template-columns: clamp(2.7rem, 3.7vw, 4.1rem) minmax(0, 1fr);
    gap: clamp(1.05rem, 1.5vw, 1.65rem);
    align-items: center;
    min-height: var(--standard-row);
    padding: clamp(0.82rem, 1.12vw, 1.12rem) clamp(1.35rem, 2.35vw, 2.4rem);
    border-bottom: 1px solid var(--priv-line);
  }

  .standards-row:last-child {
    border-bottom: 0;
  }

  .standards-row__number {
    align-self: center;
    color: color-mix(in srgb, var(--priv-violet) 72%, #788091);
    font-family: var(--font-display, "Geist Variable", ui-sans-serif, system-ui, sans-serif);
    font-size: clamp(1.02rem, 1.16vw, 1.22rem);
    font-weight: 560;
    line-height: 1;
    letter-spacing: 0;
    font-variant-numeric: tabular-nums;
  }

  .standards-row__content {
    display: grid;
    gap: 0.42rem;
    min-width: 0;
  }

  .standards-row h3 {
    margin: 0;
    color: var(--priv-ink);
    font-size: clamp(1.03rem, 1.13vw, 1.21rem);
    font-weight: 620;
    line-height: 1.1;
    letter-spacing: -0.008em;
    text-wrap: balance;
  }

  .standards-row p {
    max-width: 33ch;
    margin: 0;
    color: var(--priv-muted);
    font-size: clamp(0.85rem, 0.93vw, 1rem);
    line-height: 1.46;
    text-wrap: pretty;
  }

  .standards-strips {
    grid-area: strips;
    display: grid;
    grid-template-rows: repeat(7, var(--standard-row));
    min-width: 0;
  }

  .standards-strip {
    position: relative;
    min-height: var(--standard-row);
    margin: 0;
    overflow: hidden;
    background: #e7e6e0;
    border-bottom: 3px solid var(--priv-bg);
  }

  .standards-strip:last-child {
    border-bottom: 0;
  }

  .standards-strip::after {
    position: absolute;
    inset: 0;
    content: "";
    pointer-events: none;
    background-color: rgba(15, 23, 42, 0.045);
    mix-blend-mode: multiply;
  }

  .standards-strip img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.86) contrast(1.04) brightness(1.02);
  }

  .standards-strip:nth-child(1) img {
    object-position: 52% 36%;
  }

  .standards-strip:nth-child(2) img {
    object-position: 48% 50%;
  }

  .standards-strip:nth-child(3) img {
    object-position: 52% 45%;
  }

  .standards-strip:nth-child(4) img {
    object-position: 48% 48%;
  }

  .standards-strip:nth-child(5) img {
    object-position: 50% 50%;
  }

  .standards-strip:nth-child(6) img {
    object-position: 48% 44%;
  }

  .standards-strip:nth-child(7) img {
    object-position: 54% 54%;
  }

  @media (max-width: 1180px) {
    .privileges-section {
      --standard-row: clamp(5.6rem, 7.5vw, 6.65rem);
    }

    .standards-board {
      grid-template-columns:
        minmax(20rem, 0.38fr)
        clamp(1.35rem, 1.9vw, 2.15rem)
        minmax(20rem, 0.38fr)
        minmax(13rem, 0.24fr);
    }

    .standards-row {
      padding-inline: clamp(1rem, 1.65vw, 1.55rem);
    }
  }

  @media (max-width: 920px) {
    .standards-board {
      grid-template-areas:
        "manifest manifest"
        "strips strips"
        "register register";
      grid-template-columns: 1fr;
      border-top: 0;
      border-bottom: 0;
    }

    .standards-manifest {
      min-height: 0;
      padding: 0;
      border-right: 0;
    }

    .standards-notation {
      display: none;
    }

    .standards-board::before {
      display: none;
    }

    .standards-strips {
      grid-template-columns: repeat(7, minmax(8rem, 1fr));
      grid-template-rows: none;
      gap: 1px;
      margin-top: clamp(2rem, 5vw, 2.9rem);
      overflow-x: auto;
      border-top: 1px solid var(--priv-line-strong);
      border-bottom: 1px solid var(--priv-line-strong);
      scrollbar-width: none;
    }

    .standards-strips::-webkit-scrollbar {
      display: none;
    }

    .standards-strip {
      aspect-ratio: 1.55;
      min-height: 0;
      border-bottom: 0;
    }

    .standards-register {
      margin-top: clamp(2.2rem, 5.4vw, 3.05rem);
      border-top: 1px solid var(--priv-line-strong);
      border-right: 0;
      border-bottom: 1px solid var(--priv-line-strong);
    }
  }

  @media (max-width: 860px) {
    .privileges-shell {
      padding: 4.25rem 1rem 4.6rem;
    }

    .privileges-label {
      grid-template-columns: 42px auto;
      gap: 0.85rem;
    }

    .privileges-label__rule {
      width: 42px;
    }

    .standards-heading {
      gap: 1.3rem;
      margin-top: 1.45rem;
    }

    .privileges-title {
      max-width: 100%;
      font-size: clamp(2.04rem, 9.6vw, 3.08rem);
      line-height: 1;
      letter-spacing: -0.016em;
      overflow-wrap: break-word;
    }

    .privileges-lead {
      gap: 0.72rem;
      padding-top: 1.08rem;
    }

    .privileges-lead p {
      font-size: 0.94rem;
      line-height: 1.58;
    }

    .standards-row {
      grid-template-columns: 3.65rem minmax(0, 1fr);
      gap: 0.72rem;
      min-height: auto;
      padding: 1.15rem 0;
    }

    .standards-row__number {
      font-size: clamp(1.25rem, 5.8vw, 1.8rem);
      line-height: 0.95;
    }

    .standards-row__content {
      gap: 0.48rem;
    }

    .standards-row h3 {
      font-size: clamp(0.98rem, 4vw, 1.12rem);
      line-height: 1.13;
      overflow-wrap: break-word;
    }

    .standards-row p {
      max-width: 100%;
      font-size: 0.93rem;
      line-height: 1.54;
    }
  }

  @media (max-width: 390px) {
    .privileges-shell {
      padding-inline: 0.9rem;
    }

    .standards-strips {
      grid-template-columns: repeat(7, minmax(7.4rem, 1fr));
    }

    .standards-row {
      grid-template-columns: 3.3rem minmax(0, 1fr);
    }
  }
</style>
