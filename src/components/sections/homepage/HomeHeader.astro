---
import { company } from "@data/company";

interface NavItem {
  label: string;
  href: string;
}

interface Props {
  navItems?: NavItem[];
  mobileCtaHref?: string;
}

const defaultNavItems: NavItem[] = [
  { label: "Главная", href: "/#main" },
  { label: "Объекты", href: "/#projects" },
  { label: "О компании", href: "/#about" },
  { label: "Варианты покупки", href: "/#purchase" },
  { label: "Преимущества", href: "/#privileges" },
  { label: "Контакты", href: "/#contact" },
];

const { navItems = defaultNavItems, mobileCtaHref = "/#contact" } = Astro.props;
const primaryPhone = company.phones.find((phone) => phone.primary) ?? company.phones[0];
const socialLinks = company.socialLinks;
---

<header class="!fixed top-0 inset-x-0 !z-[80] border-b-[0.5px] border-slate-900/10">
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 -z-10 bg-alabaster/92 shadow-[0_1px_0_rgba(15,23,42,0.045)] backdrop-blur-sm"
  >
  </div>

  <div class="header-enter grid grid-cols-[1fr_auto] items-center gap-5 px-5 py-4 md:px-8 lg:grid-cols-[minmax(180px,0.85fr)_minmax(0,1.85fr)_minmax(280px,0.9fr)] lg:px-8 xl:grid-cols-[minmax(190px,0.9fr)_minmax(0,1.9fr)_minmax(310px,0.9fr)] xl:px-10">
    <a href="/#main" class="group flex min-h-11 min-w-0 items-center gap-3" aria-label="One Construction, на главную">
      <span class="truncate font-mono text-[11px] uppercase tracking-[0.18em] text-slate-900 transition-colors duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:text-violet-600 lg:tracking-[0.22em]">
        ONE CONSTRUCTION
      </span>
    </a>

    <nav aria-label="Главное меню" class="hidden min-w-0 items-center justify-center gap-4 lg:flex xl:gap-5">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class="group relative inline-flex min-h-11 items-center whitespace-nowrap font-mono text-xs uppercase tracking-[0.11em] text-slate-600 transition-colors duration-300 hover:text-slate-950 xl:text-xs xl:tracking-[0.13em]"
          >
            {item.label}
            <span
              aria-hidden="true"
              class="absolute -bottom-2 left-0 h-px w-0 bg-slate-950 transition-[width] duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:w-full"
            />
          </a>
        ))
      }
    </nav>

    <div class="hidden min-w-0 items-center justify-end gap-4 lg:flex xl:gap-6">
      <a
        href={primaryPhone.href}
      class="inline-flex min-h-11 items-center whitespace-nowrap font-mono text-[12px] uppercase tracking-[0.1em] text-slate-950 transition-colors duration-300 hover:text-violet-600 lg:text-[13px]"
      >
        {primaryPhone.display}
      </a>
      <div class="flex items-center gap-1.5">
        {
          socialLinks.map((social) => (
            <a
              href={social.href}
              target={social.external ? "_blank" : undefined}
              rel={social.external ? "noopener noreferrer" : undefined}
              aria-label={`${social.name} One Construction`}
              class="inline-flex h-11 w-11 items-center justify-center border-[0.5px] border-slate-900/20 font-mono text-[10px] uppercase tracking-[0.08em] text-slate-800 transition-colors duration-300 hover:border-slate-950 hover:text-violet-600"
            >
              {social.label}
            </a>
          ))
        }
      </div>
    </div>

    <button
      type="button"
      id="mobile-menu-trigger"
      aria-controls="mobile-menu"
      aria-expanded="false"
      class="min-h-11 justify-self-end border-[0.5px] border-slate-900/20 px-4 py-2 font-mono text-[11px] uppercase tracking-[0.16em] text-slate-900 lg:hidden"
    >
      МЕНЮ
    </button>
  </div>

  <div
    id="mobile-menu"
    aria-hidden="true"
    class="fixed inset-0 z-[90] flex h-dvh flex-col overflow-y-auto bg-alabaster opacity-0 pointer-events-none transition-opacity duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] data-[open=true]:opacity-100 data-[open=true]:pointer-events-auto lg:hidden"
    data-open="false"
    data-lenis-prevent
  >
    <div class="flex items-center justify-between gap-4 border-b-[0.5px] border-slate-900/10 px-5 py-4">
      <span class="min-w-0 truncate font-mono text-[11px] uppercase tracking-[0.18em] text-slate-900">
        ONE CONSTRUCTION
      </span>
      <button
        type="button"
        id="mobile-menu-close"
        aria-label="Закрыть меню"
        class="min-h-11 shrink-0 border-[0.5px] border-slate-900/20 px-4 py-2 font-mono text-[11px] uppercase tracking-[0.14em] text-slate-900"
      >
        Закрыть
      </button>
    </div>
    <nav aria-label="Мобильное меню" class="flex flex-col">
      {
        navItems.map((item, idx) => (
          <a
            href={item.href}
            data-mobile-nav-link
            class="flex items-center justify-between gap-5 border-b-[0.5px] border-slate-900/10 px-5 py-5 font-mono text-[14px] uppercase tracking-[0.12em] text-slate-950 transition-colors duration-300 hover:text-violet-600"
          >
            <span class="min-w-0 break-words">{item.label}</span>
            <span class="shrink-0 font-mono text-[10px] tracking-[0.18em] text-slate-500">
              {String(idx + 1).padStart(2, "0")}
            </span>
          </a>
        ))
      }
    </nav>

    <div class="mt-auto grid gap-3 border-t-[0.5px] border-slate-900/10 px-5 py-5">
      <a
        href={primaryPhone.href}
        class="inline-flex min-h-11 items-center font-mono text-[15px] uppercase tracking-[0.1em] text-slate-950"
      >
        {primaryPhone.display}
      </a>
      <div class="grid grid-cols-3 gap-2">
        {
          socialLinks.map((social) => (
            <a
              href={social.href}
              target={social.external ? "_blank" : undefined}
              rel={social.external ? "noopener noreferrer" : undefined}
              aria-label={`${social.name} One Construction`}
              class="min-h-11 border-[0.5px] border-slate-900/20 px-3 py-3 text-center font-mono text-[11px] uppercase tracking-[0.12em] text-slate-900"
            >
              {social.label}
            </a>
          ))
        }
        <a
          href={mobileCtaHref}
          data-mobile-nav-link
          class="col-span-3 min-h-11 border-[0.5px] border-slate-950 bg-slate-950 px-4 py-3 text-center font-mono text-[11px] uppercase tracking-[0.12em] text-alabaster"
        >
          Оставить заявку
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const trigger = document.getElementById("mobile-menu-trigger");
  const close = document.getElementById("mobile-menu-close");
  const menu = document.getElementById("mobile-menu");
  const links = document.querySelectorAll<HTMLAnchorElement>("[data-mobile-nav-link]");

  const setOpen = (open: boolean) => {
    if (!menu || !trigger) return;
    menu.dataset.open = String(open);
    menu.setAttribute("aria-hidden", String(!open));
    trigger.setAttribute("aria-expanded", String(open));
    document.documentElement.style.overflow = open ? "hidden" : "";
  };

  trigger?.addEventListener("click", () => setOpen(true));
  close?.addEventListener("click", () => setOpen(false));
  links.forEach((l) => l.addEventListener("click", () => setOpen(false)));
</script>
