---
/**
 * HomeProjects — полноэкранный горизонтальный скролл-пин (desktop)
 * и чистая вертикальная лента (mobile).
 *
 * ANTI-HARDCODE GUARD: все карточки рендерятся через .map() из массива.
 * Эффект scroll-pin реализован в `src/scripts/projects-scroll.ts`
 * через GSAP ScrollTrigger + matchMedia('(min-width: 768px)').
 */
import ProjectCard from "@modules/ProjectCard.astro";

const projects = [
  {
    slug: "lotos",
    name: "ЖК LOTOS",
    index: "ID: 001",
    cover:
      "https://images.unsplash.com/photo-1758193431393-0aead94a6a1b?ixlib=rb-4.1.0&q=88&fm=jpg&crop=entropy&cs=srgb&w=1600",
    location: "БИШКЕК, БОТАН. САД",
    coordinates: "42.8412° N · 74.5891° E",
    status: "СДАН · 2024",
    units: "1 / 2 / 3-КОМН · 78 КВАРТИР",
  },
  {
    slug: "yacht-village",
    name: "YACHT VILLAGE",
    index: "ID: 002",
    cover:
      "https://images.unsplash.com/photo-1760067537204-fe9b55b2f1b0?ixlib=rb-4.1.0&q=88&fm=jpg&crop=entropy&cs=srgb&w=1600",
    location: "ИССЫК-КУЛЬ · ЧОЛПОН-АТА",
    coordinates: "42.6481° N · 77.0810° E",
    status: "СТРОИТСЯ · СДАЧА 2026",
    units: "ВИЛЛЫ + АПАРТАМЕНТЫ · 142 ЕДИНИЦЫ",
  },
  {
    slug: "medina",
    name: "ЖК MEDINA",
    index: "ID: 003",
    cover:
      "https://images.unsplash.com/photo-1748440290920-9033ca4e1468?ixlib=rb-4.1.0&q=88&fm=jpg&crop=entropy&cs=srgb&w=1600",
    location: "БИШКЕК, ЦЕНТР",
    coordinates: "42.8746° N · 74.5698° E",
    status: "СДАЁТСЯ · Q3 2025",
    units: "1 / 2 / 3 / 4-КОМН · 264 КВАРТИРЫ",
  },
];
---

<section
  id="projects"
  class="relative bg-limestone border-b-[0.5px] border-slate-200 scroll-mt-28"
>
  <div class="section-stitch-top stitch-bone-to-limestone" aria-hidden="true"></div>
  <header
    class="flex items-end justify-between px-6 md:px-10 pt-20 md:pt-28 pb-8 border-b-[0.5px] border-slate-200"
  >
    <div class="flex flex-col gap-4">
      <span class="mono-detail" data-reveal>
        ОБЪЕКТЫ · {String(projects.length).padStart(2, "0")}
      </span>
      <h2
        class="display text-4xl md:text-6xl xl:text-7xl leading-[0.92] tracking-tighter text-slate-900"
        data-reveal
        style="--reveal-delay: 0.08s;"
      >
        Три проекта,<br />три температуры.
      </h2>
    </div>
    <span
      class="hidden md:inline-block font-mono text-[10px] uppercase tracking-[0.22em] text-slate-400"
      data-reveal
      style="--reveal-delay: 0.16s;"
    >
      ↘ ГОРИЗОНТ · ПРОКРУТИТЕ
    </span>
  </header>

  <!-- MOBILE: чистая вертикальная лента -->
  <div class="md:hidden flex flex-col gap-12 px-6 py-16">
    {projects.map((project) => <ProjectCard {...project} aspect="aspect-[4/5]" />)}
  </div>

  <!-- DESKTOP: горизонтальный scroll-pin -->
  <div class="hidden md:block hs-viewport overflow-hidden">
    <div class="hs-track flex items-center gap-8 px-10 py-20 h-[70vh] will-change-transform">
      {
        projects.map((project) => (
          <div class="hs-slide w-[58vw] lg:w-[48vw] h-[60vh] flex-shrink-0">
            <ProjectCard {...project} fill />
          </div>
        ))
      }
      <div class="hs-tail flex-shrink-0 w-[10vw]" aria-hidden="true"></div>
    </div>
  </div>
</section>
