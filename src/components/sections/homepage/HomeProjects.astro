---
import { getCollection } from "astro:content";

const allProjects = await getCollection("projects");
const projects = allProjects.sort((a, b) => a.data.sortOrder - b.data.sortOrder);
---

<section
  id="projects"
  class="relative bg-[#FBFBFA] border-t border-slate-200 scroll-mt-28 overflow-hidden"
  aria-label="Объекты One Construction"
>
  <div class="px-6 md:px-10 lg:px-12 pt-24 md:pt-40 pb-0">

    <!-- Section header -->
    <header class="flex items-baseline justify-between gap-6 pb-6 mb-16 md:mb-24 border-b border-slate-200">
      <span class="mono-detail" data-reveal>
        ОБЪЕКТЫ · {String(projects.length).padStart(2, "0")}
      </span>
      <span class="mono-detail" data-reveal style="--reveal-delay: 0.1s;">
        SEC: 002 / PROJECTS
      </span>
    </header>

    <!-- Section intro -->
    <div class="mb-20 md:mb-32 max-w-[58ch]" data-reveal style="--reveal-delay: 0.12s;">
      <h2 class="font-mono text-2xl md:text-4xl xl:text-5xl uppercase tracking-tight text-slate-900 leading-[1.1]">
        Наши объекты.
      </h2>
      <p class="mt-6 md:mt-8 text-sm md:text-base text-slate-600 max-w-[52ch] leading-relaxed">
        Три действующих жилых комплекса в Бишкеке. Каждый — отдельный архитектурный акт с прозрачной экономикой, фиксированной этажностью и понятным графиком сдачи.
      </p>
    </div>
  </div>

  <!-- Vertical project blocks -->
  {projects.map((project, idx) => {
    const reverse = idx % 2 === 1;
    return (
      <article
        class={`project-block relative border-t border-slate-200 ${idx === projects.length - 1 ? "border-b" : ""}`}
        data-project-index={project.data.index}
      >
        <!-- Top metadata bar -->
        <div class="px-6 md:px-10 lg:px-12 py-5 flex items-baseline justify-between gap-6 border-b border-slate-200/70">
          <span class="font-mono text-[11px] md:text-[10px] uppercase tracking-[0.14em] md:tracking-[0.22em] text-slate-500 leading-relaxed break-words">
            ID: {project.data.index} · {project.data.delivery}
          </span>
          <span class="font-mono text-[11px] md:text-[10px] uppercase tracking-[0.14em] md:tracking-[0.22em] text-slate-500 leading-relaxed text-right break-words">
            {project.data.units} · {project.data.storeys}
          </span>
        </div>

        <!-- Two-column block: image + content -->
        <div class={`grid grid-cols-1 md:grid-cols-12 gap-0 ${reverse ? "md:[&>.pb-image]:order-2" : ""}`}>
          <!-- Image -->
          <a
            href={`/projects/${project.id}`}
            class="pb-image oc-media-fallback group relative md:col-span-7 block overflow-hidden bg-[#F5F4F0] aspect-[4/3] md:aspect-auto md:min-h-[78vh]"
            data-reveal
            style="--reveal-delay: 0.05s;"
          >
            <img
              src={project.data.cover}
              alt={`${project.data.name} — архитектурный рендер`}
              loading={idx === 0 ? "eager" : "lazy"}
              decoding="async"
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-[1400ms] ease-[cubic-bezier(0.625,0.05,0,1)] group-hover:scale-[1.03]"
              onerror="this.dataset.failed='true'"
            />
            <div
              aria-hidden="true"
              class="absolute inset-0 bg-gradient-to-t from-slate-900/35 via-slate-900/0 to-transparent pointer-events-none"
            ></div>

            <!-- Blueprint hairline frame -->
            <div
              aria-hidden="true"
              class="pointer-events-none absolute inset-4 md:inset-6 border border-white/20 transition-colors duration-700 group-hover:border-violet-400/70"
            ></div>

            <!-- Index badge -->
            <span
              class="absolute top-4 left-4 md:top-6 md:left-6 max-w-[54%] font-mono text-[11px] md:text-[10px] uppercase tracking-[0.14em] md:tracking-[0.22em] text-white/85 leading-relaxed break-words"
            >
              {project.data.index} · {project.data.name}
            </span>

            <!-- Status badge -->
            <span
              class={`absolute top-4 right-4 md:top-6 md:right-6 max-w-[42%] font-mono text-[11px] md:text-[10px] uppercase tracking-[0.14em] md:tracking-[0.22em] px-3 py-1.5 border leading-relaxed text-right break-words ${project.data.status === "Готово к сдаче" ? "text-violet-100 bg-violet-700/70 border-violet-400/40" : "text-white/90 bg-slate-900/40 border-white/30"}`}
            >
              {project.data.status}
            </span>

            <!-- Bottom CTA hint -->
            <span class="absolute bottom-5 left-5 right-5 md:bottom-7 md:left-7 md:right-auto font-mono text-[11px] uppercase tracking-[0.16em] md:tracking-[0.2em] text-white opacity-95 transition-transform duration-500 group-hover:translate-x-1.5 break-words">
              Перейти к объекту →
            </span>
          </a>

          <!-- Content -->
          <div
            class={`md:col-span-5 flex flex-col gap-8 px-6 md:px-10 lg:px-12 py-12 md:py-16 ${reverse ? "md:border-r border-slate-200" : "md:border-l border-slate-200"}`}
            data-reveal
            style="--reveal-delay: 0.15s;"
          >
            <!-- Big monumental title -->
            <h3 class="display max-w-full text-[12vw] md:text-[5.4vw] xl:text-[4.6vw] leading-[0.92] tracking-tighter text-slate-900 break-words">
              {project.data.name}
            </h3>

            <!-- Location + price -->
            <div class="flex flex-col gap-3 pb-6 border-b border-slate-200">
              <span class="font-mono text-[11px] md:text-[10px] uppercase tracking-[0.14em] md:tracking-[0.22em] text-slate-400">
                ЛОКАЦИЯ
              </span>
              <span class="font-mono text-sm md:text-base text-slate-900 tracking-tight">
                {project.data.location}
              </span>
            </div>

            <!-- Stats grid -->
            <dl class="grid grid-cols-2 gap-x-6 gap-y-5">
              <div class="flex flex-col gap-1.5">
                <dt class="font-mono text-[10px] md:text-[9px] uppercase tracking-[0.14em] md:tracking-[0.22em] text-slate-400">СТАТУС</dt>
                <dd class="font-mono text-[12px] uppercase tracking-[0.14em] text-slate-900">{project.data.delivery}</dd>
              </div>
              <div class="flex flex-col gap-1.5">
                <dt class="font-mono text-[10px] md:text-[9px] uppercase tracking-[0.14em] md:tracking-[0.22em] text-slate-400">ЭТАЖНОСТЬ</dt>
                <dd class="font-mono text-[12px] uppercase tracking-[0.14em] text-slate-900">{project.data.storeys}</dd>
              </div>
              <div class="flex flex-col gap-1.5">
                <dt class="font-mono text-[10px] md:text-[9px] uppercase tracking-[0.14em] md:tracking-[0.22em] text-slate-400">КВАРТИРЫ</dt>
                <dd class="font-mono text-[12px] uppercase tracking-[0.14em] text-slate-900">{project.data.units}</dd>
              </div>
              <div class="flex flex-col gap-1.5">
                <dt class="font-mono text-[10px] md:text-[9px] uppercase tracking-[0.14em] md:tracking-[0.22em] text-slate-400">СТАРТ ЦЕНЫ</dt>
                <dd class="font-mono text-[12px] uppercase tracking-[0.14em] text-violet-700">{project.data.priceFrom}</dd>
              </div>
              {project.data.installment && (
              <div class="flex flex-col gap-1.5">
                <dt class="font-mono text-[10px] md:text-[9px] uppercase tracking-[0.14em] md:tracking-[0.22em] text-slate-400">РАССРОЧКА</dt>
                <dd class="font-mono text-[12px] uppercase tracking-[0.14em] text-slate-900">{project.data.installment.label}</dd>
              </div>
              )}
            </dl>

            <!-- Apartment table -->
            <div class="border-t border-slate-200 pt-6">
              <span class="font-mono text-[10px] md:text-[9px] uppercase tracking-[0.14em] md:tracking-[0.22em] text-slate-400 block mb-4">
                ПЛАНИРОВКИ
              </span>
              <div class="flex flex-col">
                {project.data.plans.map((p, i) => (
                  <div class={`grid grid-cols-12 gap-2 py-3 ${i < project.data.plans.length - 1 ? "border-b border-slate-200/70" : ""}`}>
                    <span class="col-span-5 font-mono text-[12px] uppercase tracking-[0.1em] text-slate-900">
                      {p.rooms}
                    </span>
                    <span class="col-span-3 font-mono text-[11px] tracking-tight text-slate-500">
                      {p.area}
                    </span>
                    <span class="col-span-4 text-right font-mono text-[12px] tracking-tight text-slate-900">
                      {p.price}
                    </span>
                  </div>
                ))}
              </div>
            </div>

            <!-- CTA -->
            <a
              href={`/projects/${project.id}`}
              class="self-start mt-2 inline-flex min-h-11 max-w-full items-center gap-3 font-mono text-[11px] uppercase tracking-[0.16em] md:tracking-[0.22em] text-slate-900 border border-slate-800 px-6 py-3.5 transition-colors duration-300 hover:bg-violet-700 hover:text-white hover:border-violet-700 break-words"
            >
              Перейти к объекту
              <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      </article>
    );
  })}
</section>
