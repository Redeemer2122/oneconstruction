---
const projects = [
  {
    slug: "lotos",
    name: "ЖК LOTOS",
    index: "01",
    cover:
      "https://images.unsplash.com/photo-1758193431393-0aead94a6a1b?ixlib=rb-4.1.0&q=88&fm=jpg&crop=entropy&cs=srgb&w=1600",
    location: "БИШКЕК, БОТАН. САД",
    coordinates: "42.8412° N · 74.5891° E",
    status: "СДАН · 2024",
    units: "1 / 2 / 3-КОМН · 78 КВАРТИР",
  },
  {
    slug: "yacht-village",
    name: "YACHT VILLAGE",
    index: "02",
    cover:
      "https://images.unsplash.com/photo-1760067537204-fe9b55b2f1b0?ixlib=rb-4.1.0&q=88&fm=jpg&crop=entropy&cs=srgb&w=1600",
    location: "ИССЫК-КУЛЬ · ЧОЛПОН-АТА",
    coordinates: "42.6481° N · 77.0810° E",
    status: "СТРОИТСЯ · СДАЧА 2026",
    units: "ВИЛЛЫ + АПАРТАМЕНТЫ · 142 ЕДИНИЦЫ",
  },
  {
    slug: "medina",
    name: "ЖК MEDINA",
    index: "03",
    cover:
      "https://images.unsplash.com/photo-1748440290920-9033ca4e1468?ixlib=rb-4.1.0&q=88&fm=jpg&crop=entropy&cs=srgb&w=1600",
    location: "БИШКЕК, ЦЕНТР",
    coordinates: "42.8746° N · 74.5698° E",
    status: "СДАЁТСЯ · Q3 2025",
    units: "1 / 2 / 3 / 4-КОМН · 264 КВАРТИРЫ",
  },
];

const rotations = ["rotate-[1.5deg]", "rotate-[-1deg]", "rotate-[0.5deg]"];
---

<section
  id="projects"
  class="relative bg-[#FBFBFA] border-t border-slate-200 scroll-mt-28 overflow-hidden"
  aria-label="Проекты One Construction"
>
  <div class="section-stitch-top stitch-limestone-to-alabaster" aria-hidden="true"></div>

  <div class="px-6 md:px-10 lg:px-12 py-24 md:py-40">

    <!-- Section header -->
    <header class="flex items-baseline justify-between pb-6 mb-16 md:mb-24 border-b border-slate-200">
      <span class="mono-detail" data-reveal>
        ОБЪЕКТЫ · {String(projects.length).padStart(2, "0")}
      </span>
      <span class="mono-detail" data-reveal style="--reveal-delay: 0.1s;">
        SEC: 003 / PROJECTS
      </span>
    </header>

    <!-- Stack layout container -->
    <div class="projects-stack-wrapper grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12">

      <!-- Left: static metadata frame (drafting sidebar) -->
      <aside class="md:col-span-4 xl:col-span-3 md:sticky md:top-32 md:self-start">
        <div class="border border-slate-200 bg-[#F5F4F0] p-6 md:p-8">
          <!-- Active project indicator -->
          <div class="mb-6 pb-4 border-b border-slate-200">
            <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-slate-400 block mb-2">АКТИВНЫЙ ОБЪЕКТ</span>
            <span class="stack-meta-name font-mono text-lg md:text-xl uppercase tracking-[0.08em] text-slate-900 block transition-opacity duration-300">
              {projects[0].name}
            </span>
          </div>

          <!-- Metadata fields -->
          <div class="flex flex-col gap-4">
            <div>
              <span class="font-mono text-[9px] uppercase tracking-[0.22em] text-slate-400 block mb-1">КООРДИНАТЫ</span>
              <span class="stack-meta-coords font-mono text-[11px] uppercase tracking-[0.14em] text-slate-800 block transition-opacity duration-300">
                {projects[0].coordinates}
              </span>
            </div>
            <div>
              <span class="font-mono text-[9px] uppercase tracking-[0.22em] text-slate-400 block mb-1">ЛОКАЦИЯ</span>
              <span class="stack-meta-location font-mono text-[11px] uppercase tracking-[0.14em] text-slate-800 block transition-opacity duration-300">
                {projects[0].location}
              </span>
            </div>
            <div>
              <span class="font-mono text-[9px] uppercase tracking-[0.22em] text-slate-400 block mb-1">СТАТУС</span>
              <span class="stack-meta-status font-mono text-[11px] uppercase tracking-[0.14em] text-slate-800 block transition-opacity duration-300">
                {projects[0].status}
              </span>
            </div>
            <div>
              <span class="font-mono text-[9px] uppercase tracking-[0.22em] text-slate-400 block mb-1">ПЛАНИРОВКИ</span>
              <span class="stack-meta-units font-mono text-[11px] uppercase tracking-[0.14em] text-slate-800 block transition-opacity duration-300">
                {projects[0].units}
              </span>
            </div>
          </div>

          <!-- Progress dots -->
          <div class="mt-8 pt-4 border-t border-slate-200 flex items-center gap-3">
            {projects.map((_, i) => (
              <span
                class={`stack-dot w-2 h-2 border border-slate-400 transition-all duration-300 ${i === 0 ? "bg-slate-900 border-slate-900" : ""}`}
                data-dot-index={i}
              ></span>
            ))}
            <span class="ml-auto font-mono text-[10px] text-slate-400 stack-counter">01 / {String(projects.length).padStart(2, "0")}</span>
          </div>
        </div>
      </aside>

      <!-- Right: card stack -->
      <div class="md:col-span-8 xl:col-span-9">
        <div class="projects-stack relative" style="height: 70vh; min-height: 480px;">
          {projects.map((project, idx) => (
            <a
              href={`/projects/${project.slug}`}
              class={`stack-card absolute inset-0 block border border-slate-200 bg-[#FBFBFA] overflow-hidden transition-shadow duration-500 hover:shadow-[0_12px_48px_-16px_rgba(30,41,59,0.12)] ${rotations[idx]}`}
              style={`z-index: ${projects.length - idx};`}
              data-stack-index={idx}
              data-project-name={project.name}
              data-project-coords={project.coordinates}
              data-project-location={project.location}
              data-project-status={project.status}
              data-project-units={project.units}
            >
              <!-- Image -->
              <div class="absolute inset-0">
                <img
                  src={project.cover}
                  alt={project.name}
                  class="w-full h-full object-cover"
                  loading={idx === 0 ? "eager" : "lazy"}
                />
                <div class="absolute inset-0 bg-gradient-to-t from-slate-900/60 via-transparent to-transparent"></div>
              </div>

              <!-- Card overlay content -->
              <div class="absolute bottom-0 left-0 right-0 p-6 md:p-8">
                <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-white/60 block mb-2">
                  ID: {project.index}
                </span>
                <h3 class="font-mono text-2xl md:text-3xl xl:text-4xl uppercase tracking-tight text-white">
                  {project.name}
                </h3>
              </div>

              <!-- Top-right index -->
              <span
                class="absolute top-4 right-4 md:top-6 md:right-6 font-mono text-[64px] md:text-[80px] leading-none tracking-tighter text-white/[0.08] select-none pointer-events-none"
                aria-hidden="true"
              >
                {project.index}
              </span>
            </a>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  import gsap from "gsap";
  import ScrollTrigger from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const init = () => {
    const section = document.getElementById("projects");
    if (!section) return;

    const stack = section.querySelector<HTMLElement>(".projects-stack");
    const cards = section.querySelectorAll<HTMLElement>(".stack-card");
    if (!stack || cards.length === 0) return;

    const metaName = section.querySelector<HTMLElement>(".stack-meta-name");
    const metaCoords = section.querySelector<HTMLElement>(".stack-meta-coords");
    const metaLocation = section.querySelector<HTMLElement>(".stack-meta-location");
    const metaStatus = section.querySelector<HTMLElement>(".stack-meta-status");
    const metaUnits = section.querySelector<HTMLElement>(".stack-meta-units");
    const counter = section.querySelector<HTMLElement>(".stack-counter");
    const dots = section.querySelectorAll<HTMLElement>(".stack-dot");
    const metaFields = [metaName, metaCoords, metaLocation, metaStatus, metaUnits].filter(Boolean) as HTMLElement[];

    let currentActiveIndex = 0;

    const updateMeta = (card: HTMLElement, animate = true) => {
      const idx = parseInt(card.dataset.stackIndex || "0");
      if (idx === currentActiveIndex && metaName?.textContent === card.dataset.projectName) return;
      currentActiveIndex = idx;

      const applyValues = () => {
        if (metaName) metaName.textContent = card.dataset.projectName || "";
        if (metaCoords) metaCoords.textContent = card.dataset.projectCoords || "";
        if (metaLocation) metaLocation.textContent = card.dataset.projectLocation || "";
        if (metaStatus) metaStatus.textContent = card.dataset.projectStatus || "";
        if (metaUnits) metaUnits.textContent = card.dataset.projectUnits || "";
        if (counter) counter.textContent = `${String(idx + 1).padStart(2, "0")} / ${String(cards.length).padStart(2, "0")}`;
        dots.forEach((dot, i) => {
          if (i === idx) {
            dot.classList.add("bg-slate-900", "border-slate-900");
          } else {
            dot.classList.remove("bg-slate-900", "border-slate-900");
          }
        });
      };

      if (animate) {
        gsap.to(metaFields, {
          opacity: 0,
          y: -6,
          duration: 0.15,
          ease: "power2.in",
          onComplete: () => {
            applyValues();
            gsap.to(metaFields, {
              opacity: 1,
              y: 0,
              duration: 0.25,
              ease: "power2.out",
            });
          },
        });
      } else {
        applyValues();
      }
    };

    // visible initial rotations — deck of blueprints feel
    const baseRotations = [0, -2.5, 2];
    const baseOffsets   = [0,  10,  18];

    const mm = gsap.matchMedia();

    mm.add(
      {
        isDesktop: "(min-width: 768px) and (prefers-reduced-motion: no-preference)",
      },
      (ctx) => {
        if (!ctx.conditions?.isDesktop) return;

        const totalCards = cards.length;
        const scrollPerCard = window.innerHeight * 0.9;

        // set initial deck state — clearly staggered & rotated
        cards.forEach((card, i) => {
          gsap.set(card, {
            x: baseOffsets[i] || 0,
            y: baseOffsets[i] || 0,
            rotateZ: baseRotations[i] || 0,
            zIndex: totalCards - i,
            opacity: 1,
          });
        });

        let lastActive = -1;

        ScrollTrigger.create({
          trigger: section,
          start: "top top",
          end: () => `+=${scrollPerCard * totalCards}`,
          pin: true,
          anticipatePin: 1,
          onUpdate: (self) => {
            const progress = self.progress * totalCards;
            const activeIndex = Math.min(Math.floor(progress), totalCards - 1);

            cards.forEach((card, i) => {
              const cardProgress = progress - i;

              if (cardProgress >= 1) {
                // card already gone
                gsap.set(card, {
                  x: "-130%",
                  y: "-10%",
                  rotateZ: -14,
                  opacity: 0,
                  zIndex: 0,
                });
              } else if (cardProgress > 0 && cardProgress < 1) {
                // card flying off — scrub in sync
                gsap.set(card, {
                  x: `${-cardProgress * 130}%`,
                  y: `${-cardProgress * 10}%`,
                  rotateZ: cardProgress * -14,
                  opacity: 1 - cardProgress,
                  zIndex: totalCards - i,
                });
              } else {
                // card waiting in deck
                const depth = i - activeIndex;
                const targetRot = depth === 0 ? 0 : baseRotations[i] || 0;
                const targetX   = depth * 10;
                const targetY   = depth * 10;

                if (i === activeIndex && lastActive !== activeIndex) {
                  // smoothly straighten the new top card
                  gsap.to(card, {
                    x: 0, y: 0, rotateZ: 0,
                    duration: 0.55,
                    ease: "power3.out",
                    overwrite: "auto",
                  });
                } else if (i !== activeIndex) {
                  gsap.set(card, {
                    x: targetX,
                    y: targetY,
                    rotateZ: targetRot,
                    opacity: 1,
                    zIndex: totalCards - i,
                  });
                }
              }
            });

            if (activeIndex !== lastActive) {
              lastActive = activeIndex;
              if (cards[activeIndex]) updateMeta(cards[activeIndex]);
            }
          },
        });

        return () => {
          ScrollTrigger.getAll().forEach((st) => {
            if (st.trigger === section) st.kill();
          });
          cards.forEach((card, i) => {
            gsap.set(card, { clearProps: "all" });
            (card as HTMLElement).style.zIndex = String(totalCards - i);
          });
        };
      }
    );
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init, { once: true });
  } else {
    init();
  }
</script>
