---
import { getCollection } from "astro:content";

const allProjects = await getCollection("projects");
const projects = allProjects
  .filter((project) => project.data.showOnHomepage !== false)
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder);

type ProjectPlan = {
  rooms: string;
  area: string;
  price: string;
};

const normalizeRoomGroup = (rooms: string) => {
  const match = rooms.match(/^(\d)/);
  return match ? `${match[1]}-комнатные` : rooms;
};

const summarizeAreas = (areas: string[]) => {
  const unique = Array.from(new Set(areas));
  if (unique.length <= 1) return unique[0] ?? "";

  const parsed = unique
    .map((area) => {
      const value = Number(area.replace(",", ".").match(/\d+(?:[.,]\d+)?/)?.[0]?.replace(",", "."));
      return Number.isFinite(value) ? { area, value } : null;
    })
    .filter(Boolean) as { area: string; value: number }[];

  if (parsed.length !== unique.length) return unique.join(" / ");

  const sorted = parsed.sort((a, b) => a.value - b.value);
  const unit = unique.find((area) => area.includes("м²")) ? " м²" : "";
  return `${sorted[0].value}-${sorted[sorted.length - 1].value}${unit}`;
};

const getHomepagePlanPreview = (plans: ProjectPlan[]) => {
  const groups = new Map<string, ProjectPlan[]>();

  plans.forEach((plan) => {
    const key = normalizeRoomGroup(plan.rooms);
    groups.set(key, [...(groups.get(key) ?? []), plan]);
  });

  return Array.from(groups.entries()).map(([rooms, group]) => {
    const prices = Array.from(new Set(group.map((plan) => plan.price)));
    return {
      rooms,
      area: summarizeAreas(group.map((plan) => plan.area)),
      price: prices.length === 1 ? prices[0] : prices[0],
    };
  });
};
---

<section
  id="projects"
  class="relative bg-[#FBFBFA] border-t border-slate-200 scroll-mt-28 overflow-hidden"
  aria-label="Объекты One Construction"
>
  <div class="px-6 md:px-10 lg:px-12 pt-[4.5rem] md:pt-24 lg:pt-28 pb-0">

    <!-- Section header -->
    <header class="flex flex-col gap-3 pb-6 mb-8 border-b border-slate-200 sm:flex-row sm:items-baseline sm:justify-between md:mb-10">
      <span class="mono-detail" data-reveal>
        ОБЪЕКТЫ / {String(projects.length).padStart(2, "0")}
      </span>
      <span class="mono-detail" data-reveal style="--reveal-delay: 0.1s;">
        Бишкек / актуальный портфель
      </span>
    </header>

    <!-- Section intro -->
    <div class="mb-12 flex flex-col gap-4 md:mb-16 md:flex-row md:items-end md:justify-between" data-reveal style="--reveal-delay: 0.12s;">
      <div class="grid max-w-[760px] grid-cols-1 gap-5">
        <h2 class="display text-[2.65rem] uppercase leading-[0.96] text-slate-900 md:text-[4.05rem] xl:text-[4.65rem]">
          Наши объекты.
        </h2>
        <div class="max-w-[58ch] border-t border-slate-900/15 pt-5">
          <p class="text-sm md:text-base text-slate-600 leading-relaxed">
            Три действующих жилых комплекса в Бишкеке. Каждый проект работает как отдельный архитектурный акт с прозрачной экономикой и понятным графиком сдачи.
          </p>
        </div>
      </div>
      <a
        href="/projects"
        class="group inline-flex items-center self-start whitespace-nowrap border-b border-slate-900/25 pb-2 font-mono text-xs uppercase tracking-[0.14em] text-slate-900 transition-colors duration-300 hover:border-violet-700 hover:text-violet-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-violet-700 md:self-end md:text-sm md:tracking-[0.16em]"
      >
        <span>Смотреть все объекты</span>
        <span aria-hidden="true" class="ml-2 transition-transform duration-300 group-hover:translate-x-1">
          →
        </span>
      </a>
    </div>
  </div>

  <!-- Vertical project blocks -->
  {projects.map((project, idx) => {
    const reverse = idx % 2 === 1;
    const stats = [
      { label: "Цена", value: project.data.priceFrom, accent: true },
      { label: "Срок", value: project.data.delivery, accent: false },
      { label: "Этажность", value: project.data.storeys, accent: false },
      { label: "Квартиры", value: project.data.units, accent: false },
      ...(project.data.installment ? [{ label: "Рассрочка", value: project.data.installment.label, accent: false }] : []),
    ];
    const planPreview = getHomepagePlanPreview(project.data.plans);

    return (
      <article
        class={`project-block relative border-t border-slate-200 bg-[#FBFBFA] ${idx === projects.length - 1 ? "border-b" : ""}`}
        data-project-index={project.data.index}
      >
        <!-- Top metadata bar -->
        <div class="grid grid-cols-1 gap-3 border-b border-slate-200/70 px-6 py-5 md:grid-cols-12 md:gap-6 md:px-10 lg:px-12">
          <span class="font-mono text-[11px] uppercase tracking-[0.12em] text-slate-500 leading-relaxed md:col-span-3 md:text-[10px] md:tracking-[0.2em]">
            OBJ: {project.data.index}
          </span>
          <span class="font-mono text-[11px] uppercase tracking-[0.12em] text-slate-600 leading-relaxed md:col-span-5 md:text-[10px] md:tracking-[0.2em]">
            {project.data.location}
          </span>
          <span class="font-mono text-[11px] uppercase tracking-[0.12em] text-slate-500 leading-relaxed md:col-span-4 md:text-right md:text-[10px] md:tracking-[0.2em]">
            {project.data.status} / {project.data.delivery}
          </span>
        </div>

        <!-- Two-column block: image + content -->
        <div class={`grid grid-cols-1 md:grid-cols-12 gap-0 ${reverse ? "md:[&>.pb-image]:order-2" : ""}`}>
          <!-- Image -->
          <a
            href={`/projects/${project.id}`}
            class="pb-image oc-media-fallback group relative block aspect-[4/3] overflow-hidden bg-[#F5F4F0] md:col-span-6 md:aspect-auto md:min-h-[60vh] lg:min-h-[66vh]"
            data-reveal
            style="--reveal-delay: 0.05s;"
          >
            <div class="absolute inset-0 z-0 flex flex-col justify-between p-5 md:p-7" aria-hidden="true">
              <div class="grid grid-cols-3 gap-3 text-slate-400/60">
                <span class="h-px bg-current"></span>
                <span class="h-px bg-current"></span>
                <span class="h-px bg-current"></span>
              </div>
              <div class="max-w-[18rem] font-mono text-[10px] uppercase leading-relaxed tracking-[0.16em] text-slate-500">
                Архитектурный рендер / {project.data.name}
              </div>
            </div>
            <img
              src={project.data.cover}
              alt={`${project.data.name}: архитектурный рендер`}
              loading={idx === 0 ? "eager" : "lazy"}
              decoding="async"
              class="absolute inset-0 z-[1] h-full w-full object-cover saturate-[0.92] contrast-[1.04] transition-transform duration-[1400ms] ease-[cubic-bezier(0.625,0.05,0,1)] group-hover:scale-[1.025]"
              onerror="this.dataset.failed='true'"
            />
            <div
              aria-hidden="true"
              class="pointer-events-none absolute inset-0 z-[2] bg-[linear-gradient(to_top,rgba(15,23,42,0.48),rgba(15,23,42,0.04)_44%,rgba(251,251,250,0.12))]"
            ></div>

            <!-- Blueprint hairline frame -->
            <div
              aria-hidden="true"
              class="pointer-events-none absolute inset-4 z-[3] border border-white/25 transition-colors duration-700 group-hover:border-violet-400/75 md:inset-6"
            ></div>

            <!-- Index badge -->
            <span
              class="absolute left-4 top-4 z-[4] max-w-[58%] font-mono text-[11px] uppercase leading-relaxed tracking-[0.12em] text-white/90 md:left-6 md:top-6 md:text-[10px] md:tracking-[0.2em]"
            >
              {project.data.index} / {project.data.name}
            </span>

            <!-- Status badge -->
            <span
              class={`absolute right-4 top-4 z-[4] max-w-[42%] border px-3 py-1.5 text-right font-mono text-[11px] uppercase leading-relaxed tracking-[0.12em] md:right-6 md:top-6 md:text-[10px] md:tracking-[0.2em] ${project.data.status === "Готово к сдаче" ? "text-violet-100 bg-violet-700/80 border-violet-300/50" : "text-white/90 bg-slate-900/45 border-white/30"}`}
            >
              {project.data.status}
            </span>
          </a>

          <!-- Content -->
          <div
            class={`flex flex-col gap-7 px-6 py-10 md:col-span-6 md:px-10 md:py-12 lg:px-12 lg:py-14 ${reverse ? "md:border-r border-slate-200" : "md:border-l border-slate-200"}`}
            data-reveal
            style="--reveal-delay: 0.15s;"
          >
            <div class="grid gap-6 border-b border-slate-200 pb-8 md:grid-cols-[1fr_auto] md:items-start">
              <div class="min-w-0">
                <span class="mb-4 block font-mono text-[11px] uppercase leading-relaxed tracking-[0.12em] text-slate-500 md:text-[10px] md:tracking-[0.2em]">
                  {project.data.location}
                </span>
                <h3 class="display max-w-full break-words text-[13vw] leading-[0.96] tracking-[-0.024em] text-slate-900 md:text-[4.55vw] xl:text-[3.95vw]">
                  {project.data.name}
                </h3>
              </div>
              <div class="border border-violet-700/45 bg-violet-700/[0.035] p-4 md:min-w-[11rem]">
                <span class="block font-mono text-[10px] uppercase tracking-[0.16em] text-slate-400">
                  Старт цены
                </span>
                <strong class="mt-2 block font-mono text-base font-medium uppercase leading-snug tracking-tight text-violet-700 md:text-lg">
                  {project.data.priceFrom}
                </strong>
              </div>
            </div>

            <div class="grid grid-cols-1 gap-4 border-b border-slate-200 pb-8 sm:grid-cols-2">
              <div>
                <span class="block font-mono text-[10px] uppercase tracking-[0.16em] text-slate-400">
                  Статус объекта
                </span>
                <span class="mt-2 block font-mono text-sm uppercase leading-snug tracking-[0.08em] text-slate-900">
                  {project.data.status}
                </span>
              </div>
              <div>
                <span class="block font-mono text-[10px] uppercase tracking-[0.16em] text-slate-400">
                  Сдача
                </span>
                <span class="mt-2 block font-mono text-sm uppercase leading-snug tracking-[0.08em] text-slate-900">
                  {project.data.delivery}
                </span>
              </div>
            </div>

            <!-- Stats grid -->
            <dl class="grid grid-cols-1 border-t border-slate-200 sm:grid-cols-2">
              {stats.map((item) => (
                <div class="border-b border-slate-200 px-0 py-4 sm:odd:border-r sm:odd:pr-5 sm:even:pl-5">
                  <dt class="font-mono text-[10px] uppercase tracking-[0.14em] text-slate-400 md:text-[9px] md:tracking-[0.2em]">
                    {item.label}
                  </dt>
                  <dd class={`mt-2 font-mono text-sm uppercase leading-snug tracking-[0.06em] md:text-[13px] ${item.accent ? "text-violet-700" : "text-slate-900"}`}>
                    {item.value}
                  </dd>
                </div>
              ))}
            </dl>

            <!-- Apartment table -->
            <div>
              <div class="mb-4 flex items-end justify-between gap-4">
                <span class="font-mono text-[10px] uppercase tracking-[0.16em] text-slate-400 md:text-[9px] md:tracking-[0.2em]">
                  Планировки
                </span>
                <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-slate-400">
                  {String(planPreview.length).padStart(2, "0")} типов
                </span>
              </div>
              <div class="border-t border-slate-300">
                {planPreview.map((p, i) => (
                  <div class={`grid grid-cols-1 gap-2 py-4 sm:grid-cols-12 sm:items-baseline sm:gap-4 ${i < planPreview.length - 1 ? "border-b border-slate-200/80" : ""}`}>
                    <span class="font-mono text-sm uppercase tracking-[0.06em] text-slate-900 sm:col-span-5">
                      {p.rooms}
                    </span>
                    <span class="font-mono text-[13px] leading-snug tracking-tight text-slate-500 sm:col-span-3">
                      {p.area}
                    </span>
                    <span class="font-mono text-sm leading-snug tracking-tight text-slate-900 sm:col-span-4 sm:text-right">
                      {p.price}
                    </span>
                  </div>
                ))}
              </div>
            </div>

            <!-- CTA -->
            <a
              href={`/projects/${project.id}`}
              class="group mt-1 inline-grid min-h-12 max-w-full grid-cols-[1fr_auto] items-center border border-slate-900 bg-slate-900 font-mono text-[11px] uppercase tracking-[0.14em] text-[#FBFBFA] transition-colors duration-300 hover:border-violet-700 hover:bg-violet-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-violet-700 md:self-start md:tracking-[0.2em]"
            >
              <span class="px-5 py-3.5">Перейти к объекту</span>
              <span aria-hidden="true" class="grid h-full min-w-12 place-items-center border-l border-[#FBFBFA]/25 transition-transform duration-300 group-hover:translate-x-0.5">
                →
              </span>
            </a>
          </div>
        </div>
      </article>
    );
  })}

</section>
