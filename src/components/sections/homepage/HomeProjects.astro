---
/**
 * HomeProjects — секция объектов с динамическим маппингом.
 *
 * ANTI-HARDCODE GUARD: Все карточки рендерятся через .map() из массива.
 * Формула циклического смещения: index % 3 создаёт волнообразный ритм.
 * Максимальная высота карточек на десктопе: h-[70vh].
 * На мобильных смещение отключено (строгая вертикальная лента).
 */
import ProjectCard from "@modules/ProjectCard.astro";

const projects = [
  {
    slug: "lotos",
    name: "ЖК LOTOS",
    index: "ID: 001",
    cover:
      "https://images.unsplash.com/photo-1758193431393-0aead94a6a1b?ixlib=rb-4.1.0&q=88&fm=jpg&crop=entropy&cs=srgb&w=1600",
    location: "БИШКЕК, БОТАН. САД",
    coordinates: "42.8412° N · 74.5891° E",
    status: "СДАН · 2024",
    units: "1 / 2 / 3-КОМН · 78 КВАРТИР",
  },
  {
    slug: "yacht-village",
    name: "YACHT VILLAGE",
    index: "ID: 002",
    cover:
      "https://images.unsplash.com/photo-1760067537204-fe9b55b2f1b0?ixlib=rb-4.1.0&q=88&fm=jpg&crop=entropy&cs=srgb&w=1600",
    location: "ИССЫК-КУЛЬ · ЧОЛПОН-АТА",
    coordinates: "42.6481° N · 77.0810° E",
    status: "СТРОИТСЯ · СДАЧА 2026",
    units: "ВИЛЛЫ + АПАРТАМЕНТЫ · 142 ЕДИНИЦЫ",
  },
  {
    slug: "medina",
    name: "ЖК MEDINA",
    index: "ID: 003",
    cover:
      "https://images.unsplash.com/photo-1748440290920-9033ca4e1468?ixlib=rb-4.1.0&q=88&fm=jpg&crop=entropy&cs=srgb&w=1600",
    location: "БИШКЕК, ЦЕНТР",
    coordinates: "42.8746° N · 74.5698° E",
    status: "СДАЁТСЯ · Q3 2025",
    units: "1 / 2 / 3 / 4-КОМН · 264 КВАРТИРЫ",
  },
];

/**
 * Формула циклического смещения для десктопа.
 * index % 3 создаёт паттерн: 0 → 0rem, 1 → 8rem, 2 → 2rem, 3 → 0rem...
 */
const getVerticalOffset = (index: number): string => {
  const pattern = index % 3;
  if (pattern === 0) return "md:translate-y-0";
  if (pattern === 1) return "md:translate-y-32 lg:translate-y-40";
  return "md:translate-y-8 lg:translate-y-12";
};

/**
 * Динамическая задержка анимации reveal.
 */
const getRevealDelay = (index: number): string => {
  return `${0.05 + index * 0.14}s`;
};
---

<section
  id="projects"
  class="relative bg-alabaster px-6 md:px-10 pt-32 md:pt-44 pb-24 md:pb-32 border-b-[0.5px] border-slate-200 scroll-mt-28"
>
  <header class="flex items-end justify-between mb-20 md:mb-32 pb-4 border-b-[0.5px] border-slate-200">
    <div class="flex flex-col gap-4">
      <span class="mono-detail" data-reveal>ОБЪЕКТЫ · {String(projects.length).padStart(2, "0")}</span>
      <h2
        class="display text-4xl md:text-7xl leading-[0.92] tracking-tighter text-slate-900"
        data-reveal
        style="--reveal-delay: 0.08s;"
      >
        Три проекта,<br />три температуры.
      </h2>
    </div>
    <a
      href="#contact"
      data-reveal
      style="--reveal-delay: 0.16s;"
      class="hidden md:inline-block font-mono text-[11px] uppercase tracking-[0.22em] text-slate-500 border-b-[0.5px] border-slate-300 pb-1.5 transition-colors duration-300 hover:text-violet-600 hover:border-violet-600"
    >
      Каталог планировок ↘
    </a>
  </header>

  <div class="relative z-10 grid grid-cols-1 md:grid-cols-12 gap-y-16 md:gap-y-0 md:gap-x-8">
    {
      projects.map((project, index) => (
        <div
          class={`md:col-span-4 ${getVerticalOffset(index)} max-h-none md:max-h-[70vh]`}
        >
          <div data-reveal style={`--reveal-delay: ${getRevealDelay(index)};`}>
            <ProjectCard {...project} aspect="aspect-[4/5]" />
          </div>
        </div>
      ))
    }
  </div>
</section>
