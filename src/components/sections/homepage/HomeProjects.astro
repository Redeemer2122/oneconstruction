---
import ProjectCard from "@modules/ProjectCard.astro";

const projects = [
  {
    slug: "lotos",
    name: "ЖК LOTOS",
    index: "ID: 001",
    cover:
      "https://images.unsplash.com/photo-1758193431393-0aead94a6a1b?ixlib=rb-4.1.0&q=88&fm=jpg&crop=entropy&cs=srgb&w=1600",
    location: "БИШКЕК, БОТАН. САД",
    coordinates: "42.8412° N · 74.5891° E",
    status: "СДАН · 2024",
    units: "1 / 2 / 3-КОМН · 78 КВАРТИР",
  },
  {
    slug: "yacht-village",
    name: "YACHT VILLAGE",
    index: "ID: 002",
    cover:
      "https://images.unsplash.com/photo-1760067537204-fe9b55b2f1b0?ixlib=rb-4.1.0&q=88&fm=jpg&crop=entropy&cs=srgb&w=1600",
    location: "ИССЫК-КУЛЬ · ЧОЛПОН-АТА",
    coordinates: "42.6481° N · 77.0810° E",
    status: "СТРОИТСЯ · СДАЧА 2026",
    units: "ВИЛЛЫ + АПАРТАМЕНТЫ · 142 ЕДИНИЦЫ",
  },
  {
    slug: "medina",
    name: "ЖК MEDINA",
    index: "ID: 003",
    cover:
      "https://images.unsplash.com/photo-1748440290920-9033ca4e1468?ixlib=rb-4.1.0&q=88&fm=jpg&crop=entropy&cs=srgb&w=1600",
    location: "БИШКЕК, ЦЕНТР",
    coordinates: "42.8746° N · 74.5698° E",
    status: "СДАЁТСЯ · Q3 2025",
    units: "1 / 2 / 3 / 4-КОМН · 264 КВАРТИРЫ",
  },
];
---

<section
  id="projects"
  class="relative bg-blueprint border-b border-[oklch(0.195_0.018_42_/_0.10)] scroll-mt-28"
  aria-label="Проекты One Construction"
>
  <div class="section-stitch-top stitch-bone-to-blueprint" aria-hidden="true"></div>

  <header
    class="relative flex items-end justify-between px-6 md:px-10 pt-20 md:pt-28 pb-8
           border-b border-[oklch(0.195_0.018_42_/_0.10)]"
  >
    <!-- Угловой штамп — едва заметный -->
    <span
      class="absolute top-4 right-4 md:top-6 md:right-6 font-mono text-[9px] uppercase
             tracking-[0.20em] text-[#38332f]/20 select-none"
      aria-hidden="true"
    >
      ЛИСТ 01 · М 1:500
    </span>

    <div class="flex flex-col gap-4">
      <span class="mono-detail" data-reveal>
        ОБЪЕКТЫ · {String(projects.length).padStart(2, "0")}
      </span>
      <h2
        class="display text-4xl md:text-6xl xl:text-7xl leading-[0.92] tracking-tighter text-[#38332f]"
        data-reveal
        style="--reveal-delay: 0.08s;"
      >
        Три проекта,<br />три температуры.
      </h2>
    </div>

    <span
      class="hidden md:inline-block font-mono text-[10px] uppercase tracking-[0.22em] text-[#7e7975]/60"
      data-reveal
      style="--reveal-delay: 0.16s;"
    >
      ↘ ГОРИЗОНТ · ПРОКРУТИТЕ
    </span>
  </header>

  <!-- MOBILE: вертикальная лента -->
  <div class="md:hidden flex flex-col gap-0 px-6 py-16 border-x border-[oklch(0.195_0.018_42_/_0.10)]">
    {projects.map((project, i) => (
      <div class={i < projects.length - 1 ? "mb-12" : ""}>
        <ProjectCard {...project} aspect="aspect-[4/5]" />
      </div>
    ))}
  </div>

  <!-- DESKTOP: горизонтальный scroll-pin -->
  <div class="hidden md:block hs-viewport overflow-hidden">
    <div class="hs-track flex items-center gap-6 px-10 py-20 h-[70vh] will-change-transform">
      {projects.map((project) => (
        <div class="hs-slide w-[58vw] lg:w-[48vw] h-[60vh] flex-shrink-0">
          <ProjectCard {...project} fill />
        </div>
      ))}
      <div class="hs-tail flex-shrink-0 w-[10vw]" aria-hidden="true"></div>
    </div>
  </div>
</section>
