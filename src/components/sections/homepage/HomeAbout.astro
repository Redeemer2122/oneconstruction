---
const statementRows = [
  {
    index: "01",
    text: "Наша цель — сделать процесс строительства прозрачным,\nкомфортным и предсказуемым.",
  },
  {
    index: "02",
    text: "Мы работаем только с проверенными подрядчиками и командами,\nкоторые разделяют наши стандарты качества.",
  },
  {
    index: "03",
    text: "Каждый объект проходит строгий контроль и строится\nпо единым регламентам.",
  },
  {
    index: "04",
    text: "Мы ценим доверие, открытость и результат, которым можно гордиться.",
  },
  {
    index: "05",
    text: "Для нас важно не количество проектов, а ощущение, что каждый дом\nот One Construction становится частью города — надолго!",
  },
] as const;

const metricItems = [
  {
    value: "Более 10 лет опыта",
    displayValue: ["Более 10 лет", "опыта"],
    description:
      "От строительной компании до девелопера бизнес-класса.",
  },
  {
    value: "400 000 м²",
    description:
      "Реализованные и строящиеся жилые комплексы.",
  },
  {
    value: "1200+ семей",
    description:
      "Уже выбрали квартиры One Construction.",
  },
  {
    value: "Контроль качества",
    description:
      "Проверка этапов по внутренним стандартам.",
  },
  {
    value: "Архитектура со смыслом",
    description:
      "Планировки, фасады и инфраструктура продуманы.",
  },
] as const;
---

<section id="about" class="about-chapter oc-chapter oc-chapter--about relative overflow-hidden border-t border-slate-900/10">
  <div class="section-stitch-top stitch-gallery-to-bone" aria-hidden="true"></div>

  <div class="about-chapter__inner px-5 py-16 sm:px-6 md:px-10 md:py-24 lg:px-12 lg:py-28">
    <div class="about-chapter__block">
      <div class="about-chapter__copy">
        <div class="about-chapter__label" data-reveal>
          <span class="about-chapter__label-rule" aria-hidden="true"></span>
          <span class="mono-detail oc-section-label">О КОМПАНИИ</span>
        </div>

        <h2 class="about-chapter__title display uppercase text-slate-950" data-reveal style="--reveal-delay: 0.06s;">
          Мы создаём пространство,<br />
          в котором хочется жить
        </h2>

        <div class="about-chapter__text mt-8 grid max-w-[62ch] gap-7" data-reveal style="--reveal-delay: 0.14s;">
          <p class="about-chapter__lead text-base font-medium leading-relaxed text-slate-800 md:text-lg">
            One Construction — девелопер, который создаёт не просто здания,<br class="hidden sm:block" />
            а пространства, где хочется жить.
          </p>

          <div class="about-chapter__statements">
            {statementRows.map((row) => (
              <div class="about-chapter__statement">
                <span class="about-chapter__statement-index font-mono text-[10px] uppercase leading-none tracking-[0.16em] text-violet-700">
                  {row.index}
                </span>
                <p class="about-chapter__statement-text text-[15px] leading-relaxed text-slate-650 md:text-base">
                  {row.text.split("\n").map((line) => (
                    <>
                      {line}
                      <br />
                    </>
                  ))}
                </p>
              </div>
            ))}
          </div>
        </div>
      </div>

      <div class="about-chapter__metrics" data-reveal style="--reveal-delay: 0.22s;">
        {metricItems.map((item) => (
          <article class="about-chapter__metric">
            <span class="about-chapter__metric-mark" aria-hidden="true"></span>
            <div class="about-chapter__metric-value font-mono text-slate-950" aria-label={item.value}>
              {"displayValue" in item ? (
                item.displayValue.map((line) => (
                  <span class="about-chapter__metric-value-line">
                    {line}
                  </span>
                ))
              ) : (
                item.value
              )}
            </div>
            <div class="about-chapter__metric-meta">
              <p class="about-chapter__metric-description text-[12px] text-slate-600 md:text-[13px]">
                {item.description}
              </p>
            </div>
          </article>
        ))}
      </div>

      <figure class="about-chapter__media-wrap" data-reveal style="--reveal-delay: 0.1s;">
        <div class="about-chapter__media oc-media-fallback">
          <img
            src="/img/about/about-main.jpg"
            alt="Современный жилой фасад с бетонными, стеклянными и теплыми панелями"
            loading="lazy"
            decoding="async"
            class="h-full w-full object-cover"
            onerror="this.dataset.failed='true'"
          />
          <div class="about-chapter__image-shade" aria-hidden="true"></div>
        </div>
      </figure>
    </div>
  </div>
</section>

<style>
  .about-chapter {
    --about-violet: #5d3ac4;
    color: #101827;
    contain: paint;
  }

  .about-chapter__inner {
    position: relative;
    z-index: 1;
  }

  .about-chapter__label-rule,
  .about-chapter__metric-mark {
    height: 1px;
    background: rgba(93, 58, 196, 0.74);
  }

  .about-chapter__label {
    display: grid;
    grid-template-columns: 52px auto;
    align-items: center;
    justify-content: start;
    gap: 1rem;
    margin-bottom: clamp(1.65rem, 2.4vw, 2.35rem);
  }

  .about-chapter__label-rule {
    width: 52px;
  }

  .about-chapter__block {
    position: relative;
    display: grid;
    grid-template-areas:
      "copy media"
      "metrics media";
    grid-template-columns: minmax(0, 54.5fr) minmax(0, 45.5fr);
    grid-template-rows: 1fr auto;
    overflow: hidden;
    border-block: 1px solid rgba(15, 23, 42, 0.16);
    background:
      linear-gradient(112deg, rgba(248, 247, 244, 0.9) 0%, rgba(251, 251, 250, 0.72) 45%, rgba(245, 244, 240, 0.56) 100%),
      rgba(251, 251, 250, 0.44);
  }

  .about-chapter__block::after {
    content: "";
    position: absolute;
    right: 0;
    bottom: 0;
    left: 54.5%;
    height: 1px;
    pointer-events: none;
    background: rgba(15, 23, 42, 0.18);
  }

  .about-chapter__copy {
    grid-area: copy;
    display: flex;
    min-width: 0;
    flex-direction: column;
    justify-content: center;
    padding: clamp(3.35rem, 5.25vw, 6rem) clamp(3rem, 5.35vw, 6.55rem) clamp(2.95rem, 4.65vw, 5.15rem) clamp(1.15rem, 1.8vw, 1.8rem);
    background:
      linear-gradient(90deg, rgba(251, 251, 250, 0.9) 0%, rgba(251, 251, 250, 0.68) 70%, rgba(245, 244, 240, 0.22) 100%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.22), rgba(15, 23, 42, 0.025));
  }

  .about-chapter__title {
    max-width: 12.6ch;
    font-size: clamp(2.78rem, 4.82vw, 5.72rem);
    line-height: 1;
    letter-spacing: 0;
  }

  .about-chapter__statements {
    display: grid;
    border-top: 1px solid rgba(15, 23, 42, 0.14);
  }

  .about-chapter__statement {
    display: grid;
    grid-template-columns: 2.6rem minmax(0, 1fr);
    gap: 1.25rem;
    align-items: start;
    padding: 1.06rem 0;
    border-bottom: 1px solid rgba(15, 23, 42, 0.11);
  }

  .about-chapter__statement-text {
    max-width: 56ch;
    line-height: 1.72;
  }

  .about-chapter__metrics {
    grid-area: metrics;
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    align-items: stretch;
    min-width: 0;
    border-top: 1px solid rgba(15, 23, 42, 0.17);
    background: rgba(251, 251, 250, 0.76);
  }

  .about-chapter__metric {
    position: relative;
    display: flex;
    min-height: clamp(8rem, 8.4vw, 9.35rem);
    min-width: 0;
    flex-direction: column;
    padding: clamp(1.08rem, 1.34vw, 1.42rem) clamp(0.74rem, 1vw, 1rem) clamp(1rem, 1.2vw, 1.28rem);
  }

  .about-chapter__metric + .about-chapter__metric {
    border-left: 1px solid rgba(15, 23, 42, 0.16);
  }

  .about-chapter__metric-mark {
    display: block;
    width: 22px;
    margin-bottom: clamp(0.9rem, 1.08vw, 1.12rem);
  }

  .about-chapter__metric-value {
    max-width: 100%;
    min-height: 2.42em;
    font-size: clamp(0.82rem, 0.96vw, 1.02rem);
    line-height: 1.13;
    letter-spacing: 0;
    overflow-wrap: break-word;
  }

  .about-chapter__metric-value-line {
    display: block;
  }

  .about-chapter__metric-meta {
    min-width: 0;
    margin-top: 0;
    padding-top: clamp(0.72rem, 0.86vw, 0.95rem);
  }

  .about-chapter__metric-description {
    max-width: 100%;
    font-size: clamp(0.68rem, 0.74vw, 0.78rem);
    line-height: 1.44;
  }

  .about-chapter__media-wrap {
    grid-area: media;
    position: relative;
    min-width: 0;
    border-left: 1px solid rgba(15, 23, 42, 0.17);
  }

  .about-chapter__media-wrap::before {
    content: "";
    position: absolute;
    top: 0;
    right: 0;
    left: 0;
    z-index: 3;
    height: 1px;
    pointer-events: none;
    background: rgba(251, 251, 250, 0.62);
  }

  .about-chapter__media {
    position: relative;
    height: 100%;
    min-height: min(78vh, 880px);
    overflow: hidden;
    background-color: #f5f4f0;
  }

  .about-chapter__media::before {
    content: none;
  }

  .about-chapter__media img {
    position: absolute;
    inset: 0;
    z-index: 1;
    height: 100%;
    width: 100%;
    object-fit: cover;
    object-position: 50% 46%;
    filter: brightness(1.03) saturate(0.9) contrast(1.01);
    transform: scale(1.035);
    transition: transform 1400ms cubic-bezier(0.625, 0.05, 0, 1), filter 700ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .about-chapter__media:hover img {
    filter: brightness(1.04) saturate(0.94) contrast(1.02);
    transform: scale(1.055);
  }

  .about-chapter__image-shade {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background:
      linear-gradient(to right, rgba(251, 251, 250, 0.08), transparent 30%),
      linear-gradient(to top, rgba(15, 23, 42, 0.14), transparent 36%);
  }

  @media (max-width: 1180px) {
    .about-chapter__metric-value {
      font-size: clamp(0.74rem, 0.9vw, 0.92rem);
    }

    .about-chapter__metric-description {
      font-size: clamp(0.64rem, 0.72vw, 0.72rem);
    }
  }

  @media (max-width: 1023px) {
    .about-chapter__block {
      grid-template-areas:
        "copy"
        "media"
        "metrics";
      grid-template-columns: 1fr;
      grid-template-rows: auto auto auto;
    }

    .about-chapter__block::after {
      content: none;
    }

    .about-chapter__copy {
      padding: 3rem 1.35rem 2.9rem;
    }

    .about-chapter__title {
      max-width: 13ch;
      font-size: clamp(2.65rem, 9.4vw, 5rem);
    }

    .about-chapter__media-wrap {
      border-top: 1px solid rgba(15, 23, 42, 0.15);
      border-left: 0;
    }

    .about-chapter__media-wrap::before {
      content: none;
    }

    .about-chapter__media {
      min-height: 60vh;
    }

    .about-chapter__metrics {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .about-chapter__metric-value {
      min-height: 0;
      font-size: clamp(1.35rem, 4.8vw, 2.35rem);
    }

    .about-chapter__metric-description {
      font-size: 0.8125rem;
    }

    .about-chapter__metric + .about-chapter__metric {
      border-left: 0;
    }

    .about-chapter__metric:nth-child(even) {
      border-left: 1px solid rgba(15, 23, 42, 0.16);
    }

    .about-chapter__metric:nth-child(n + 3) {
      border-top: 1px solid rgba(15, 23, 42, 0.16);
    }
  }

  @media (max-width: 767px) {
    .about-chapter__inner {
      padding-top: 4.25rem;
      padding-bottom: 4.25rem;
    }

    .about-chapter__block {
      margin-top: 0;
      width: 100%;
    }

    .about-chapter__copy {
      padding: 2.55rem 1.05rem 2.35rem;
      min-width: 0;
    }

    .about-chapter__label {
      grid-template-columns: 42px auto;
      gap: 0.85rem;
      margin-bottom: 1.5rem;
    }

    .about-chapter__label-rule {
      width: 42px;
    }

    .about-chapter__title {
      max-width: 100%;
      font-size: clamp(2.02rem, 8.75vw, 3.16rem);
      line-height: 1.04;
      overflow-wrap: break-word;
    }

    .about-chapter__text {
      margin-top: 1.75rem;
      gap: 1rem;
      max-width: 100%;
      min-width: 0;
    }

    .about-chapter__text p:first-child {
      font-size: 1rem;
    }

    .about-chapter__media {
      min-height: clamp(22rem, 112vw, 28rem);
    }

    .about-chapter__media img {
      object-position: 52% 45%;
      transform: scale(1.04);
    }

    .about-chapter__metrics {
      grid-template-columns: 1fr;
      width: 100%;
      min-width: 0;
    }

    .about-chapter__metric + .about-chapter__metric,
    .about-chapter__metric:nth-child(even) {
      border-left: 0;
    }

    .about-chapter__metric:nth-child(n + 2),
    .about-chapter__metric:nth-child(n + 3) {
      border-top: 1px solid rgba(15, 23, 42, 0.14);
    }

    .about-chapter__metric {
      display: block;
      width: 100%;
      min-height: 0;
      min-width: 0;
      padding: 1.22rem 1.05rem 1.28rem;
    }

    .about-chapter__metric-mark {
      position: static;
      width: 2.25rem;
      margin: 0 0 0.9rem;
    }

    .about-chapter__metric-value {
      padding-top: 0;
      min-height: 0;
      font-size: clamp(1.25rem, 6.2vw, 1.85rem);
      line-height: 1.08;
      overflow-wrap: anywhere;
    }

    .about-chapter__metric-meta {
      margin-top: 0;
      padding-top: 0.76rem;
      min-width: 0;
    }

    .about-chapter__metric-description,
    .about-chapter__statement-text {
      overflow-wrap: break-word;
    }

    .about-chapter__metric-description {
      font-size: 0.8125rem;
      line-height: 1.45;
    }
  }

  @media (max-width: 390px) {
    .about-chapter__metric {
      grid-template-columns: 1fr;
      gap: 0.35rem;
    }

    .about-chapter__metric-meta {
      padding-top: 0;
    }
  }
</style>
