---
import { about } from "@data/homepage";

const { advantages, manifestoTitle, paragraphs } = about;
const [primaryParagraph, secondaryParagraph] = paragraphs;
const titleLines = manifestoTitle.split("\n");
---

<section id="about" class="about-chapter oc-chapter oc-chapter--about relative overflow-hidden border-t border-slate-900/10">
  <div class="section-stitch-top stitch-gallery-to-bone" aria-hidden="true"></div>

  <div class="about-chapter__inner px-5 py-16 sm:px-6 md:px-10 md:py-24 lg:px-12 lg:py-28">
    <div class="about-chapter__topbar" data-reveal>
      <span class="mono-detail oc-section-label">01</span>
      <span class="about-chapter__rule" aria-hidden="true"></span>
      <span class="mono-detail oc-section-label">О КОМПАНИИ</span>
    </div>

    <div class="about-chapter__block mt-10 md:mt-14">
      <div class="about-chapter__copy">
        <h2 class="about-chapter__title font-mono uppercase text-slate-950" data-reveal style="--reveal-delay: 0.06s;">
          {titleLines.map((line) => (
            <>
              {line}
              <br />
            </>
          ))}
        </h2>

        <span class="about-chapter__short-rule mt-9 block" aria-hidden="true" data-reveal-line style="--reveal-delay: 0.14s;"></span>

        <div class="about-chapter__text mt-8 grid max-w-[59ch] gap-5" data-reveal style="--reveal-delay: 0.18s;">
          <p
            class="text-base leading-relaxed text-slate-700 md:text-lg"
            set:html={primaryParagraph.html}
          />
          <p
            class="max-w-[52ch] text-sm leading-relaxed text-slate-600 md:text-base"
            set:html={secondaryParagraph.html}
          />
        </div>
      </div>

      <div class="about-chapter__metrics" data-reveal style="--reveal-delay: 0.22s;">
        {advantages.map((item) => (
          <article class="about-chapter__metric">
            <span class="about-chapter__metric-mark" aria-hidden="true"></span>
            <div class="about-chapter__metric-value font-mono text-slate-950">
              {item.metric}
            </div>
            <div class="about-chapter__metric-meta">
              <h3 class="font-mono text-[10px] uppercase leading-snug tracking-[0.1em] text-slate-800">
                {item.title}
              </h3>
              <p class="mt-2 text-[12px] leading-relaxed text-slate-600">
                {item.body}
              </p>
            </div>
          </article>
        ))}
      </div>

      <figure class="about-chapter__media-wrap" data-reveal style="--reveal-delay: 0.1s;">
        <div class="about-chapter__media oc-media-fallback">
          <img
            src="/img/about/about-main.jpg"
            alt="Современный жилой фасад с бетонными, стеклянными и теплыми панелями"
            loading="lazy"
            decoding="async"
            class="h-full w-full object-cover"
            onerror="this.dataset.failed='true'"
          />
          <div class="about-chapter__image-shade" aria-hidden="true"></div>
        </div>
      </figure>
    </div>
  </div>
</section>

<style>
  .about-chapter {
    --about-violet: #5d3ac4;
    color: #101827;
    contain: paint;
  }

  .about-chapter__inner {
    position: relative;
    z-index: 1;
  }

  .about-chapter__topbar {
    display: grid;
    grid-template-columns: auto minmax(44px, 88px) auto;
    align-items: center;
    justify-content: start;
    gap: 1.15rem;
  }

  .about-chapter__rule,
  .about-chapter__short-rule,
  .about-chapter__metric-mark {
    height: 1px;
    background: rgba(93, 58, 196, 0.74);
  }

  .about-chapter__rule {
    width: 100%;
    min-width: 44px;
  }

  .about-chapter__short-rule {
    width: 58px;
  }

  .about-chapter__block {
    display: grid;
    grid-template-areas:
      "copy media"
      "metrics media";
    grid-template-columns: minmax(0, 54.5fr) minmax(0, 45.5fr);
    grid-template-rows: 1fr auto;
    overflow: hidden;
    border-block: 1px solid rgba(15, 23, 42, 0.16);
    background: rgba(251, 251, 250, 0.44);
  }

  .about-chapter__copy {
    grid-area: copy;
    display: flex;
    min-width: 0;
    flex-direction: column;
    justify-content: center;
    padding: clamp(3rem, 5.2vw, 6rem) clamp(2.4rem, 5vw, 6rem) clamp(2.5rem, 4.4vw, 4.8rem) 0;
  }

  .about-chapter__title {
    max-width: 11.8ch;
    font-size: clamp(3.45rem, 6.75vw, 7.95rem);
    line-height: 0.96;
    letter-spacing: 0;
  }

  .about-chapter__text :global(strong) {
    color: #0f172a;
    font-weight: 520;
  }

  .about-chapter__metrics {
    grid-area: metrics;
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    min-width: 0;
    border-top: 1px solid rgba(15, 23, 42, 0.17);
    background: rgba(251, 251, 250, 0.7);
  }

  .about-chapter__metric {
    position: relative;
    min-width: 0;
    overflow: hidden;
    padding: clamp(1.15rem, 1.65vw, 1.75rem) clamp(0.7rem, 1.05vw, 1.1rem) clamp(1.2rem, 1.8vw, 1.85rem);
  }

  .about-chapter__metric + .about-chapter__metric {
    border-left: 1px solid rgba(15, 23, 42, 0.16);
  }

  .about-chapter__metric-mark {
    display: block;
    width: 18px;
    margin-bottom: 0.95rem;
  }

  .about-chapter__metric-value {
    max-width: 100%;
    font-size: clamp(1.16rem, 1.86vw, 2.28rem);
    line-height: 0.95;
    letter-spacing: 0;
    white-space: nowrap;
    overflow-wrap: normal;
    text-wrap: nowrap;
  }

  .about-chapter__metric-meta {
    min-width: 0;
    margin-top: 0.85rem;
  }

  .about-chapter__metric-meta p {
    display: -webkit-box;
    max-width: 100%;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .about-chapter__media-wrap {
    grid-area: media;
    min-width: 0;
    border-left: 1px solid rgba(15, 23, 42, 0.17);
  }

  .about-chapter__media {
    position: relative;
    height: 100%;
    min-height: min(78vh, 880px);
    overflow: hidden;
    background-color: #f5f4f0;
  }

  .about-chapter__media::before {
    content: none;
  }

  .about-chapter__media img {
    position: absolute;
    inset: 0;
    z-index: 1;
    height: 100%;
    width: 100%;
    object-fit: cover;
    object-position: 50% 46%;
    filter: brightness(1.03) saturate(0.9) contrast(1.01);
    transform: scale(1.035);
    transition: transform 1400ms cubic-bezier(0.625, 0.05, 0, 1), filter 700ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .about-chapter__media:hover img {
    filter: brightness(1.04) saturate(0.94) contrast(1.02);
    transform: scale(1.055);
  }

  .about-chapter__image-shade {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background:
      linear-gradient(to right, rgba(251, 251, 250, 0.08), transparent 30%),
      linear-gradient(to top, rgba(15, 23, 42, 0.14), transparent 36%);
  }

  @media (max-width: 1180px) {
    .about-chapter__metric-value {
      font-size: clamp(1.04rem, 1.62vw, 1.9rem);
    }

    .about-chapter__metric {
      padding-inline: 0.62rem;
    }
  }

  @media (max-width: 1023px) {
    .about-chapter__block {
      grid-template-areas:
        "copy"
        "media"
        "metrics";
      grid-template-columns: 1fr;
      grid-template-rows: auto auto auto;
    }

    .about-chapter__copy {
      padding: 3rem 0 2.75rem;
    }

    .about-chapter__title {
      max-width: 13ch;
      font-size: clamp(3rem, 11.2vw, 5.9rem);
    }

    .about-chapter__media-wrap {
      border-top: 1px solid rgba(15, 23, 42, 0.15);
      border-left: 0;
    }

    .about-chapter__media {
      min-height: 60vh;
    }

    .about-chapter__metrics {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .about-chapter__metric-value {
      font-size: clamp(1.8rem, 6vw, 3rem);
    }

    .about-chapter__metric + .about-chapter__metric {
      border-left: 0;
    }

    .about-chapter__metric:nth-child(even) {
      border-left: 1px solid rgba(15, 23, 42, 0.16);
    }

    .about-chapter__metric:nth-child(n + 3) {
      border-top: 1px solid rgba(15, 23, 42, 0.16);
    }
  }

  @media (max-width: 767px) {
    .about-chapter__inner {
      padding-top: 4.25rem;
      padding-bottom: 4.25rem;
    }

    .about-chapter__topbar {
      gap: 0.9rem;
    }

    .about-chapter__block {
      margin-top: 2rem;
    }

    .about-chapter__copy {
      padding: 2.3rem 0 2rem;
    }

    .about-chapter__title {
      max-width: 100%;
      font-size: clamp(2.42rem, 10.4vw, 3.75rem);
      line-height: 1;
    }

    .about-chapter__text {
      margin-top: 1.75rem;
      gap: 1rem;
    }

    .about-chapter__text p:first-child {
      font-size: 1rem;
    }

    .about-chapter__media {
      min-height: 28rem;
    }

    .about-chapter__media img {
      object-position: 52% 45%;
      transform: scale(1.04);
    }

    .about-chapter__metrics {
      grid-template-columns: 1fr;
    }

    .about-chapter__metric + .about-chapter__metric,
    .about-chapter__metric:nth-child(even) {
      border-left: 0;
    }

    .about-chapter__metric:nth-child(n + 2),
    .about-chapter__metric:nth-child(n + 3) {
      border-top: 1px solid rgba(15, 23, 42, 0.14);
    }

    .about-chapter__metric {
      display: grid;
      grid-template-columns: minmax(8.5rem, auto) 1fr;
      align-items: end;
      gap: 1.25rem;
      padding: 1.15rem 0.9rem;
    }

    .about-chapter__metric-mark {
      position: absolute;
      top: 1.1rem;
      left: 0.9rem;
      margin: 0;
    }

    .about-chapter__metric-value {
      padding-top: 1.2rem;
      font-size: clamp(2rem, 12vw, 3.15rem);
    }

    .about-chapter__metric-meta {
      margin-top: 0;
      padding-top: 1.25rem;
    }
  }

  @media (max-width: 390px) {
    .about-chapter__metric {
      grid-template-columns: 1fr;
      gap: 0.35rem;
    }

    .about-chapter__metric-meta {
      padding-top: 0;
    }
  }
</style>
