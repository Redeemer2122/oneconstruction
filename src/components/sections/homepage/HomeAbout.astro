---
const manifesto = [
  {
    index: "01",
    title: "МАТЕРИАЛ",
    body: "Стекло. Сталь. Натуральный камень. Никаких имитаций, никакого маркетингового пластика. Бескомпромиссный выбор материала важнее, чем декоративная отделка.",
    bg: "bg-[#38332f]",
    text: "text-[#f2efe9]",
    accent: "text-[#a39c8c]",
    decor: "lines",
  },
  {
    index: "02",
    title: "МЕТОД",
    body: "Архитектура как инженерное обещание. Точные планы, выверенные пропорции, честная конструкция. Мы строим то, что покажем родителям и оставим детям.",
    bg: "bg-[#7e7975]",
    text: "text-[#f2efe9]",
    accent: "text-[#d7d1c6]",
    decor: "arc",
  },
  {
    index: "03",
    title: "МАСШТАБ",
    body: "Три действующих жилых комплекса в Бишкеке, более 480 квартир спроектированы и сданы. Каждый проект как отдельный архитектурный акт, не серия.",
    bg: "bg-[#d7d1c6]",
    text: "text-[#38332f]",
    accent: "text-[#7e7975]",
    decor: "lines",
  },
  {
    index: "04",
    title: "ОБЕЩАНИЕ",
    body: "Никаких компромиссов на тишине, свете и пропорциях. Жильё, в котором утренний кофе у окна становится главным событием дня.",
    bg: "bg-[#f2efe9]",
    text: "text-[#38332f]",
    accent: "text-[#7e7975]",
    decor: "arc",
  },
];
---

<section
  id="about"
  class="relative bg-[#f2efe9] px-6 md:px-10 py-32 md:py-48 border-t border-[oklch(0.195_0.018_42_/_0.10)]"
>
  <div class="section-stitch-top stitch-alabaster-to-bone" aria-hidden="true"></div>

  <div class="grid grid-cols-12 gap-6 md:gap-10">

    <!-- Шапка секции -->
    <header class="col-span-12 flex items-baseline justify-between mb-16 md:mb-24 pb-4 border-b border-[oklch(0.195_0.018_42_/_0.10)]">
      <span class="mono-detail" data-reveal>О КОМПАНИИ</span>
      <span class="mono-detail" data-reveal style="--reveal-delay: 0.1s;">ID: 002 / MANIFESTO</span>
    </header>

    <!-- Левая колонка — заголовок-заявление -->
    <div class="col-span-12 md:col-span-5 flex flex-col gap-6">
      <h2
        class="display text-4xl md:text-6xl xl:text-7xl leading-[0.92] tracking-tighter text-[#38332f] max-w-[16ch]"
        data-reveal
        style="--reveal-delay: 0.05s;"
      >
        Мы создаём пространство, в котором хочется жить.
      </h2>
      <p
        class="text-base md:text-lg text-[#7e7975] leading-relaxed max-w-[42ch]"
        data-reveal
        style="--reveal-delay: 0.12s;"
      >
        Не функцию, в которой приходится существовать. Архитектура без компромисса.
      </p>
    </div>

    <!-- Правая колонка — 4 плиты манифеста -->
    <div class="col-span-12 md:col-span-7 grid grid-cols-1 md:grid-cols-2 gap-0 border border-[oklch(0.195_0.018_42_/_0.10)]">
      {manifesto.map((item, idx) => (
        <article
          class={`relative flex flex-col gap-4 p-7 md:p-8 ${item.bg} overflow-hidden min-h-[220px]
                  border-b border-r border-[oklch(0.195_0.018_42_/_0.10)]
                  md:even:border-r-0 md:[&:nth-last-child(-n+2)]:border-b-0`}
          data-reveal
          style={`--reveal-delay: ${0.08 + idx * 0.07}s;`}
        >
          {/* Векторный декор — чистые чертёжные формы */}
          {item.decor === "lines" && (
            <span
              aria-hidden="true"
              class="absolute inset-0 pointer-events-none"
              style={{
                backgroundImage: `repeating-linear-gradient(to right, currentColor 0px, currentColor 1px, transparent 1px, transparent 10px)`,
                opacity: "0.05",
              }}
            />
          )}
          {item.decor === "arc" && (
            <svg
              aria-hidden="true"
              class="absolute bottom-0 right-0 pointer-events-none"
              width="130"
              height="90"
              viewBox="0 0 130 90"
              style="opacity: 0.07;"
            >
              {[24, 44, 64, 84, 104, 124].map((r) => (
                <path
                  d={`M ${130 - r} 90 A ${r} ${r * 0.69} 0 0 1 130 ${90 - r * 0.69}`}
                  fill="none"
                  stroke="currentColor"
                  stroke-width="0.8"
                />
              ))}
            </svg>
          )}

          {/* Моноширинный индекс */}
          <span class={`relative font-mono text-[10px] uppercase tracking-[0.22em] ${item.accent} opacity-60`}>
            {item.index}
          </span>

          {/* Заголовок */}
          <h3 class={`relative font-mono text-xs uppercase tracking-[0.20em] ${item.accent}`}>
            {item.title}
          </h3>

          {/* Текст */}
          <p class={`relative text-sm leading-relaxed ${item.text} opacity-80 mt-auto`}>
            {item.body}
          </p>
        </article>
      ))}
    </div>

  </div>
</section>
