---
/**
 * HomeAbout — манифест компании в виде чертежной сетки.
 *
 * Композиция: строгие тонкие стальные ячейки (border-slate-200) с
 * моноширинными индексами (01, 02, 03, 04) на Geist Mono. Слева —
 * крупный бруталистичный заголовок-заявление.
 */
const manifesto = [
  {
    index: "01",
    title: "МАТЕРИАЛ",
    body: "Стекло. Сталь. Натуральный камень. Никаких имитаций, никакого маркетингового пластика. Бескомпромиссный выбор материала важнее, чем декоративная отделка.",
  },
  {
    index: "02",
    title: "МЕТОД",
    body: "Архитектура как инженерное обещание. Точные планы, выверенные пропорции, честная конструкция. Мы строим то, что покажем родителям и оставим детям.",
  },
  {
    index: "03",
    title: "МАСШТАБ",
    body: "Три действующих жилых комплекса в Бишкеке, более 480 квартир спроектированы и сданы. Каждый проект как отдельный архитектурный акт, не серия.",
  },
  {
    index: "04",
    title: "ОБЕЩАНИЕ",
    body: "Никаких компромиссов на тишине, свете и пропорциях. Жильё, в котором утренний кофе у окна становится главным событием дня.",
  },
];
---

<section
  id="about"
  class="relative bg-bone px-6 md:px-10 py-32 md:py-48 border-t-[0.5px] border-slate-200"
>
  <div class="section-stitch-top stitch-alabaster-to-bone" aria-hidden="true"></div>
  <div class="grid grid-cols-12 gap-6 md:gap-10">
    <header class="col-span-12 flex items-baseline justify-between mb-16 md:mb-24 pb-4 border-b-[0.5px] border-slate-200">
      <span class="mono-detail" data-reveal>О КОМПАНИИ</span>
      <span class="mono-detail" data-reveal style="--reveal-delay: 0.1s;">ID: 002 / MANIFESTO</span>
    </header>

    <div class="col-span-12 md:col-span-5 flex flex-col gap-6">
      <h2
        class="display text-4xl md:text-6xl xl:text-7xl leading-[0.92] tracking-tighter text-slate-900 max-w-[16ch]"
        data-reveal
        style="--reveal-delay: 0.05s;"
      >
        Мы создаём пространство, в котором хочется жить.
      </h2>
      <p
        class="text-base md:text-lg text-slate-600 leading-relaxed max-w-[42ch]"
        data-reveal
        style="--reveal-delay: 0.12s;"
      >
        Не функцию, в которой приходится существовать. Архитектура без компромисса.
      </p>
    </div>

    <div class="col-span-12 md:col-span-7 grid grid-cols-1 md:grid-cols-2 gap-0 border-[0.5px] border-slate-200">
      {
        manifesto.map((item, idx) => (
          <article
            class="flex flex-col gap-4 p-6 md:p-8 border-b-[0.5px] md:border-r-[0.5px] border-slate-200 last:border-b-0 md:even:border-r-0 md:[&:nth-last-child(-n+2)]:border-b-0"
            data-reveal
            style={`--reveal-delay: ${0.08 + idx * 0.08}s;`}
          >
            <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-slate-400">
              {item.index}
            </span>
            <h3 class="font-mono text-sm uppercase tracking-[0.18em] text-violet-600">
              {item.title}
            </h3>
            <p class="text-sm md:text-base text-slate-700 leading-relaxed">
              {item.body}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>
