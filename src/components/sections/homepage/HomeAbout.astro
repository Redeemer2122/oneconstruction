---
const manifesto = [
  {
    index: "01",
    title: "МАТЕРИАЛ",
    body: "Стекло. Сталь. Натуральный камень. Никаких имитаций, никакого маркетингового пластика.",
  },
  {
    index: "02",
    title: "МЕТОД",
    body: "Архитектура как инженерное обещание. Точные планы, выверенные пропорции, честная конструкция.",
  },
  {
    index: "03",
    title: "МАСШТАБ",
    body: "Три действующих ЖК в Бишкеке, более 480 квартир спроектированы и сданы. Каждый проект — отдельный архитектурный акт.",
  },
  {
    index: "04",
    title: "ОБЕЩАНИЕ",
    body: "Никаких компромиссов на тишине, свете и пропорциях. Жильё, в котором утренний кофе у окна — главное событие дня.",
  },
];
---

<section
  id="about"
  class="relative bg-[#F5F4F0] border-t border-slate-200 overflow-hidden"
>
  <div class="section-stitch-top stitch-alabaster-to-limestone" aria-hidden="true"></div>

  <div class="px-6 md:px-10 lg:px-12 py-24 md:py-40">

    <!-- Section header -->
    <header class="flex items-baseline justify-between pb-6 mb-20 md:mb-32 border-b border-slate-200">
      <span class="mono-detail" data-reveal>О КОМПАНИИ</span>
      <span class="mono-detail" data-reveal style="--reveal-delay: 0.1s;">SEC: 002 / MANIFESTO</span>
    </header>

    <!-- Intro statement -->
    <div class="mb-24 md:mb-40 max-w-[58ch]" data-reveal style="--reveal-delay: 0.12s;">
      <h2 class="font-mono text-2xl md:text-4xl xl:text-5xl uppercase tracking-tight text-slate-900 leading-[1.1]">
        Мы создаём пространство,<br/>в котором хочется жить.
      </h2>
    </div>

    <!-- INTERACTIVE DRAFTING BOARD — asymmetric overlapping plates -->
    <div class="kulman-board relative min-h-[700px] md:min-h-[600px]" data-reveal style="--reveal-delay: 0.2s;">

      <!-- SVG connector lines layer -->
      <svg
        class="kulman-lines absolute inset-0 w-full h-full pointer-events-none z-[5]"
        aria-hidden="true"
        preserveAspectRatio="none"
      >
        <!-- Horizontal axis line -->
        <line class="kulman-line" data-connects="01-02" x1="28%" y1="18%" x2="55%" y2="22%" stroke="#64748b" stroke-width="1.5" stroke-dasharray="6 4" />
        <!-- Diagonal connector -->
        <line class="kulman-line" data-connects="01-03" x1="22%" y1="42%" x2="38%" y2="58%" stroke="#64748b" stroke-width="1.5" stroke-dasharray="6 4" />
        <!-- Vertical connector -->
        <line class="kulman-line" data-connects="02-04" x1="68%" y1="38%" x2="62%" y2="62%" stroke="#64748b" stroke-width="1.5" stroke-dasharray="6 4" />
        <!-- Cross connector -->
        <line class="kulman-line" data-connects="03-04" x1="48%" y1="72%" x2="58%" y2="68%" stroke="#64748b" stroke-width="1.5" stroke-dasharray="6 4" />

        <!-- Axis circles -->
        <circle class="kulman-node" data-node="01" cx="28%" cy="18%" r="4" fill="none" stroke="#64748b" stroke-width="1.5" />
        <circle class="kulman-node" data-node="02" cx="55%" cy="22%" r="4" fill="none" stroke="#64748b" stroke-width="1.5" />
        <circle class="kulman-node" data-node="03" cx="38%" cy="58%" r="4" fill="none" stroke="#64748b" stroke-width="1.5" />
        <circle class="kulman-node" data-node="04" cx="62%" cy="62%" r="4" fill="none" stroke="#64748b" stroke-width="1.5" />

        <!-- Arrow indicators -->
        <polygon class="kulman-arrow" data-connects="01-02" points="0,-4 8,0 0,4" fill="#64748b" transform="translate(200, 80) rotate(8)" />
        <polygon class="kulman-arrow" data-connects="02-04" points="0,-4 8,0 0,4" fill="#64748b" transform="translate(480, 240) rotate(78)" />
      </svg>

      <!-- Plate 01 — top-left, widest -->
      <article
        class="kulman-plate absolute top-0 left-0 w-[72%] md:w-[52%] z-10 bg-[#FBFBFA] border border-slate-200 p-6 md:p-8 transition-all duration-500 hover:z-30 hover:shadow-[0_8px_40px_-12px_rgba(30,41,59,0.10)] hover:border-slate-400"
        data-plate="01"
      >
        <span
          class="absolute -top-2 -left-2 md:-top-3 md:-left-3 font-mono text-[72px] md:text-[100px] leading-none tracking-tighter text-slate-900/[0.05] select-none pointer-events-none"
          aria-hidden="true"
        >01</span>
        <div class="relative z-10">
          <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-slate-400 block mb-3">01</span>
          <h3 class="font-mono text-sm md:text-base uppercase tracking-[0.14em] text-slate-900 mb-4">{manifesto[0].title}</h3>
          <p class="text-sm text-slate-600 leading-relaxed max-w-[32ch]">{manifesto[0].body}</p>
        </div>
      </article>

      <!-- Plate 02 — top-right, narrower, overlaps plate 01 -->
      <article
        class="kulman-plate absolute top-[8%] right-0 md:right-[4%] w-[58%] md:w-[42%] z-20 bg-[#FBFBFA] border border-slate-200 p-6 md:p-8 transition-all duration-500 hover:z-30 hover:shadow-[0_8px_40px_-12px_rgba(30,41,59,0.10)] hover:border-slate-400"
        data-plate="02"
      >
        <span
          class="absolute -top-2 -right-2 md:-top-3 md:-right-3 font-mono text-[72px] md:text-[100px] leading-none tracking-tighter text-slate-900/[0.05] select-none pointer-events-none"
          aria-hidden="true"
        >02</span>
        <div class="relative z-10">
          <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-slate-400 block mb-3">02</span>
          <h3 class="font-mono text-sm md:text-base uppercase tracking-[0.14em] text-slate-900 mb-4">{manifesto[1].title}</h3>
          <p class="text-sm text-slate-600 leading-relaxed max-w-[32ch]">{manifesto[1].body}</p>
        </div>
      </article>

      <!-- Plate 03 — bottom-left, medium width, overlaps plate 01 bottom -->
      <article
        class="kulman-plate absolute top-[52%] left-[4%] md:left-[8%] w-[62%] md:w-[44%] z-10 bg-[#FBFBFA] border border-slate-200 p-6 md:p-8 transition-all duration-500 hover:z-30 hover:shadow-[0_8px_40px_-12px_rgba(30,41,59,0.10)] hover:border-slate-400"
        data-plate="03"
      >
        <span
          class="absolute -bottom-2 -left-2 md:-bottom-3 md:-left-3 font-mono text-[72px] md:text-[100px] leading-none tracking-tighter text-slate-900/[0.05] select-none pointer-events-none"
          aria-hidden="true"
        >03</span>
        <div class="relative z-10">
          <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-slate-400 block mb-3">03</span>
          <h3 class="font-mono text-sm md:text-base uppercase tracking-[0.14em] text-slate-900 mb-4">{manifesto[2].title}</h3>
          <p class="text-sm text-slate-600 leading-relaxed max-w-[32ch]">{manifesto[2].body}</p>
        </div>
      </article>

      <!-- Plate 04 — bottom-right, narrow tall, overlaps 02 and 03 -->
      <article
        class="kulman-plate absolute top-[48%] right-[2%] md:right-[6%] w-[54%] md:w-[38%] z-20 bg-[#FBFBFA] border border-slate-200 p-6 md:p-8 transition-all duration-500 hover:z-30 hover:shadow-[0_8px_40px_-12px_rgba(30,41,59,0.10)] hover:border-slate-400"
        data-plate="04"
      >
        <span
          class="absolute -bottom-2 -right-2 md:-bottom-3 md:-right-3 font-mono text-[72px] md:text-[100px] leading-none tracking-tighter text-slate-900/[0.05] select-none pointer-events-none"
          aria-hidden="true"
        >04</span>
        <div class="relative z-10">
          <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-slate-400 block mb-3">04</span>
          <h3 class="font-mono text-sm md:text-base uppercase tracking-[0.14em] text-slate-900 mb-4">{manifesto[3].title}</h3>
          <p class="text-sm text-slate-600 leading-relaxed max-w-[32ch]">{manifesto[3].body}</p>
        </div>
      </article>

    </div>
  </div>
</section>

<script>
  const board = document.querySelector('.kulman-board');
  if (board) {
    const plates = board.querySelectorAll<HTMLElement>('.kulman-plate');
    const lines = board.querySelectorAll<SVGElement>('.kulman-line');
    const nodes = board.querySelectorAll<SVGElement>('.kulman-node');
    const arrows = board.querySelectorAll<SVGElement>('.kulman-arrow');

    const allSvgElements = [...lines, ...nodes, ...arrows];
    allSvgElements.forEach((el) => {
      (el as HTMLElement).style.transition = 'all 0.3s ease';
    });

    plates.forEach((plate) => {
      const id = plate.dataset.plate;

      plate.addEventListener('mouseenter', () => {
        lines.forEach((line) => {
          const connects = line.dataset.connects || '';
          if (connects.includes(id!)) {
            line.style.stroke = '#0f172a';
            line.style.strokeWidth = '2.5';
            line.style.opacity = '1';
          } else {
            line.style.opacity = '0.15';
            line.style.strokeWidth = '1';
          }
        });
        nodes.forEach((node) => {
          const nodeId = node.dataset.node || '';
          if (nodeId === id) {
            node.style.stroke = '#0f172a';
            node.style.strokeWidth = '2.5';
            node.style.fill = '#0f172a';
          } else {
            node.style.opacity = '0.2';
          }
        });
        arrows.forEach((arrow) => {
          const connects = arrow.dataset.connects || '';
          if (connects.includes(id!)) {
            arrow.style.fill = '#0f172a';
            arrow.style.opacity = '1';
          } else {
            arrow.style.opacity = '0.15';
          }
        });
      });

      plate.addEventListener('mouseleave', () => {
        lines.forEach((line) => {
          line.style.stroke = '#64748b';
          line.style.strokeWidth = '1.5';
          line.style.opacity = '1';
        });
        nodes.forEach((node) => {
          node.style.stroke = '#64748b';
          node.style.strokeWidth = '1.5';
          node.style.fill = 'none';
          node.style.opacity = '1';
        });
        arrows.forEach((arrow) => {
          arrow.style.fill = '#64748b';
          arrow.style.opacity = '1';
        });
      });
    });
  }
</script>
