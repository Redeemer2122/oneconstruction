---
/**
 * Button — премиальная кнопка.
 * НЕТ скруглений, НЕТ bounce. Tactile feedback: scale[0.98] на :active.
 * Hover — заливка кобальтом сквозь маску, не glow.
 */
interface Props {
  href?: string;
  variant?: "primary" | "ghost";
  type?: "button" | "submit";
  class?: string;
}

const { href, variant = "primary", type = "button", class: className = "" } = Astro.props;

const base =
  "group relative inline-flex items-center gap-3 px-6 py-3 text-[11px] uppercase tracking-[0.18em] font-mono transition-transform duration-300 ease-[cubic-bezier(0.22,1,0.36,1)] active:scale-[0.98]";

const styles = {
  primary:
    "bg-ink-100 text-ink-950 border-[0.5px] border-ink-100 hover:bg-cobalt-500 hover:text-ink-100 hover:border-cobalt-500",
  ghost:
    "bg-transparent text-ink-100 border-[0.5px] border-white/15 hover:border-white/40",
};

const Tag = href ? "a" : "button";
---

<Tag
  {...(href ? { href } : { type })}
  class={`${base} ${styles[variant]} ${className}`}
>
  <slot />
  <span aria-hidden="true" class="block w-4 h-px bg-current transition-[width] duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:w-8"></span>
</Tag>
